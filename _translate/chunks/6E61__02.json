{
"i": 706,
"t": "8. Müalicə"
},
{
"i": 707,
"t": "Etioloji müalicə — tibbi vəziyyət və ya dərman korreksiyası."
},
{
"i": 708,
"t": "Simptomatik psixiatrik müalicə:"
},
{
"i": 709,
"t": "Depresiv — SSRİ (xəstəlik-spesifik seçim; kardiyak — sertralin, esitalopram; onkoloji — mirtazapin);"
},
{
"i": 710,
"t": "Manik — antipsixotik (kvetiapin, olanzapin); steroid induksiyalı manik halda steroidin azaltma və ya antipsixotik;"
},
{
"i": 711,
"t": "Qarışıq və ya refrakter — EKT."
},
{
"i": 712,
"t": "Multidisiplinarlı koordinasiya."
},
{
"i": 713,
"t": "Müalicə metodikaları"
},
{
"i": 714,
"t": "Etioloji Müdaxilə"
},
{
"i": 715,
"t": "— Tibbi vəziyyət və ya dərman dəyişdirmə."
},
{
"i": 716,
"t": "SSRİ Xəstəlik-Spesifik"
},
{
"i": 717,
"t": "— Kardiyak, onkoloji, neyroloji kontekstə uyğun seçim."
},
{
"i": 718,
"t": "EKT"
},
{
"i": 719,
"t": "— Refrakter və ağır halda."
},
{
"i": 720,
"t": "9. Proqnoz"
},
{
"i": 721,
"t": "Etioloji müdaxilə ilə əksər remisya."
},
{
"i": 722,
"t": "10. Mif və yanlış inanclar"
},
{
"i": 723,
"t": "Mif 1: \"Tibbi xəstəlikli pasiyent üçün depresiya \"normal\"-dır\""
},
{
"i": 724,
"t": "Sübut:"
},
{
"i": 725,
"t": "klinik depresiya tibbi vəziyyətin gedişini pisləşdirir; aktiv müdaxilə tələb edir."
},
{
"i": 726,
"t": "Mif 2: \"Steroid induksiyalı mania özü-özünə keçir\""
},
{
"i": 727,
"t": "Sübut:"
},
{
"i": 728,
"t": "dozanın azaldılması və ya antipsixotik əlavə tələb olunur."
},
{
"i": 729,
"t": "Mif 3: \"Antidepresant hipotireoiddə birinci sıra\""
},
{
"i": 730,
"t": "Sübut:"
},
{
"i": 731,
"t": "tireoid korreksiyası birinci; antidepresant qalıq simptomlar üçün."
},
{
"i": 732,
"t": "Mif 4: \"İnterferon depresiyası nadir\""
},
{
"i": 733,
"t": "Sübut:"
},
{
"i": 734,
"t": "HCV interferon terapiyasında 20–40% — aktiv izləmə tələb olunur."
},
{
