},
{
"i": 695,
"t": "Bipolyar birinci"
},
{
"i": 696,
"t": "Affektiv epizod tarixçəsi tibbi səbəb olmadan."
},
{
"i": 697,
"t": "Adaptasiya pozuntusu (6B40)"
},
{
