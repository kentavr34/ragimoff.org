{
"id": "elave-acde__01",
"file": "elave-acde.html",
"segments": [
{
"i": 361,
"t": "Hər rüb"
},
{
"i": 362,
"t": "&gt;"
},
{
"i": 363,
"t": "Kritik:"
},
{
"i": 364,
"t": "valproat"
},
{
"i": 365,
"t": "doğuş yaşlı qadınlarda"
},
{
"i": 366,
"t": "neyral boru defekti və koqnitiv zərər səbəbinə görə"
},
{
"i": 367,
"t": "yalnız effektiv kontrasepsiya ilə"
},
{
"i": 368,
"t": ", digər seçimlər əvvəlcə qiymətləndirildikdən sonra."
},
{
"i": 369,
"t": "Karbamazepin:"
},
{
"i": 370,
"t": "CBC, qaraciyər – başlanğıc, 1 ay, rüblük;"
},
{
"i": 371,
"t": "HLA-B*1502 testi"
},
{
"i": 372,
"t": "Asiya mənşəli pasiyentlərdə (Stevens-Johnson riski);"
},
{
"i": 373,
"t": "Auto-induksiya səbəbindən səviyyənin enməsi ilk 4 həftədə – səviyyə yoxla."
},
{
"i": 374,
"t": "Lamotrigin:"
},
{
"i": 375,
"t": "Yavaş titrasiya"
},
{
"i": 376,
"t": "– Stevens-Johnson sindromu riski;"
},
{
"i": 377,
"t": "Başlanğıc 25 mq həftədə"
},
{
"i": 378,
"t": ", 4–8 həftə ərzində hədəf dozaya;"
},
{
"i": 379,
"t": "Valproat ilə birlikdə:"
},
{
"i": 380,
"t": "başlanğıc 12,5 mq"
},
{
"i": 381,
"t": "– valproat lamotrigin metabolizmini yavaşlatır;"
},
{
"i": 382,
"t": "Dəri reaksiyası olsa –"
},
{
"i": 383,
"t": "dərhal dayandır."
},
{
"i": 384,
"t": "A.4. SSRİ və SNRİ monitorinqi"
},
{
"i": 385,
"t": "Hiponatremiya riski"
},
{
"i": 386,
"t": "– xüsusilə yaşlılarda, diuretik istifadə edənlərdə;"
},
{
"i": 387,
"t": "Bazal Na"
},
{
"i": 388,
"t": ", 1 ay sonra, sonra simptom ilə;"
},
{
"i": 389,
"t": "Suicidalitet artımı"
},
{
"i": 390,
"t": "xüsusilə 25 yaşdan aşağı başlanğıcda – ilk 1-2 ay yaxın monitorinq;"
},
{
"i": 391,
"t": "QTc uzanma"
},
{
"i": 392,
"t": "– esitalopram, sitalopram (yüksək dozalarda);"
},
{
"i": 393,
"t": "Serotonin sindromu"
},
{
"i": 394,
"t": "(MAOİ və ya triptan və s. kombinasiyada) – əlamətlərin öyrədilməsi."
},
{
"i": 395,
"t": "A.5. Benzodiazepin istifadəsi"
},
{
"i": 396,
"t": "Maximum uzunluq: 2–4 həftə"
},
{
"i": 397,
"t": "Uzunmüddətli istifadədə asılılıq qaçılmazdır;"
},
{
"i": 398,
"t": "Azaltma sxemi (tapering):"
},
{
"i": 399,
"t": "25% hər 2 həftə, bəzən daha yavaş;"
},
{
"i": 400,
"t": "Geriyə təpki simptomları"
},
{
"i": 401,
"t": "(rebound anxiety, yuxusuzluq, tremor) normal və müvəqqətidir."
},
{
"i": 402,
"t": "A.6. Psixoterapiya monitorinqi"
},
{
"i": 403,
"t": "Keyfiyyət göstəriciləri:"
},
{
"i": 404,
"t": "Seansın davam müddəti, tezlik;"
},
{
"i": 405,
"t": "Xəstə simptom şkalaları (PHQ-9, GAD-7 və s.)"
},
{
"i": 406,
"t": "hər 4–6 həftə"
},
{
"i": 407,
"t": "Funksional göstəricilər;"
},
{
"i": 408,
"t": "Terapevtik əlaqə qiymətləndirilməsi (Working Alliance Inventory);"
},
{
"i": 409,
"t": "Kənar məqsədlərə çatma;"
},
{
"i": 410,
"t": "Residiv əlamətləri."
},
{
"i": 411,
"t": "Supervision və kolleqial konsultasiya – kompleks pasiyentlərdə və istəyən klinisist üçün."
},
{
"i": 412,
"t": "ƏLAVƏ C"
},
{
"i": 413,
"t": "PSİXİATRİK TƏCİLİ VƏZİYYƏTLƏR"
},
{
"i": 414,
"t": "Bu əlavə həyatı təhdid edən və ya kəskin kliniki dəyərləndirmə tələb edən psixiatrik vəziyyətlərə praktik yanaşma təqdim edir."
},
{
"i": 415,
"t": "C.1. Aktiv intihar riski"
},
{
"i": 416,
"t": "İlkin qiymətləndirmə:"
},
{
"i": 417,
"t": "İntihar düşüncəsi varmı? Plan? Vasitə?"
},
{
"i": 418,
"t": "Yaxınlıq, konkretlik:"
},
{
"i": 419,
"t": "&quot;Bu gün axşam həyətəm tabançayla...&quot;  vs ümumi &quot;Bəzən ölmək istəyirəm&quot;;"
},
{
"i": 420,
"t": "Əvvəlki cəhdlər"
},
{
"i": 421,
"t": "– ən güclü prediktor;"
},
{
"i": 422,
"t": "Maddə intoksikasiyası"
},
{
"i": 423,
"t": "– inhibisiya azalır;"
},
{
"i": 424,
"t": "Protektiv faktorlar"
},
{
"i": 425,
"t": "– ailə, dini inanclar, gələcək planlar."
},
{
"i": 426,
"t": "Yüksək risk əlamətləri:"
},
{
"i": 427,
"t": "Konkret plan + vasitələrə çatımlılıq;"
},
{
"i": 428,
"t": "Yaxın vəziyyət dəyişikliyi (itki, ağır xəstəlik);"
},
{
"i": 429,
"t": "Təklik + rağın;"
},
{
"i": 430,
"t": "Psixoz və ya ağır depressiya;"
},
{
"i": 431,
"t": "Yeni başlanğıc və ya dərin hipomania (enerji qayıdır + aşağı əhval qalır);"
},
{
"i": 432,
"t": "Yetkin kişi + əlillik + alkogol."
},
{
"i": 433,
"t": "İdarəetmə:"
},
{
"i": 434,
"t": "Aşağı-orta risk:"
},
{
"i": 435,
"t": "Təhlükəsizlik planı"
},
{
"i": 436,
"t": "– yazılı;"
},
{
"i": 437,
"t": "Vasitələrə çatımlılığın azaldılması (silah uzaqlaşdırılması, dərman kiçik miqdarlarda);"
},
{
"i": 438,
"t": "Yaxın ambulator izləmə (24-48 saatda yenidən);"
},
{
"i": 439,
"t": "Krizi xətti nömrəsi;"
},
{
"i": 440,
"t": "Ailə iştirakı (razılıqla)."
},
{
"i": 441,
"t": "Yüksək risk:"
},
{
"i": 442,
"t": "Hospitalizasiya"
},
{
"i": 443,
"t": "(könüllü və ya məcburi);"
},
{
"i": 444,
"t": "Yaxın nəzarət – 1:1 əgər çox yüksək;"
},
{
"i": 445,
"t": "İntihar üsullarının kənarlaşdırılması (kəskin əşya, ip, pəncərə);"
},
{
"i": 446,
"t": "Nəzarətli dərman qəbulu."
},
{
"i": 447,
"t": "Məcburi hospitalizasiya Azərbaycan çərçivəsində:"
},
{
"i": 448,
"t": "&quot;Psixiatrik yardım haqqında&quot; Azərbaycan Respublikası qanunu;"
},
{
"i": 449,
"t": "Məcburi hospitalizasiya üçün"
},
{
"i": 450,
"t": "iki psixiatrın qərarı"
},
{
"i": 451,
"t": "və hüquqi prosedur;"
},
{
"i": 452,
"t": "72 saat təcili müşahidə sonra məhkəmə qərarı."
},
{
"i": 453,
"t": "C.2. Delirium tremens və alkogol kəsilməsi"
},
{
"i": 454,
"t": "Simptomlar:"
},
{
"i": 455,
"t": "Tremor"
},
{
"i": 456,
"t": "– əllər, sonra ümumi;"
},
{
"i": 457,
"t": "Təşviş, aqitasiya;"
},
{
"i": 458,
"t": "Halüsinasiya"
},
{
"i": 459,
"t": "– visual, tactile (&quot;həşəratlar üzərimdə&quot;);"
},
{
"i": 460,
"t": "Dezorientasiya;"
},
{
"i": 461,
"t": "Autonom hiperaktivlik"
},
{
"i": 462,
"t": "– taksikardiya, təzyiq, tərləmə, qızdırma;"
},
{
"i": 463,
"t": "Tutmalar"
},
{
"i": 464,
"t": "Müalicə (ICU və ya IMU şəraitində):"
},
{
"i": 465,
"t": "Benzodiazepin"
},
{
"i": 466,
"t": "diazepam 10-20 mq IV/IM hər 15-20 dəq"
},
{
"i": 467,
"t": "sedasyon əldə olunana qədər; sonra saxlayıcı rejim;"
},
{
"i": 468,
"t": "Alternativ: lorazepam (qaraciyər disfunksiyası olanlarda);"
},
{
"i": 469,
"t": "Tiamin 100-300 mq IV"
},
{
"i": 470,
"t": "– Wernicke ensefalopatiyasının qarşısının alınması."
},
{
"i": 471,
"t": "Qlukoza verməzdən əvvəl"
},
{
"i": 472,
"t": "Maye və elektrolit"
},
{
"i": 473,
"t": "bərpası;"
},
{
"i": 474,
"t": "Magnezium sulfatı, kalium – çox vaxt aşağı;"
},
{
"i": 475,
"t": "Ölümçüllük: müalicəsiz 15-20%, adekvat müalicə ilə &lt;1%."
},
{
"i": 476,
"t": "CIWA-Ar shkalası – monitorinqdə."
},
{
"i": 477,
"t": "C.3. Serotonin sindromu"
},
{
"i": 478,
"t": "Səbəb:"
},
{
"i": 479,
"t": "SSRİ + MAOİ, SSRİ + triptan, SSRİ + tramadol, SSRİ + linezolid, SSRİ + metilen mavisi və s."
},
{
"i": 480,
"t": "Simptomlar:"
},
{
"i": 481,
"t": "Mental dəyişiklik"
},
{
"i": 482,
"t": "– aqitasiya, konfüziya;"
},
{
"i": 483,
"t": "Autonom"
},
{
"i": 484,
"t": "– taksikardiya, hipertoniya, hipertermiya, tərləmə;"
},
{
"i": 485,
"t": "Neyromuskulyar"
},
{
"i": 486,
"t": "– tremor, hiperrefleksiya,"
},
{
"i": 487,
"t": "klonus"
},
{
"i": 488,
"t": "(alt ekstremite – xüsusi əlamət)."
},
{
"i": 489,
"t": "Müalicə:"
},
{
"i": 490,
"t": "Səbəb dərmanının dərhal kəsilməsi;"
},
{
"i": 491,
"t": "Destek – mayelər, elektrolit, soyutma;"
},
{
"i": 492,
"t": "Ağır hallarda"
},
{
"i": 493,
"t": "siproheptadin 12 mq ilkin, 2 mq hər saat maksimum 32 mq/gün"
},
{
"i": 494,
"t": "İnvaziv müdaxilə (intubasiya) ağır hipertermiyada."
},
{
"i": 495,
"t": "C.4. Antipsixotik Malign Sindrom (NMS)"
},
{
"i": 496,
"t": "Səbəb:"
},
{
"i": 497,
"t": "antipsikotiklər (xüsusilə yüksək güclü, haloperidol), kəskin başlanğıc və ya dozanın artırılması."
},
{
"i": 498,
"t": "Simptomlar (4 əsas):"
},
{
"i": 499,
"t": "Əzələ sərtliyi"
},
{
"i": 500,
"t": "(&quot;qurğuşun boru&quot;);"
},
{
"i": 501,
"t": "Hipertermiya"
},
{
"i": 502,
"t": "(38–42°C);"
},
{
"i": 503,
"t": "Autonom dəyişkənlik"
},
{
"i": 504,
"t": "(yüksək arterial təzyiq, taksikardiya, tərləmə);"
},
{
"i": 505,
"t": "Mental vəziyyət dəyişikliyi"
},
{
"i": 506,
"t": "(konfüziya → stupor → koma)."
},
{
"i": 507,
"t": "Laboratoriya:"
},
{
"i": 508,
"t": "CPK kəskin yüksək"
},
{
"i": 509,
"t": "(&gt;1000), mioqlobinuriya, leykositoz, ALT/AST yüksək."
},
{
"i": 510,
"t": "Müalicə (ICU):"
},
{
"i": 511,
"t": "Antipsikotikin dərhal kəsilməsi;"
},
{
"i": 512,
"t": "Soyutma;"
},
{
"i": 513,
"t": "Mayelər (rabdomioliz və akut böyrək çatışmazlığı riski);"
},
{
"i": 514,
"t": "Dantrolen"
},
{
"i": 515,
"t": "1-2,5 mq/kq IV – əzələ sərtliyi azaldır;"
},
{
"i": 516,
"t": "Bromokriptin"
},
{
"i": 517,
"t": "2,5-5 mq hər 8 saat – dopamin agonisti;"
},
{
"i": 518,
"t": "EKT cavabsız hallarda."
},
{
"i": 519,
"t": "Ölümçüllük:"
},
{
"i": 520,
"t": "5-20% adekvat müalicə ilə."
},
{
"i": 521,
"t": "C.5. Kəskin distoniya"
},
{
"i": 522,
"t": "Səbəb:"
},
{
"i": 523,
"t": "antipsikotik başlanğıcı, xüsusilə güclü D2 antaqonistləri."
},
{
"i": 524,
"t": "Simptomlar:"
},
{
"i": 525,
"t": "Kəskin əzələ spazmları – boyun (tortikolis), dil, göz (okuloqirik kriz), müəyyən qida-boru spazmı;"
},
{
"i": 526,
"t": "Həyat təhlükəsi – laringeal spazm."
},
{
"i": 527,
"t": "Müalicə:"
},
{
"i": 528,
"t": "Difenhidramin"
},
{
"i": 529,
"t": "50 mq IM/IV – 15 dəqiqəyə rahatlama;"
},
{
"i": 530,
"t": "Benztropin"
},
{
"i": 531,
"t": "1-2 mq IM/IV;"
},
{
"i": 532,
"t": "Antipsikotikin dozasının azaldılması və ya dəyişdirilməsi;"
},
{
"i": 533,
"t": "Profilaktik antikolinergik riskli pasiyentlərdə."
},
{
"i": 534,
"t": "C.6. Kəskin mania və psixomotor aqitasiya"
},
{
"i": 535,
"t": "İdarəetmə:"
},
{
"i": 536,
"t": "- Oral tercihli: haloperidol 2-5 mq + lorazepam 1-2 mq;"
},
{
"i": 537,
"t": "- IM göstərişlə: haloperidol 5 mq + lorazepam 2 mq (50/50 şpris) və ya olanzapin IM 10 mq;"
},
{
"i": 538,
"t": "Təhlükəsiz mühit"
},
{
"i": 539,
"t": "– sakit, stimullardan azad;"
},
{
"i": 540,
"t": "Verbal de-eskalasiya"
},
{
"i": 541,
"t": "ilk addım;"
},
{
"i": 542,
"t": "Dərman:"
},
{
"i": 543,
"t": "Qeyri-könüllü hospitalizasiya"
},
{
"i": 544,
"t": "göstərişlə;"
},
{
"i": 545,
"t": "Fiziki təmkin"
},
{
"i": 546,
"t": "– yalnız son seçim, şəxsi həyat təhlükəsi, qısamüddətli."
},
{
"i": 547,
"t": "C.7. Kəskin psixoz"
},
{
"i": 548,
"t": "Yuxarıdakı ilə oxşar protokol. Diferensial: üzvi səbəblər, maddə intoksikasiyası, doğuşdan sonrakı psixoz, NMS."
},
{
"i": 549,
"t": "C.8. Katatoniya"
},
{
"i": 550,
"t": "Simptomlar:"
},
{
"i": 551,
"t": "Stupor, mutizm;"
},
{
"i": 552,
"t": "Katalepsi (&quot;mum əyilməsi&quot;);"
},
{
"i": 553,
"t": "Negativizm;"
},
{
"i": 554,
"t": "Manerizmlər, stereotiplər;"
},
{
"i": 555,
"t": "Eholalia, ekopraksiya."
},
{
"i": 556,
"t": "Birinci sıra müalicə:"
},
{
"i": 557,
"t": "Lorazepam 1-2 mq IV/IM test"
},
{
"i": 558,
"t": "– 1-2 saat ərzində əhəmiyyətli cavab → katatoniya diaqnozu və müalicə;"
},
{
"i": 559,
"t": "Cavab alınsa – 4-24 mq/gün dozaya çıxarmaq;"
},
{
"i": 560,
"t": "Cavabsız –"
},
{
"i": 561,
"t": "ECT"
},
{
"i": 562,
"t": "2-ci sıra, çox effektiv;"
},
{
"i": 563,
"t": "Antipsikotikdən qaçınmaq"
},
{
"i": 564,
"t": "kəskin fazada – NMS tədbiqi provoke edə bilər."
},
{
"i": 565,
"t": "Səbəbini axtar:"
},
{
"i": 566,
"t": "üzvi (ensefalit, epilepsiya), əhval pozuntusu, şizofreniya, autizm, bəzi maddələr."
},
{
"i": 567,
"t": "ƏLAVƏ D"
},
{
"i": 568,
"t": "HƏRBİ-TİBBİ EKSPERTİZA (AZƏRBAYCANDA)"
},
{
"i": 569,
"t": "Bu əlavə Azərbaycan Respublikasında hərbi xidmətə yararlılıq qiymətləndirilməsi üçün psixiatrik aspektlərə dair praktik təlimat təqdim edir."
},
{
"i": 570,
"t": "D.1. Hüquqi əsas"
},
{
"i": 571,
"t": "&quot;Hərbi xidmətə çağırış haqqında&quot;"
},
{
"i": 572,
"t": "Azərbaycan Respublikası Qanunu;"
},
{
"i": 573,
"t": "Hərbi-tibbi ekspertiza haqqında Əsasnamə;"
},
{
"i": 574,
"t": "Müdafiə Nazirliyinin"
},
{
"i": 575,
"t": "normativ aktları;"
},
{
"i": 576,
"t": "Xəstəliklərin cədvəli"
},
{
"i": 577,
"t": "– yarıya bölünür: yüngül/ağır dərəcələr, A-D qruplarına."
},
{
"i": 578,
"t": "D.2. Psixiatrik qiymətləndirmə strukturu"
},
{
"i": 579,
"t": "Əsas ekspertiza:"
},
{
"i": 580,
"t": "Şikayətlər və anamnez (xəstə və yaxın qohumları);"
},
{
"i": 581,
"t": "Əvvəlki tibbi sənədlər;"
},
{
"i": 582,
"t": "Klinik müsahibə və mental status müayinəsi;"
},
{
"i": 583,
"t": "Eksperimental-psixoloji müayinə"
},
{
"i": 584,
"t": "(EPM) – psixoloq tərəfindən;"
},
{
"i": 585,
"t": "Laboratoriya və instrumental müayinələr lazım olduqda;"
}
]
}