{
"i": 586,
"t": "Diferensial, diaqnoz və xəstəliyin dərəcəsinin qiymətləndirilməsi;"
},
{
"i": 587,
"t": "Nəticə."
},
{
"i": 588,
"t": "Tipik psixoloji testlər (EPM):"
},
{
"i": 589,
"t": "MMPI-2"
},
{
"i": 590,
"t": "(Minnesota Multiphasic Personality Inventory-2) – şəxsiyyət profili;"
},
{
"i": 591,
"t": "Raven proqressiv matrisləri"
},
{
"i": 592,
"t": "– intellekt;"
},
{
"i": 593,
"t": "Luriya testləri"
},
{
"i": 594,
"t": "– yaddaş, diqqət;"
},
{
"i": 595,
"t": "Wechsler IQ şkalası (WAIS)"
},
{
"i": 596,
"t": "Rorschach testi"
},
{
"i": 597,
"t": "– proyektiv (mübahisəli müasir etibarlılığı);"
},
{
"i": 598,
"t": "Beck, Hamilton şkalaları"
},
{
"i": 599,
"t": "– əhval."
},
{
"i": 600,
"t": "D.3. Psixiatrik pozuntular və hərbi xidmətə yararlılıq qiymətləndirilməsi"
},
{
"i": 601,
"t": "Qrupa görə təsnif (adaptasiya – yerli normativ aktlar əsas):"
},
{
"i": 602,
"t": "A qrupu – xidmətə tam yararlı"
},
{
"i": 603,
"t": "Psixiatrik tarixçə yoxdur və ya cüzi keçici məsələlər."
},
{
"i": 604,
"t": "B qrupu – məhdudiyyətlə yararlı"
},
{
"i": 605,
"t": "Yüngül şəxsiyyət cizgiləri (pozuntu həddinə çatmayan);"
},
{
"i": 606,
"t": "Müvəqqəti adaptasiya pozuntuları;"
},
{
"i": 607,
"t": "Yüngül yuxu pozuntuları;"
},
{
"i": 608,
"t": "Remissiya halında nevrotik pozuntular."
},
{
"i": 609,
"t": "V qrupu – xidmət zamanı məhdud"
},
{
"i": 610,
"t": "Qismən remissiya halında orta psixiatrik pozuntular;"
},
{
"i": 611,
"t": "Müəyyən şəxsiyyət pozuntuları;"
},
{
"i": 612,
"t": "Keçmiş PTSD, kompensasiya edilmiş;"
},
{
"i": 613,
"t": "Orta dərəcədə neyrokognitiv disfunksiya."
},
{
"i": 614,
"t": "Q qrupu – xidmətə yararsız"
},
{
"i": 615,
"t": "Şizofreniya spektri;"
},
{
"i": 616,
"t": "Bipolyar pozuntu;"
},
{
"i": 617,
"t": "Ağır depressiya;"
},
{
"i": 618,
"t": "Aktiv PTSD/kompleks PTSD (Qarabağ müharibəsi veteranları – ayrıca müalicə proqramı);"
},
{
"i": 619,
"t": "Maddə istifadəsi pozuntuları;"
},
{
"i": 620,
"t": "Ağır şəxsiyyət pozuntuları;"
},
{
"i": 621,
"t": "Mental gerilik;"
},
{
"i": 622,
"t": "Autizm spektri ağır formalar;"
},
{
"i": 623,
"t": "Aktiv intihar riski olan pozuntular;"
},
{
"i": 624,
"t": "Parafilik pozuntular (ağır, aktiv)."
},
{
"i": 625,
"t": "D.4. doğuşdan sonrakı travma və veteran qiymətləndirməsi"
},
{
"i": 626,
"t": "Qarabağ müharibəsi veteranlarında:"
},
{
"i": 627,
"t": "Kompleks PTSD yüksək yayılma"
},
{
"i": 628,
"t": "– travma-yönəldilmiş müdaxilə;"
},
{
"i": 629,
"t": "Alkogol və maddə istifadəsi"
},
{
"i": 630,
"t": "komorbid;"
},
{
"i": 631,
"t": "Depressiya, intihar riski;"
},
{
"i": 632,
"t": "Ailə funksiya pozuntusu;"
},
{
"i": 633,
"t": "Moral zərər"
},
{
"i": 634,
"t": "– döyüş zamanı etik konflikt (öldürmə, şahid olmaq);"
},
{
"i": 635,
"t": "Yanma və təkrar-travmatizasiya"
},
{
"i": 636,
"t": "risk faktorları."
},
{
"i": 637,
"t": "Spesifik reabilitasiya proqramları:"
},
{
"i": 638,
"t": "Təsdiqli travma terapiyası (PE, CPT, EMDR);"
},
{
"i": 639,
"t": "Qrup terapiyası veteranlara;"
},
{
"i": 640,
"t": "Ailə terapiyası;"
},
{
"i": 641,
"t": "Dərman (SSRİ/SNRİ);"
},
{
"i": 642,
"t": "Sosial reabilitasiya (iş, təhsil)."
},
{
"i": 643,
"t": "ƏLAVƏ E"
},
{
"i": 644,
"t": "ƏLAQƏLİ NEYROLOJİ ŞƏRTLƏR"
},
{
"i": 645,
"t": "Psixiatriya və neyrologiyanın kəsişdiyi sahələrdə klinik praktika üçün vacib olan neyroloji xəstəliklərin qısa təsviri."
},
{
"i": 646,
"t": "E.1. Epilepsiya (G40) və psixiatrik təzahürlər"
},
{
"i": 647,
"t": "Epileptik sindromlar və psixiatriya:"
},
{
"i": 648,
"t": "- İnter-ikt şəxsiyyət dəyişiklikləri (Geschwind sindromu – hiperreligiozluq, hipergrafiya, &quot;viskozlıq&quot;);"
},
{
"i": 649,
"t": "- İnter-ikt psixoz – uzunmüddətli TLE;"
},
{
"i": 650,
"t": "- Post-ikt psixoz – tutma sonrası 24-72 saat ərzində psixotik epizodlar;"
},
{
"i": 651,
"t": "- İkt təşviş və dissosiativ təcrübələr;"
},
{
"i": 652,
"t": "Temporal lob epilepsiyası (TLE)"
},
{
"i": 653,
"t": "– ən çox psixiatrik komorbidlik:"
},
{
"i": 654,
"t": "Absans epilepsiyası"
},
{
"i": 655,
"t": "– diqqət problemi, DDHP ilə diferensial;"
},
{
"i": 656,
"t": "Juvenile miyoklonik epilepsiya"
},
{
"i": 657,
"t": "– yüksək komorbid təşviş, impulsivlik."
},
{
"i": 658,
"t": "Psikogen (qeyri-epileptik) tutmalar (PNES) – dissosiativ neyroloji simptom pozuntusu ("
},
{
"i": 659,
"t": "6B60.4"
},
{
"i": 660,
"t": "Video-EEG"
},
{
"i": 661,
"t": "– qızıl standart diferensial;"
},
{
"i": 662,
"t": "PNES – epilepsiya ilə tez-tez komorbid, 10-30%;"
},
{
"i": 663,
"t": "Müalicə: KDT-PNES, antikonvulsantlardan yavaş kəsilmə."
},
{
"i": 664,
"t": "Antiepileptiklərin psixiatrik yan təsirləri:"
},
{
"i": 665,
"t": "Levetirasetam:"
},
{
"i": 666,
"t": "aqressiya, qıcıqlılıq, depressiya;"
},
{
"i": 667,
"t": "Fenobarbital, primidon:"
},
{
"i": 668,
"t": "depressiya, koqnitiv yavaşlama;"
},
{
"i": 669,
"t": "Topiramat:"
},
{
"i": 670,
"t": "koqnitiv disfunksiya, depressiya;"
},
{
"i": 671,
"t": "Lamotrigin:"
},
{
"i": 672,
"t": "genə əhval stabilizasiya edir."
},
{
"i": 673,
"t": "E.2. Baş ağrısı və psixiatrik komorbidlik"
},
{
"i": 674,
"t": "Migren"
},
{
"i": 675,
"t": "– depressiya riski 2-4× yüksək; anxiety pozuntuları;"
},
{
"i": 676,
"t": "Kluster baş ağrısı"
},
{
"i": 677,
"t": "– depressiya, intihar riski;"
},
{
"i": 678,
"t": "Xronik gündəlik baş ağrısı"
},
{
"i": 679,
"t": "– analgezik həddən istifadə (MOH) – əhval pozuntusu komorbid tez-tez;"
},
{
"i": 680,
"t": "Təkrar tension baş ağrısı"
},
{
"i": 681,
"t": "– sıx stres, təşviş ilə əlaqəli."
},
{
"i": 682,
"t": "İdarəetmə:"
},
{
"i": 683,
"t": "SSRİ/SNRİ bir çox baş ağrısı tipini yaxşılaşdırır;"
},
{
"i": 684,
"t": "TCA (amitriptilin) profilaktik migren üçün tarixi standart;"
},
{
"i": 685,
"t": "Topiramat, valproat profilaktik;"
},
{
"i": 686,
"t": "KDT xroniki baş ağrısında effektivdir;"
},
{
"i": 687,
"t": "Opioidlərdən və həddən analgesik istifadəsindən qaçmaq."
},
{
"i": 688,
"t": "E.3. Beyin-qan damar xəstəlikləri (insult)"
},
{
"i": 689,
"t": "Post-stroke depressiya:"
},
{
"i": 690,
"t": "30-40% ilk il;"
},
{
"i": 691,
"t": "Post-stroke mania:"
},
{
"i": 692,
"t": "nadir, sağ frontal və ya talamik zədələrdə;"
},
{
"i": 693,
"t": "Pseudobulbar affekt"
},
{
"i": 694,
"t": "(patoloji gülmə/ağlama):"
},
{
"i": 695,
"t": "dekstrometorfan-kinidin kombinasiyası"
},
{
"i": 696,
"t": "təsdiqli müalicədir;"
},
{
"i": 697,
"t": "Vaskulyar koqnitiv pozuntu/demensiya:"
},
{
"i": 698,
"t": "6D81"
},
{
"i": 699,
"t": "altında klassifikasiya;"
},
{
"i": 700,
"t": "Reabilitasiya:"
},
{
"i": 701,
"t": "multidisiplinar, psixiatrik dəstək mərkəzi rolunda."
},
{
"i": 702,
"t": "E.4. Parkinson xəstəliyi"
},
{
"i": 703,
"t": "Depressiya:"
},
{
"i": 704,
"t": "Təşviş:"
},
{
"i": 705,
"t": "Dopamin agonisti-induksiyalı impuls nəzarət pozuntusu:"
},
{
"i": 706,
"t": "Parkinsonda psixoz:"
},
{
"i": 707,
"t": "əsasən vizual halüsinasiyalar; levodopa-induksiya;"
},
{
"i": 708,
"t": "Parkinsonda demensiya:"
},
{
"i": 709,
"t": "6D85"
},
{
"i": 710,
"t": "REM yuxu davranış pozuntusu:"
},
{
"i": 711,
"t": "Parkinson üçün erkən markeri."
},
{
"i": 712,
"t": "Müalicə xüsusiyyətləri:"
},
{
"i": 713,
"t": "Antipsikotiklərin Parkinsonda istifadəsi:"
},
{
"i": 714,
"t": "kvetiapin, klozapin"
},
{
"i": 715,
"t": "(D2 minimal blokada);"
},
{
"i": 716,
"t": "Haloperidol, risperidon"
},
{
"i": 717,
"t": "– motor simptomları pisləşdirir;"
},
{
"i": 718,
"t": "SSRİ"
},
{
"i": 719,
"t": "depressiya üçün;"
},
{
"i": 720,
"t": "Pimavanserin"
},
{
"i": 721,
"t": "– ABŞ-da Parkinson psixozu üçün təsdiqli."
},
{
"i": 722,
"t": "E.5. Multipl skleroz (MS)"
},
{
"i": 723,
"t": "Depressiya:"
},
{
"i": 724,
"t": "Təşviş:"
},
{
"i": 725,
"t": "Bipolyar bənzər simptomlar:"
},
{
"i": 726,
"t": "Pseudobulbar affekt;"
},
{
"i": 727,
"t": "Koqnitiv disfunksiya"
},
{
"i": 728,
"t": "– xəstəliyin çoxunda;"
},
{
"i": 729,
"t": "Uyuşuqluq və yorğunluq"
},
{
"i": 730,
"t": "– depressiya ilə sıx, diferensial çətin."
},
{
"i": 731,
"t": "İnterferon-beta terapiyası"
},
{
"i": 732,
"t": "depressiyanı pisləşdirir – aktiv monitorinq."
},
{
"i": 733,
"t": "E.6. Travmatik beyin zədəsi (TBZ)"
},
{
"i": 734,
"t": "Post-konkussion sindromu:"
},
{
"i": 735,
"t": "baş ağrısı, baş gicəllənməsi, yaddaş problemi, əhval dəyişikliyi;"
},
{
"i": 736,
"t": "Kroniki travma ensefalopatiyası (CTE):"
},
{
"i": 737,
"t": "təkrar zədələr, idman (boxing, amerikan futbolu);"
},
{
"i": 738,
"t": "PTSD + TBZ"
},
{
"i": 739,
"t": "– çox tez-tez komorbid;"
},
{
