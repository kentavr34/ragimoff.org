"id": "7A60__02",
"file": "7A60.html",
"segments": [
{
"i": 692,
"t": "Affektiv simptomlar."
},
{
"i": 693,
"t": "İnsomniya (7A00)"
},
{
"i": 694,
"t": "Yetərsiz yuxu."
},
{
"i": 695,
"t": "Klein-Levin sindromu"
},
{
"i": 696,
"t": "Episodik 1–2 həftəlik hipersomniya + iştah."
},
{
"i": 697,
"t": "7. Müayinə və qiymətləndirmə"
},
{
"i": 698,
"t": "Epworth, PSG + MSLT."
},
{
"i": 699,
"t": "Tibbi laborator."
},
{
"i": 700,
"t": "8. Müalicə"
},
{
"i": 701,
"t": "Modafinil, armodafinil — birinci sıra."
},
{
"i": 702,
"t": "Stimulyantlar (metilfenidat, amfetamin) — refrakter."
},
{
"i": 703,
"t": "Pitolisant (FDA 2019, idiopatik və narkolepsiya)."
},
{
"i": 704,
"t": "Solriamfetol (FDA 2019)."
},
{
"i": 705,
"t": "Yuxu hijyeni və davranış müdaxiləsi (planlaşdırılmış gündüz yuxular)."
},
{
"i": 706,
"t": "Klein-Levin — supportiv; epizodlar arası asimptomatik."
},
{
"i": 707,
"t": "Mənbə-spesifik dəqiqləşdirmələr"
},
{
"i": 708,
"t": "AASM Treatment Guidelines (Maski K. et al. 2021)."
},
{
"i": 709,
"t": "Müalicə metodikaları"
},
{
"i": 710,
"t": "Modafinil/Armodafinil"
},
{
"i": 711,
"t": "— Wakefulness-promoting; birinci sıra; başağrısı, narahatlıq yan təsir."
},
{
"i": 712,
"t": "Çoxsaylı Yuxu Latentliyi Testi (MSLT — Multiple Sleep Latency Test)"
},
{
"i": 713,
"t": "— 5 yuxu cəhdi 2 saat fasilə ilə; yuxu latensiya ölçüsü."
},
{
"i": 714,
"t": "Pitolisant və Solriamfetol"
},
{
"i": 715,
"t": "— Yeni dərmanlar; refrakter halda."
},
{
"i": 716,
"t": "9. Proqnoz"
},
{
"i": 717,
"t": "Xronik; farmakoterapiya ilə funksional yaxşılaşma."
},
{
"i": 718,
"t": "10. Mif və yanlış inanclar"
},
{
"i": 719,
"t": "Mif 1: \"Gündüz yuxululuğu \"tənbəllik\"-dir\""
},
{
"i": 720,
"t": "Sübut:"
},
{
"i": 721,
"t": "klinik vəziyyət; mortalite və qəza riski artımı."
},
{
"i": 722,
"t": "Mif 2: \"Kafein hipersomniya üçün kifayətdir\""
},
{
"i": 723,
"t": "Sübut:"
},
{
"i": 724,
"t": "kafein adjunkt; modafinil və ya stimulyant tələb olunur."
},
{
"i": 725,
"t": "Mif 3: \"Hipersomniya yalnız depresiya əlamətidir\""
},
{
"i": 726,
"t": "Sübut:"
},
{
"i": 727,
"t": "idiopatik hipersomniya ayrı pozuntudur; MSLT diferensiasiya edir."
},
{
"i": 728,
"t": "11. Mənbələr"
},
{
"i": 729,
"t": "WHO. ICD-11. 7A60 Hypersomnolence disorders. 2024."
},
{
"i": 730,
"t": "APA. DSM-5-TR. 2022."
},
{
"i": 731,
"t": "Maski K. et al. Treatment of central disorders of hypersomnolence: AASM Clinical Practice Guideline. J Clin Sleep Med 2021;17(9):1881–1893."
},
