},
{
"i": 255,
"t": "YUXU POZUNTULARI"
},
{
"i": 256,
"t": "HA00–HA8Z"
},
{
"i": 257,
"t": "CİNSİ DİSFUNKSİYALAR VƏ CİNSİ SAĞLAMLIQ POZUNTULARI"
},
{
"i": 258,
"t": "ƏLAVƏ B"
},
{
"i": 259,
"t": "NEYROİNKİŞAF POZUNTULARIIN SKRİNİNQ ŞKALALARI"
},
{
"i": 260,
"t": "&gt;"
},
{
"i": 261,
"t": "İstifadə qaydaları:"
},
{
"i": 262,
"t": "Bu şkalalar"
},
{
"i": 263,
"t": "diaqnostik deyil, skrininq alətlərdir"
},
{
"i": 264,
"t": ". Müsbət nəticə – ixtisaslaşmış klinik qiymətləndirmə üçün göstərişdir,"
},
{
"i": 265,
"t": "diaqnoz deyil."
},
{
"i": 266,
"t": "Qəti diaqnoz klinik müsahibə, ətraflı qiymətləndirmə və (lazım olduqda) standartlaşdırılmış diaqnostik alətlər (ADOS-2, ADI-R, WISC-V və s.) vasitəsilə qoyulur."
},
{
"i": 267,
"t": "&gt;"
},
{
"i": 268,
"t": "&gt;"
},
{
"i": 269,
"t": "Lisenziya statusu:"
},
{
"i": 270,
"t": "Bu əlavədə təqdim edilən bütün şkalalar elmi-araşdırma və klinik istifadə üçün tərtibatçılar tərəfindən açıq şəkildə təqdim edilmiş alətlərdir."
},
{
"i": 271,
"t": "B.1. M-CHAT-R: Autizm Spektri üçün Düzəldilmiş Yoxlama Cədvəli (16–30 aylıq uşaqlar)"
},
{
"i": 272,
"t": "Orijinal müəlliflər:"
},
{
"i": 273,
"t": "Diana L. Robins, Deborah Fein, Marianne Barton, 2009."
},
{
"i": 274,
"t": "Orijinal istinad:"
},
{
"i": 275,
"t": "Robins DL, Fein D, Barton M. M-CHAT-R/F. Self-published, 2009; Pediatrics, 2014; 133: 37–45."
},
{
"i": 276,
"t": "Təlimat"
},
{
"i": 277,
"t": "Bu anket uşağınızın gündəlik davranışı haqqında 20 sualdan ibarətdir."
},
{
"i": 278,
"t": "Valideyn və ya ilkin qulluq edən tərəfindən doldurulur."
},
{
"i": 279,
"t": "Hər suala"
},
{
"i": 280,
"t": "BƏLİ"
},
{
"i": 281,
"t": "və ya"
},
{
"i": 282,
"t": "XEYR"
},
{
"i": 283,
"t": "kimi cavab verin – uşağınızın"
},
{
"i": 284,
"t": "adətən"
},
{
"i": 285,
"t": "necə davrandığı əsasında. Əgər davranışı bir-iki dəfə görmüsünüzsə, amma ümumiyyətlə uşaq belə etmirsə,"
},
{
"i": 286,
"t": "XEYR"
},
{
"i": 287,
"t": "cavablayın."
},
{
"i": 288,
"t": "Suallar"
},
{
"i": 289,
"t": "Sual"
},
{
"i": 290,
"t": "Bəli"
},
{
"i": 291,
"t": "Xeyr"
},
{
"i": 292,
"t": "Əgər siz otağın o tərəfindəki bir şeyə baxsanız, uşağınız da ora baxırmı? (Məsələn, uçan təyyarəyə, böyük heyvana və ya oyuncağa)"
},
{
"i": 293,
"t": "Heç uşağınızın kar olduğunu düşünmüsünüzmü?"
},
{
"i": 294,
"t": "Uşağınız uydurma oyunlar oynayırmı? (Məsələn, boş fincandan içmək kimi, telefonla danışmaq kimi, kuklaya yemək vermək kimi)"
},
{
"i": 295,
"t": "Uşağınız əşyalara dırmanmağı sevirmi? (Məbəl, pilləkən, ağac)"
},
{
"i": 296,
"t": "Uşağınız ovuclarını, barmaqlarını və ya bədəninin digər hissələrini gözünün qarşısında qeyri-adi hərəkətlərlə edirmi?"
},
{
"i": 297,
"t": "Uşağınız istədiyi bir şeyə işarə edirmi? (Məsələn, bufetdən uzaqda olan bir oyuncaq üçün)"
},
{
"i": 298,
"t": "Uşağınız maraqlı bir şeyə diqqətinizi cəlb etmək üçün işarə edirmi? (Məsələn, göydəki təyyarə və ya böyük maşın)"
},
{
"i": 299,
"t": "Uşağınız başqa uşaqlara maraq göstərirmi? (Məsələn, oyun parkında uşaqlara baxır, onlara qoşulmağa çalışır)"
},
{
"i": 300,
"t": "Uşağınız sizə bir şey göstərməklə və ya önünüzə qoymaqla sizinlə paylaşırmı (bunu kömək üçün deyil, paylaşmaq üçün)?"
},
{
"i": 301,
"t": "Uşağınız adı çağırıldıqda cavab verirmi?"
},
{
"i": 302,
"t": "Uşağınıza gülümsədiyinizdə, o da sizə gülümsəyirmi?"
},
{
"i": 303,
"t": "Uşağınız gündəlik səslərdən narahat olurmı? (Məsələn, tozsoran, yüksək musiqi)"
},
{
"i": 304,
"t": "Uşağınız yeriyirmi?"
},
{
"i": 305,
"t": "Uşağınız siz onunla, onun paltarını geyindirən və ya oynayarkən gözlərinizə baxırmı?"
},
{
"i": 306,
"t": "Uşağınız sizin etdiklərinizi təqlid edirmi? (Məsələn, siz üzünüzə fəaliyyət etdikdə, o da eyni şeyi edir)"
},
{
"i": 307,
"t": "Uşağınız bir şey eşitdikdə sizə baxırmı ki, nəyin olduğunu görsün?"
}
]
}