"segments": [
{
"i": 447,
"t": "Tez-tez sakit oynamaqda çətinlik çəkir"
},
{
"i": 448,
"t": "Tez-tez &quot;hərəkətli&quot; və ya &quot;motorla işləyən&quot; kimi davranır"
},
{
"i": 449,
"t": "Tez-tez həddindən artıq danışır"
},
{
"i": 450,
"t": "Tez-tez sual bitməmiş cavabları ağızdan qaçırdır"
},
{
"i": 451,
"t": "Tez-tez öz növbəsini gözləyə bilmir"
},
{
"i": 452,
"t": "Tez-tez başqalarının fəaliyyətini kəsir (söhbətə, oyuna)"
},
{
"i": 453,
"t": "Opozisiyon-etiraz davranışı subskalası (Items 19–26):"
},
{
"i": 454,
"t": "İfadə"
},
{
"i": 455,
"t": "Tez-tez özünü itirir"
},
{
"i": 456,
"t": "Tez-tez yetkinlərlə mübahisə edir"
},
{
"i": 457,
"t": "Tez-tez yetkinlərin tələblərinə və ya qaydalara qarşı çıxır"
},
{
"i": 458,
"t": "Tez-tez qəsdən başqalarını qıcıqlandırır"
},
{
"i": 459,
"t": "Tez-tez öz səhvləri və ya pis davranışı üçün başqalarını günahlandırır"
},
{
"i": 460,
"t": "Tez-tez başqaları tərəfindən asan qıcıqlandırılır"
},
{
"i": 461,
"t": "Tez-tez əsəbidir və kəskin narazıdır"
},
{
"i": 462,
"t": "Tez-tez qisasçı və ya kinli davranır"
},
{
"i": 463,
"t": "Hesablama"
},
{
