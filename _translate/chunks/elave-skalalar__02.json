},
{
"i": 482,
"t": "Kombinə edilmiş:"
},
{
"i": 483,
"t": "Hər iki subskala müsbət."
},
{
"i": 484,
"t": "Opozisiyon-etiraz subskalası ilə müsbət nəticə –"
},
{
"i": 485,
"t": "komorbid opozisiyon-etiraz pozuntusunun (ODD, WHO, 2019, qüvvəyə minmə 2022 — XBT-11"
},
{
"i": 486,
"t": "6C90"
},
{
"i": 487,
"t": "əhtimalını göstərir."
},
{
"i": 488,
"t": "&gt;"
},
{
"i": 489,
"t": "Qeyd:"
},
{
"i": 490,
"t": "SNAP-IV – tədqiqat və klinik istifadə üçün sərbəst əlçatandır. Tam 90 suallı versiya, qısa 26 suallı versiya və müəllim versiyaları Swanson prof. rəsmi saytından yüklənə bilər: http://www.shared-care.ca/files/Scoring_for_SNAP_IV_Guide_26-item.pdf"
},
{
"i": 491,
"t": "B.5. Intellektual və adaptiv qiymətləndirmənin əsas alətləri (məlumat cədvəli)"
},
{
"i": 492,
"t": "Aşağıdakı alətlər"
