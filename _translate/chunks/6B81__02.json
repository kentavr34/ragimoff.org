"id": "6B81__02",
"file": "6B81.html",
"segments": [
{
"i": 688,
"t": "Klinik müsahibə."
},
{
"i": 689,
"t": "EDE-Q, EDE."
},
{
"i": 690,
"t": "Tibbi: elektrolitlər (K, P, Mg, Cl), qaraciyər, böyrək, EKG (QTc)."
},
{
"i": 691,
"t": "Diş müayinəsi (eroziya)."
},
{
"i": 692,
"t": "Komorbidlik və suicid riski."
},
{
"i": 693,
"t": "6.4 Differensial diaqnostika"
},
{
"i": 694,
"t": "Vəziyyət"
},
{
"i": 695,
"t": "Fərqləndirici"
},
{
"i": 696,
"t": "Sinir anoreksiyası, obur yemə/təmizlənmə tipi (6B80)"
},
{
"i": 697,
"t": "Çəki əhəmiyyətli aşağı."
},
{
"i": 698,
"t": "BED (6B82)"
},
{
"i": 699,
"t": "Kompensator davranış yox."
},
{
"i": 700,
"t": "Night Eating Syndrome"
},
{
"i": 701,
"t": "Gecə qida qəbulu üstündür."
},
{
"i": 702,
"t": "Klein-Levin sindromu"
},
{
"i": 703,
"t": "Hipersomniya + hiperfagiya."
},
{
"i": 704,
"t": "7. Müayinə və qiymətləndirmə"
},
{
"i": 705,
"t": "EDE-Q."
},
{
"i": 706,
"t": "Tibbi: elektrolitlər, EKG, diş müayinəsi."
},
{
"i": 707,
"t": "C-SSRS."
},
{
"i": 708,
"t": "8. Müalicə"
},
{
"i": 709,
"t": "CBT-E birinci sıra"
},
{
"i": 710,
"t": "(Fairburn) — 20 seans 20 həftə; sübut: Fairburn C.G. et al. Behav Res Ther 2009."
},
{
"i": 711,
"t": "Fluoksetin 60 mq/gün"
},
{
"i": 712,
"t": "— FDA təsdiqi BN üçün; obur yemə və qusma azaldır."
},
{
"i": 713,
"t": "FBT (Lock J., Le Grange D.) — yeniyetmələrdə."
},
{
"i": 714,
"t": "İPT alternativ."
},
{
"i": 715,
"t": "Tibbi: elektrolit korreksiyası, refeeding, diş qulluğu."
},
{
"i": 716,
"t": "Bupropion"
},
{
"i": 717,
"t": "əkstərkib"
},
{
"i": 718,
"t": "(tutma riski)."
},
{
"i": 719,
"t": "Mənbə-spesifik dəqiqləşdirmələr"
},
{
"i": 720,
"t": "NICE NG69 — CBT-E birinci sıra; FBT yeniyetmələrdə."
},
{
"i": 721,
"t": "APA 2023."
},
{
"i": 722,
"t": "Müalicə metodikaları"
},
{
"i": 723,
"t": "CBT-E (Fairburn)"
},
{
"i": 724,
"t": "— 20 seans; transdiaqnostik; binge-purge zəncirinin pozulması."
},
{
"i": 725,
"t": "Fluoksetin 60 mq"
},
{
"i": 726,
"t": "— FDA təsdiqi; obur yemə tezliyini ~50% azaldır."
},
{
"i": 727,
"t": "FBT BN üçün"
},
{
"i": 728,
"t": "— Yeniyetmələrdə uyğunlaşdırılmış."
},
{
"i": 729,
"t": "İnterpersonal Terapiya (İPT / IPT — Interpersonal Therapy)"
},
{
"i": 730,
"t": "— Alternativ; ləng cavab, lakin uzunmüddətli effekt."
},
{
"i": 731,
"t": "9. Proqnoz"
},
{
"i": 732,
"t": "50–70% remisya CBT-E ilə; uzunmüddətli izləmə vacib."
},
{
"i": 733,
"t": "10. Mif və yanlış inanclar"
},
{
"i": 734,
"t": "Mif 1: \"Bulimiya \"diyet uğursuzluğu\"-dur\""
},
{
"i": 735,
"t": "Sübut:"
},
{
"i": 736,
"t": "klinik pozuntudur; restriktiv dieta tipik tetikleyicidir."
},
{
"i": 737,
"t": "Mif 2: \"Qusma effektiv kilo verme metodudur\""
},
{
"i": 738,
"t": "Sübut:"
},
{
"i": 739,
"t": "qusma kalori udulmasının yalnız 30–50%-ni qarşısını alır; tibbi ciddi komplikasiyalar."
},
{
"i": 740,
"t": "Mif 3: \"Bupropion antidepresant kimi BN-da istifadə oluna bilər\""
},
{
"i": 741,
"t": "Sübut:"
},
{
"i": 742,
"t": "bupropion BN-da"
},
{
"i": 743,
"t": "əkstərkibdir"
},
{
"i": 744,
"t": "— tutma riski yüksək."
},
{
"i": 745,
"t": "Mif 4: \"BN normal çəki olduqda problem yoxdur\""
},
{
"i": 746,
"t": "Sübut:"
},
{
"i": 747,
"t": "tibbi komplikasiyalar (elektrolit, kardiyak) və psixiatrik yük əhəmiyyətlidir."
},
{
"i": 748,
"t": "Mif 5: \"Yalnız antidepresant kifayətdir\""
},
{
"i": 749,
"t": "Sübut:"
},
{
"i": 750,
"t": "CBT-E + farmakoterapiya kombinasiyası üstün."
},
{
"i": 751,
"t": "11. Mənbələr"
},
{
