"file": "yekun.html",
"segments": [
{
"i": 318,
"t": "C-SSRS"
},
{
"i": 319,
"t": "– intihar riski."
},
{
"i": 320,
"t": "Azərbaycan dilinə tərcümə edilmiş və validasiya edilmiş alətlərə sərmayə qoyulmalıdır."
},
{
"i": 321,
"t": "İntihar riskinin qiymətləndirilməsi"
},
{
"i": 322,
"t": "Hər psixiatrik görüşdə aktiv sorğu:"
},
{
"i": 323,
"t": "Son vaxtlar ölüm və ya öz həyatınıza son qoymaqla bağlı düşüncələr olubmu?"
},
{
"i": 324,
"t": "Konkret plan, vasitə?"
},
{
"i": 325,
"t": "Əvvəlki cəhdlər?"
},
{
"i": 326,
"t": "Risk faktorları:"
},
{
"i": 327,
"t": "Əvvəlki cəhdlər (ən güclü prediktor);"
},
{
"i": 328,
"t": "Ailədə intihar tarixi;"
},
{
"i": 329,
"t": "Yaxınlıq təxminən-qəti plan;"
},
{
"i": 330,
"t": "Vasitələrə çatımlılıq;"
},
{
"i": 331,
"t": "Maddə istifadəsi, depressiya, BPD, psixoz;"
},
{
"i": 332,
"t": "Kəskin stressor, itki."
},
{
"i": 333,
"t": "Müdaxilə:"
},
{
"i": 334,
"t": "Təhlükəsizlik planı;"
},
{
"i": 335,
"t": "Vasitələrə çatımlılığın azaldılması;"
},
{
"i": 336,
"t": "Yaxın monitorinq;"
},
{
"i": 337,
"t": "Hospitalizasiya göstərişlə;"
},
{
"i": 338,
"t": "C-SSRS"
},
{
"i": 339,
"t": "kimi şkala ilə formalaşmış qiymətləndirmə."
},
{
"i": 340,
"t": "Komorbidlik qayda istisna deyil"
},
{
"i": 341,
"t": "Psixi pozuntularda"
},
{
"i": 342,
"t": "komorbidlik norm"
},
{
"i": 343,
"t": "dur:"
},
{
"i": 344,
"t": "Depressiya + təşviş"
},
{
"i": 345,
"t": "– 60% komorbid;"
},
{
"i": 346,
"t": "PTSD + depressiya"
},
{
"i": 347,
"t": "Şəxsiyyət pozuntusu + depressiya/təşviş/maddə"
},
{
"i": 348,
"t": "Autizm + DDHP"
},
{
"i": 349,
"t": "Yemə pozuntusu + depressiya + travma"
},
{
"i": 350,
"t": "– tipik üçlük."
},
{
"i": 351,
"t": "Müalicə planı"
},
{
"i": 352,
"t": "bütün komorbidlikləri əhatə etməlidir"
},
{
"i": 353,
"t": "– əsas pozuntunun təklikdə müalicəsi çox vaxt kifayət deyil."
},
{
"i": 354,
"t": "Yaş və inkişaf mərhələsi mütləq nəzərə alınmalıdır"
},
{
"i": 355,
"t": "Uşaqda psixi pozuntu"
},
{
"i": 356,
"t": "– valideyn və kontekst mühümdür; dərmanlar az, psixoterapiya və ailə-yönləndirmə daha çox;"
},
{
"i": 357,
"t": "Yeniyetmə"
},
{
"i": 358,
"t": "– identitet inkişafı, erkən müdaxilə kritik;"
},
{
"i": 359,
"t": "Yetkin"
},
{
"i": 360,
"t": "– iş, ailə, sosial funksiya;"
},
{
"i": 361,
"t": "Yaşlı"
},
{
"i": 362,
"t": "– komorbid tibbi xəstəliklər, polipharmasi, koqnitiv pozuntular;"
},
{
"i": 363,
"t": "demensiya vs depressiya"
},
{
"i": 364,
"t": "xüsusi diqqət."
},
{
"i": 365,
"t": "Multidisiplinar komanda – effektiv klinik işin əsasıdır"
},
{
"i": 366,
"t": "Kompleks hallarda:"
},
{
"i": 367,
"t": "Psixiatr;"
},
{
"i": 368,
"t": "Psixoloq / psixoterapevt;"
},
{
"i": 369,
"t": "Sosial işçi;"
},
{
"i": 370,
"t": "Tibbi həkim (komorbidliklər);"
},
{
"i": 371,
"t": "Ailə üzvləri (razılıqla);"
},
{
"i": 372,
"t": "Məktəb / iş yerindəki şəxslər (uşaqda)."
},
{
"i": 373,
"t": "Azərbaycanda bu strukturun inkişaf etdirilməsi – strateji prioritet."
},
{
"i": 374,
"t": "Etik və hüquqi çərçivə"
},
{
"i": 375,
"t": "Hər klinisist bilməlidir:"
},
{
"i": 376,
"t": "Məxfilik və onun sərhədləri (başqalarına təhlükə, uşaq qoruma);"
},
{
"i": 377,
"t": "İnformasiyalı razılıq;"
},
{
"i": 378,
"t": "Məcburi hospitalizasiya hüquqi çərçivəsi;"
},
{
"i": 379,
"t": "Uşaq/yaşlı zorakılığı bildirişi;"
},
{
"i": 380,
"t": "Forensik qiymətləndirmə əsasları;"
},
{
"i": 381,
"t": "Sənədləşmənin əhəmiyyəti."
},
{
"i": 382,
"t": "Öz sağlamlığınıza diqqət"
},
{
"i": 383,
"t": "Psixiatrik iş –"
},
{
"i": 384,
"t": "emosional yükü yüksək"
},
{
"i": 385,
"t": "peşədir. Yanma (burnout), ikinci dərəcəli travma, empatik yorğunluq klinisist üçün real risklərdir."
},
{
"i": 386,
"t": "Supervision və kolleqial konsultasiya;"
},
{
"i": 387,
"t": "Şəxsi psixoterapiya;"
},
{
"i": 388,
"t": "Sağlam həyat tərzi;"
},
{
"i": 389,
"t": "Həddinin bilinməsi – bütün xəstələri qurtara bilməzsiniz."
},
{
"i": 390,
"t": "Davamlı təhsil və inkişaf"
},
{
"i": 391,
"t": "WHO, 2019, qüvvəyə minmə 2022 — XBT-11 sabit qalacaq onilliklər boyunca, lakin:"
},
{
"i": 392,
"t": "Müalicə standartları"
},
{
"i": 393,
"t": "hər 3–5 ildə"
},
{
"i": 394,
"t": "yenilənir;"
},
{
"i": 395,
"t": "Yeni dərmanlar, yeni psixoterapevtik protokollar çıxır;"
},
{
"i": 396,
"t": "AACE, APA, NICE, WFSBP, ISTSS"
},
{
"i": 397,
"t": "kimi təşkilatların qaydalarını müntəzəm izləmə;"
},
{
"i": 398,
"t": "Peer-review jurnalları: Lancet Psychiatry, JAMA Psychiatry, American Journal of Psychiatry, World Psychiatry."
},
{
"i": 399,
"t": "Kitabın məqsədi:"
},
{
"i": 400,
"t": "Azərbaycanda psixiatrik qayğının keyfiyyətinə, xəstə və ailələrə, professional inkişafa töhfə vermək. Oxucu bu kitabdan faydalandığı halda, məqsəd əldə olunmuş hesab olunacaq."
},
{
"i": 401,
"t": "Sağlıqlı müalicə, peşəkar yüksəliş və xəstələrinizə faydalı olmağınızı arzu edirəm."
},
{
