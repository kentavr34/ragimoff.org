"file": "6C91.html",
"segments": [
{
"i": 690,
"t": "DMDD (DSM-5)"
},
{
"i": 691,
"t": "Davamlı irritabellik + ağır qəzəb partlayışları, 6 ay; ODD-dan ayrıca diaqnoz oluna bilməz."
},
{
"i": 692,
"t": "Narahatlıq pozuntusu"
},
{
"i": 693,
"t": "Narahatlıq komponenti dominant."
},
{
"i": 694,
"t": "İntellektual əlillik"
},
{
"i": 695,
"t": "Koqnitiv defisit kontekstdə davranış pozulması."
},
{
"i": 696,
"t": "Yaşa uyğun \"uşaq müqaviməti\""
},
{
"i": 697,
"t": "Funksional pozulma yoxdur."
},
{
"i": 698,
"t": "7. Müayinə və qiymətləndirmə"
},
{
"i": 699,
"t": "ECBI, CBCL."
},
{
"i": 700,
"t": "Komorbid ADHD, narahatlıq, MDD."
},
{
"i": 701,
"t": "8. Müalicə"
},
{
"i": 702,
"t": "Valideyn təlimi birinci sıra:"
},
{
"i": 703,
"t": "PCIT — 2–7 yaş;"
},
{
"i": 704,
"t": "Incredible Years — 3–8 yaş;"
},
{
"i": 705,
"t": "Parent Management Training (Barkley) — 6+ yaş;"
},
{
"i": 706,
"t": "Triple P."
},
{
"i": 707,
"t": "Komorbid ADHD — stimulyant."
},
{
"i": 708,
"t": "SSRİ — komorbid narahatlıq/depressiya."
},
{
"i": 709,
"t": "Məktəb-əsaslı müdaxilə."
},
{
"i": 710,
"t": "İntimat partnyor zorakılığı şübhəsi — sosial xidmət koordinasiyası."
},
{
"i": 711,
"t": "Mənbə-spesifik dəqiqləşdirmələr"
},
{
"i": 712,
"t": "NICE NG158."
},
{
"i": 713,
"t": "AACAP — valideyn təlimi."
},
{
"i": 714,
"t": "Müalicə metodikaları"
},
{
"i": 715,
"t": "Valideyn-Uşaq Qarşılıqlı Təsir Terapiyası (PCIT)"
},
{
"i": 716,
"t": "— Real vaxtda terapevtin koçluğu."
},
{
"i": 717,
"t": "«Incredible Years» proqramı"
},
{
"i": 718,
"t": "— Qrup formatı."
},
{
"i": 719,
"t": "Triple P — Pozitiv Valideynlik Proqramı (Positive Parenting Program)"
},
{
"i": 720,
"t": "— 5 pilləli sistem."
},
{
"i": 721,
"t": "Valideyn İdarəetmə Təlimi (Parent Management Training) — Barkli (Barkley)"
},
{
"i": 722,
"t": "— Davranış prinsipləri əsaslı təlim."
},
{
"i": 723,
"t": "Eyberg Uşaq Davranış Sorğusu (ECBI — Eyberg Child Behavior Inventory)"
},
{
"i": 724,
"t": "— Valideyn-rated davranış şkalası."
},
{
"i": 725,
"t": "9. Proqnoz"
},
{
"i": 726,
"t": "Erkən valideyn təlimi ilə əksər pasiyent yaxşılaşır."
},
{
"i": 727,
"t": "Komorbid ADHD, ağır variantı — CD/ASPD riski."
},
{
"i": 728,
"t": "10. Mif və yanlış inanclar"
},
{
"i": 729,
"t": "Mif 1: \"ODD adi \"inadkar uşaq\" davranışıdır\""
},
{
"i": 730,
"t": "Sübut:"
},
{
"i": 731,
"t": "klinik diaqnoz funksional pozulma və tezlik əsasında; normal yaş varyantından fərqlidir."
},
{
"i": 732,
"t": "Mif 2: \"Sərt intizam ODD-ni düzəldər\""
},
{
"i": 733,
"t": "Sübut:"
},
{
"i": 734,
"t": "sərt cəza simptomları gücləndirir; pozitiv valideyn təlimi sübutludur."
},
{
"i": 735,
"t": "Mif 3: \"Antipsixotik birinci sıra\""
},
{
"i": 736,
"t": "Sübut:"
},
{
"i": 737,
"t": "valideyn təlimi birinci sıra; antipsixotik refrakter halda nadir."
},
{
"i": 738,
"t": "Mif 4: \"ODD həmişə CD-yə çevrilir\""
},
{
"i": 739,
"t": "Sübut:"
},
{
"i": 740,
"t": "30%-də CD-yə keçid; uşaqlıq tipi və komorbidliklə risk yüksək; əksəriyyət CD-yə çevrilmir."
},
{
"i": 741,
"t": "Mif 5: \"Yalnız uşaq müalicə olunmalıdır, ailə yox\""
},
{
"i": 742,
"t": "Sübut:"
},
{
"i": 743,
"t": "valideyn təlimi mərkəzi komponentdir; uşaq tək başına psixoterapiya az effektivdir."
},
{
