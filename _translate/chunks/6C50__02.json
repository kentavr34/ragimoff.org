"segments": [
{
"i": 693,
"t": "6.3 Diaqnostika alqoritmi"
},
{
"i": 694,
"t": "Klinik müsahibə."
},
{
"i": 695,
"t": "SOGS (South Oaks Gambling Screen) və ya PGSI (Problem Gambling Severity Index)."
},
{
"i": 696,
"t": "IGDS9-SF (Internet Gaming Disorder Scale)."
},
{
"i": 697,
"t": "Komorbid maddə, MDD, suicid."
},
{
"i": 698,
"t": "Maliyyə vəziyyəti qiymətləndirməsi."
},
{
"i": 699,
"t": "6.4 Differensial diaqnostika"
},
{
"i": 700,
"t": "Vəziyyət"
},
{
"i": 701,
"t": "Fərqləndirici"
},
{
"i": 702,
"t": "Manik epizod (qumar disinhibisiyası)"
},
{
"i": 703,
"t": "Affektiv simptomlar."
},
{
"i": 704,
"t": "OKP (kompulsiv yoxlama)"
},
{
"i": 705,
"t": "Obsessiya əsas."
},
{
"i": 706,
"t": "BPD (impulsivlik)"
},
{
"i": 707,
"t": "Davamlı model bütün sahələrə."
},
{
"i": 708,
"t": "Sosial gaming (problem yox)"
},
{
"i": 709,
"t": "Funksional pozulma yox."
},
{
"i": 710,
"t": "7. Müayinə və qiymətləndirmə"
},
{
"i": 711,
"t": "SOGS, PGSI, IGDS9-SF."
},
{
"i": 712,
"t": "Komorbidlik şkalaları."
},
{
"i": 713,
"t": "C-SSRS suicid."
},
{
"i": 714,
"t": "8. Müalicə"
},
{
"i": 715,
"t": "KDT — birinci sıra; tetikleyicilərin idarəsi, davranış aktivasiyası, koqnitiv yenidən strukturlaşdırma (\"near miss\" və \"gambler's fallacy\"). Cowlishaw S. Cochrane 2012 meta-analiz."
},
{
"i": 716,
"t": "Naltrekson, nalmefen — sübut bazası inkişaf etməkdə (Grant J.E. icmalları)."
},
{
"i": 717,
"t": "SSRİ — komorbid MDD/narahatlıqda."
},
{
"i": 718,
"t": "Self-help (Gamblers Anonymous, Gam-Anon) — adjunkt."
},
{
"i": 719,
"t": "Maliyyə konsultasiyası — qumarda kritik."
},
{
"i": 720,
"t": "Gaming için — fiziki aktivlik, alternativ məşğuliyyət, ailə müdaxiləsi."
},
{
"i": 721,
"t": "Müalicə metodikaları"
},
{
"i": 722,
"t": "Qumar üçün KDT"
},
{
"i": 723,
"t": "— Koqnitiv distorsiyaların düzəldilməsi, ekspozisiya (tetikleyicilərə cavab azaltma), problem-həll."
},
{
"i": 724,
"t": "Naltrekson off-label"
},
{
"i": 725,
"t": "— Cravings azaltma; 50–150 mq/gün."
},
{
"i": 726,
"t": "SOGS, PGSI, IGDS9-SF"
},
{
"i": 727,
"t": "— Şkalalar."
},
{
"i": 728,
"t": "Self-help qrupları (GA)"
},
{
"i": 729,
"t": "— 12-step model."
},
{
"i": 730,
"t": "9. Proqnoz"
},
{
"i": 731,
"t": "KDT ilə remisya 30–50%."
},
{
"i": 732,
"t": "Komorbid MDD pis proqnoz."
},
{
"i": 733,
"t": "10. Mif və yanlış inanclar"
},
{
"i": 734,
"t": "Mif 1: \"Qumar asılılığı \"xarakter\" pozuntusudur\""
},
{
"i": 735,
"t": "Sübut:"
},
{
"i": 736,
"t": "DSM-5, XBT-11 — tibbi/davranış pozuntudur; neyrobioloji və genetik yatkınlıq."
},
{
"i": 737,
"t": "Mif 2: \"Pasiyent \"böyük utuş\"-la borcdan çıxar\""
},
{
"i": 738,
"t": "Sübut:"
},
{
"i": 739,
"t": "\"chasing losses\" qumarın diaqnostik əlamətidir; itki paterni statistik mütləqdir."
},
{
"i": 740,
"t": "Mif 3: \"Gaming asılılıq deyil, sadəcə hobbi\""
},
{
"i": 741,
"t": "Sübut:"
},
{
"i": 742,
"t": "WHO — Gaming Disorder rəsmi; funksional pozulma və neyrobioloji oxşarlıq."
},
{
"i": 743,
"t": "Mif 4: \"Yalnız maliyyə dəstəyi kifayətdir\""
},
{
"i": 744,
"t": "Sübut:"
},
{
"i": 745,
"t": "bailout asılılığı diaqnostik əlamətdir; psixososial müdaxilə tələb olunur."
},
{
"i": 746,
"t": "Mif 5: \"Pasiyent \"böyüyəndə keçər\"\""
},
{
"i": 747,
"t": "Sübut:"
},
{
"i": 748,
"t": "aktiv müdaxilə tələb olunur; xronikləşmə."
},
{
