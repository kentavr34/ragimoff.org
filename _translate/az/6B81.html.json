},
{
"i": 634,
"t": "SİNİR BULİMİYASI"
},
{
"i": 635,
"t": "Tərif və nozologiya"
},
{
"i": 636,
"t": "Tarixçə"
},
{
"i": 637,
"t": "Epidemiologiya"
},
{
"i": 638,
"t": "Etiologiya və patogenez"
},
{
"i": 639,
"t": "Klinik mənzərə"
},
{
"i": 640,
"t": "Diaqnoz"
},
{
"i": 641,
"t": "Müayinə və qiymətləndirmə"
},
{
"i": 642,
"t": "Müalicə"
},
{
"i": 643,
"t": "Proqnoz"
},
{
"i": 644,
"t": "Mif və yanlış inanclar"
},
{
"i": 645,
"t": "Mənbələr"
},
{
"i": 646,
"t": "1. Tərif və nozologiya"
},
{
"i": 647,
"t": "Sinir bulimiyası (XBT-11:"
},
{
"i": 648,
"t": "6B81"
},
{
"i": 649,
"t": "; DSM-5-TR: 307.51) — təkrarlanan obur yemə epizodları (qısa müddətdə çoxlu qida + nəzarət itkisi hissi) və kompensator davranışlar (qusma, laksativ, idman, oruc) ilə xarakterizə olunan yemə pozuntusudur. Anorexia-dan fərqli olaraq çəki tipik olaraq normal və ya artıqdır."
},
{
"i": 650,
"t": "2. Tarixçə"
},
{
"i": 651,
"t": "Russell G.F. (1979) — \"bulimia nervosa\" termini və ilk klinik təsvir."
},
{
"i": 652,
"t": "DSM-III (1980) — rəsmi diaqnoz."
},
{
"i": 653,
"t": "DSM-5 (2013) — tezlik meyarı həftədə 1 dəfəyə endirilmişdir (DSM-IV-də 2 dəfə)."
},
{
"i": 654,
"t": "3. Epidemiologiya"
},
{
"i": 655,
"t": "Ömürlük yayılma: qadınlarda 1,5–3%, kişilərdə 0,5%."
},
{
"i": 656,
"t": "Başlanğıc: yeniyetməlik və erkən yetkinlik."
},
{
"i": 657,
"t": "Komorbidlik: MDD ~70%, narahatlıq, maddə istifadəsi, BPD, anorexia tarixçəsi."
},
{
"i": 658,
"t": "Suicid riski yüksək."
},
{
"i": 659,
"t": "4. Etiologiya və patogenez"
},
{
"i": 660,
"t": "İrsilik 50–60%."
},
{
"i": 661,
"t": "Neyrobioloji — serotonergic disregulasiya, dopamin mükafat sistemi."
},
{
"i": 662,
"t": "Sosial-mədəni — incəlik idealı, dieta tarixçəsi."
},
{
"i": 663,
"t": "Şəxsiyyət — impulsivlik, perfeksionizm, aşağı özünə qiymət."
},
{
"i": 664,
"t": "5. Klinik mənzərə"
},
{
"i": 665,
"t": "Obur yemə epizodlar — kontrol itkisi, gizlin."
},
{
"i": 666,
"t": "Kompensator davranışlar:"
},
{
"i": 667,
"t": "Purging — özü-özünə qusma, laksativ, diuretik;"
},
{
"i": 668,
"t": "Non-purging — oruc, həddən artıq idman."
},
{
"i": 669,
"t": "Bədən imajı və çəki məşğuliyyəti."
},
{
"i": 670,
"t": "Tibbi komplikasiyalar: hipokalemiya (qusma), Russell əlaməti (parmaq döyənəkləri), diş eroziyası, parotid hipertrofiya, ezofagit, mədə-bağırsaq."
},
{
"i": 671,
"t": "6. Diaqnoz"
},
{
"i": 672,
"t": "6.1 Vahid diaqnostik meyarlar"
},
{
"i": 673,
"t": "A."
},
{
"i": 674,
"t": "Təkrarlanan obur yemə epizodlar — qısa müddətdə (≤ 2 saat) çoxlu qida + nəzarət itkisi hissi."
},
{
"i": 675,
"t": "B."
},
{
"i": 676,
"t": "Çəki artımının qarşısını almaq üçün təkrarlanan qeyri-uyğun kompensator davranışlar."
},
{
"i": 677,
"t": "C."
},
{
"i": 678,
"t": "Tezlik: ən azı həftədə 1 dəfə, ≥ 3 ay."
},
{
"i": 679,
"t": "D."
},
{
"i": 680,
"t": "Özünə qiymət çəki və bədən formasından həddən artıq asılı."
},
{
"i": 681,
"t": "E."
},
{
"i": 682,
"t": "Sinir anoreksiyası epizodu kontekstində baş vermir."
},
{
"i": 683,
"t": "6.2 Mənbə-spesifik dəqiqləşdirmələr"
},
{
"i": 684,
"t": "DSM-5-TR — şiddət epizod tezliyinə görə (yüngül 1–3, orta 4–7, ağır 8–13, ekstrem ≥ 14 həftədə)."
},
{
"i": 685,
"t": "XBT-11 — paralel; \"atypical bulimia nervosa\" kvalifikator."
},
{
"i": 686,
"t": "NICE NG69 — diaqnoz və müalicə."
},
{
"i": 687,
"t": "6.3 Diaqnostika alqoritmi"
},
{
"i": 688,
"t": "Klinik müsahibə."
},
{
"i": 689,
"t": "EDE-Q, EDE."
},
{
"i": 690,
"t": "Tibbi: elektrolitlər (K, P, Mg, Cl), qaraciyər, böyrək, EKG (QTc)."
},
{
"i": 691,
"t": "Diş müayinəsi (eroziya)."
},
{
"i": 692,
"t": "Komorbidlik və suicid riski."
},
{
"i": 693,
"t": "6.4 Differensial diaqnostika"
},
{
"i": 694,
"t": "Vəziyyət"
},
{
"i": 695,
"t": "Fərqləndirici"
},
{
"i": 696,
"t": "Sinir anoreksiyası, obur yemə/təmizlənmə tipi (6B80)"
},
{
"i": 697,
"t": "Çəki əhəmiyyətli aşağı."
},
{
"i": 698,
"t": "BED (6B82)"
},
{
"i": 699,
"t": "Kompensator davranış yox."
},
{
"i": 700,
"t": "Night Eating Syndrome"
},
{
"i": 701,
"t": "Gecə qida qəbulu üstündür."
},
{
"i": 702,
"t": "Klein-Levin sindromu"
},
{
"i": 703,
"t": "Hipersomniya + hiperfagiya."
},
{
"i": 704,
"t": "7. Müayinə və qiymətləndirmə"
},
{
"i": 705,
"t": "EDE-Q."
},
{
"i": 706,
"t": "Tibbi: elektrolitlər, EKG, diş müayinəsi."
},
{
"i": 707,
"t": "C-SSRS."
},
{
"i": 708,
"t": "8. Müalicə"
},
{
"i": 709,
"t": "CBT-E birinci sıra"
},
{
