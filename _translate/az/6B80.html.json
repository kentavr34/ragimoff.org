},
{
"i": 634,
"t": "SİNİR ANOREKSİYASI"
},
{
"i": 635,
"t": "Tərif və nozologiya"
},
{
"i": 636,
"t": "Tarixçə"
},
{
"i": 637,
"t": "Epidemiologiya"
},
{
"i": 638,
"t": "Etiologiya və patogenez"
},
{
"i": 639,
"t": "Klinik mənzərə"
},
{
"i": 640,
"t": "Diaqnoz"
},
{
"i": 641,
"t": "Müayinə və qiymətləndirmə"
},
{
"i": 642,
"t": "Müalicə"
},
{
"i": 643,
"t": "Proqnoz"
},
{
"i": 644,
"t": "Mif və yanlış inanclar"
},
{
"i": 645,
"t": "Mənbələr"
},
{
"i": 646,
"t": "1. Tərif və nozologiya"
},
{
"i": 647,
"t": "Sinir anoreksiyası (XBT-11:"
},
{
"i": 648,
"t": "6B80"
},
{
"i": 649,
"t": "; DSM-5-TR: 307.1) — qida qəbulunun məhdudlaşdırılması nəticəsində əhəmiyyətli aşağı bədən çəkisi, çəki artımından kəskin qorxu və bədən imajının pozulması ilə xarakterizə olunan ağır yemə pozuntusudur. Mortalite ən yüksək psixiatrik pozuntular sırasındadır."
},
{
"i": 650,
"t": "2. Tarixçə"
},
{
"i": 651,
"t": "Morton R. (1689) — ilk klinik təsvir."
},
{
"i": 652,
"t": "Lasègue C. (1873) və Gull W. (1874) — \"anorexia hysterica\" və \"sinir anoreksiyası\"."
},
{
"i": 653,
"t": "DSM-III (1980) — rəsmi diaqnoz."
},
{
"i": 654,
"t": "DSM-5 (2013) — amenoreya meyarı ləğv olunmuşdur (kişilərdə və premenarchal-da diaqnoz mümkün)."
},
{
"i": 655,
"t": "3. Epidemiologiya"
},
{
"i": 656,
"t": "Ömürlük yayılma: qadınlarda 0,9–4%, kişilərdə 0,3% (Smink F.R. icmalları)."
},
{
"i": 657,
"t": "Cins: qadınlarda 10:1; lakin kişi pasiyentlərdə az-aşkarlanma."
},
{
"i": 658,
"t": "Başlanğıc: yeniyetməlik (14–18 yaş); ikinci pik orta yaşda."
},
{
"i": 659,
"t": "Mortalite: ömürlük 5–6%; yarısı tibbi (kahheksiya, ürək), yarısı intihar (Arcelus J. et al. Arch Gen Psychiatry 2011 meta-analiz)."
},
{
"i": 660,
"t": "Komorbidlik: MDD, OKP, narahatlıq, BPD."
},
{
"i": 661,
"t": "4. Etiologiya və patogenez"
},
{
"i": 662,
"t": "İrsilik 50–60% (Bulik C.M. icmalları)."
},
{
"i": 663,
"t": "Neyrobioloji — koqnitiv elastikliyin azalması, mükafat dövrü disregulasiyası, açlığa qeyri-tipik cavab."
},
{
"i": 664,
"t": "Sosial-mədəni amillər — incəlik idealı; sosial media təsiri."
},
{
"i": 665,
"t": "Şəxsiyyət — perfeksionizm, narahatlıq, ailə tarixçəsində yemə pozuntusu."
},
{
"i": 666,
"t": "5. Klinik mənzərə"
},
{
"i": 667,
"t": "Qida məhdudlaşdırılması — kalori, qida növləri."
},
{
"i": 668,
"t": "Bədən çəkisi əhəmiyyətli aşağı (BMI &lt; 18,5 yetkinlərdə; uşaqlarda BMI persentili)."
},
{
"i": 669,
"t": "Çəki artımından kəskin qorxu və ya qarşısının alınmasına yönəlmiş davamlı davranış."
},
{
"i": 670,
"t": "Bədən imajının pozulması — \"kök hiss edirəm\" arıq olduqda da."
},
{
"i": 671,
"t": "Alt-tiplər:"
},
{
"i": 672,
"t": "Restriktiv tip"
},
{
"i": 673,
"t": "— yalnız qida məhdudlaşdırılması."
},
{
"i": 674,
"t": "Obur yemə/təmizlənmə tipi"
},
{
"i": 675,
"t": "— qusma, laksativ, idman."
},
{
"i": 676,
"t": "Tibbi komplikasiyalar — bradikardiya, hipotenziya, hipotermiya, elektrolit disbalansı, osteoporoz, amenoreya, lanugo, ürək aritmiyası, ölüm."
},
{
"i": 677,
"t": "6. Diaqnoz"
},
{
"i": 678,
"t": "6.1 Vahid diaqnostik meyarlar"
},
{
"i": 679,
"t": "A."
},
{
"i": 680,
"t": "Qida qəbulunun məhdudlaşdırılması nəticəsində əhəmiyyətli aşağı çəki (BMI &lt; 18,5 yetkinlərdə; uşaqlarda yaşa uyğun normadan aşağı)."
},
{
"i": 681,
"t": "B."
},
{
"i": 682,
"t": "Çəki artımından kəskin qorxu və ya buna qarşı davamlı davranış, çəki aşağı olsa belə."
},
{
"i": 683,
"t": "C."
},
{
"i": 684,
"t": "Bədən imajının pozulması və ya hazırkı çəkinin ciddiyyətini tanımama."
},
{
"i": 685,
"t": "6.2 Mənbə-spesifik dəqiqləşdirmələr"
},
{
"i": 686,
"t": "DSM-5-TR — şiddət BMI əsasında (yüngül BMI ≥ 17, orta 16–16,99, ağır 15–15,99, ekstrem &lt; 15)."
},
{
"i": 687,
"t": "XBT-11 — paralel; \"atypical sinir anoreksiyası\" çəki BMI normal olduqda mümkündür (6B8Y)."
},
{
"i": 688,
"t": "NICE NG69 (Eating disorders, 2017, yenilənmə) — diaqnoz və müalicə alqoritmləri."
},
{
"i": 689,
"t": "6.3 Diaqnostika alqoritmi"
},
{
"i": 690,
"t": "Klinik müsahibə."
},
{
"i": 691,
"t": "EDE-Q (Eating Disorder Examination Questionnaire) və ya EDE — qızıl standart."
},
{
"i": 692,
"t": "Tibbi müayinə — BMI, vital göstəricilər, elektrolitlər, EKG, kemik dansitometriyası."
},
{
"i": 693,
"t": "Laborator: tam qan, elektrolitlər (xüsusilə K, P, Mg), qaraciyər, böyrək, qlükoza, tireoid."
},
{
"i": 694,
"t": "Komorbidlik (MDD, OKP, narahatlıq)."
},
{
"i": 695,
"t": "Refeeding sindromu riski qiymətləndirməsi (xüsusilə BMI &lt; 13 və ya minimal qida qəbulu uzun müddət)."
},
{
"i": 696,
"t": "6.4 Differensial diaqnostika"
},
{
"i": 697,
"t": "Vəziyyət"
},
{
"i": 698,
"t": "Fərqləndirici"
},
{
"i": 699,
"t": "Sinir bulimiyası (6B81)"
},
{
"i": 700,
"t": "Normal çəki; obur yemə + kompensator davranış."
},
{
"i": 701,
"t": "ARFID (6B85)"
},
{
"i": 702,
"t": "Çəki itkisi, lakin bədən imajı pozulması yoxdur."
},
{
"i": 703,
"t": "Tibbi xəstəlik (xərçəng, hipertiroid, IBS, Krohn)"
},
{
"i": 704,
"t": "Klinik təsdiq."
},
{
"i": 705,
"t": "MDD (qida qəbulunun azalması)"
},
{
"i": 706,
"t": "Bədən imajı pozulması yoxdur."
},
{
"i": 707,
"t": "Şizofreniya (qida sayıqlaması)"
},
{
"i": 708,
"t": "Psixotik fikir əsas."
},
{
"i": 709,
"t": "7. Müayinə və qiymətləndirmə"
},
{
"i": 710,
"t": "EDE-Q, EDE."
},
{
"i": 711,
"t": "Vital göstəricilər, BMI, çəki tarixçəsi."
},
{
"i": 712,
"t": "Laborator: tam qan, elektrolitlər, qaraciyər, böyrək, tireoid, FSH/LH, prolaktin, vitamin D, B12, dəmir."
},
{
"i": 713,
"t": "EKG — bradikardiya, QTc."
},
{
"i": 714,
"t": "DEXA — osteoporoz."
},
{
"i": 715,
"t": "C-SSRS suicid riski."
},
{
"i": 716,
"t": "8. Müalicə"
},
{
"i": 717,
"t": "8.1 Ümumi prinsiplər (NICE NG69 · APA 2023)"
},
{
"i": 718,
"t": "Tibbi stabilizasiya kritik:"
},
{
"i": 719,
"t": "elektrolitlər, refeeding sindromu profilaktikası (fosfor, magnezium, tiamin), kardiyak monitorinq."
},
{
"i": 720,
"t": "Hospitalize göstərişi:"
},
{
"i": 721,
"t": "BMI &lt; 13, bradikardiya &lt; 40, hipokalemia, ortostatik dəyişikliklər, suicid riski, ambulatorda uğursuzluq."
},
{
"i": 722,
"t": "Psixoterapiya birinci sıra:"
},
{
"i": 723,
"t": "FBT — Family-Based Treatment (Maudsley Model, Lock J., Le Grange D.)"
},
{
"i": 724,
"t": "— uşaq və yeniyetmələrdə qızıl standart; 20 seans 3 fazada."
},
{
"i": 725,
"t": "CBT-E — Enhanced Cognitive Behavioral Therapy (Fairburn C.G.)"
},
{
"i": 726,
"t": "— yetkinlərdə birinci sıra; 40 seans 20 həftə."
},
{
"i": 727,
"t": "MANTRA, SSCM yetkin alternativləri."
},
{
"i": 728,
"t": "Farmakoterapiya AN üçün spesifik effektiv preparat YOXDUR"
},
{
"i": 729,
"t": "— antidepresant və antipsixotik komorbidlik üçün; olanzapin aşağı dozada (2,5–10 mq) bəzi pasiyentlərdə çəki artımına yardım edə bilər (Attia E. et al. Am J Psychiatry 2019), lakin əsas müdaxilə deyil."
},
{
"i": 730,
"t": "Nutrisiya — qrupla və ya fərdi nutrisionist; refeeding sindromu profilaktikası — başlanğıc enerji aşağıdan başlanır, fosfor monitorinqi."
},
{
"i": 731,
"t": "Müalicə müddəti uzun (1–2 il və ya daha çox)."
},
{
"i": 732,
"t": "8.2 Mənbə-spesifik dəqiqləşdirmələr"
},
{
"i": 733,
"t": "NICE NG69 (2017) — FBT uşaq və yeniyetmələrdə; CBT-E yetkinlərdə."
},
{
"i": 734,
"t": "APA 2023 Practice Guideline for the Treatment of Patients with Eating Disorders, 4th ed."
},
{
"i": 735,
"t": "AED (Academy for Eating Disorders) — refeeding sindromu medical care standartları."
},
{
"i": 736,
"t": "NICE — antidepresant rutin tövsiyə edilmir AN üçün."
},
{
"i": 737,
"t": "Müalicə metodikaları"
},
{
"i": 738,
"t": "Ailə-Əsaslı Müalicə / Maudsli Modeli (FBT — Family-Based Treatment) — Lok (Lock J.), Le Qranj (Le Grange D.)"
},
{
"i": 739,
"t": "— 3 fazalı 20 seans: (1) çəkinin bərpası — ailə qida qəbulunu nəzarət edir; (2) ailəyə yeyə nəzarətinin geri qaytarılması; (3) yeniyetmə-spesifik mövzular. Sübut: Lock J. et al. Arch Gen Psychiatry 2010 RKİ."
},
{
"i": 740,
"t": "Gücləndirilmiş Koqnitiv-Davranış Terapiyası (CBT-E — Enhanced Cognitive Behavioral Therapy) — Feyrbörn (Fairburn C.G.)"
},
{
"i": 741,
"t": "— Transdiaqnostik (AN, BN, BED birgə) yanaşma; 40 seans 20 həftə; mərkəzdə bədən və çəki haqqında həddən artıq dəyər."
},
{
"i": 742,
"t": "cbte.co"
},
{
"i": 743,
"t": "Maudsli Yetkinlərdə Sinir Anoreksiyası Müalicəsi (MANTRA — Maudsley Anorexia Nervosa Treatment for Adults) — Şmidt (Schmidt U.)"
},
{
"i": 744,
"t": "— Yetkinlər üçün manualizə edilmiş; sosial-perfeksionist xüsusiyyətlərə fokus."
},
{
"i": 745,
"t": "Mütəxəssis Dəstəkləyici Klinik İdarəetmə (SSCM — Specialist Supportive Clinical Management)"
},
{
"i": 746,
"t": "— Klinik nəzarət və psixoedukation əsaslı."
},
{
"i": 747,
"t": "Yemə Pozuntusu Müayinə Sorğusu (EDE-Q — Eating Disorder Examination Questionnaire)"
},
{
"i": 748,
"t": "— 28 maddə; ilkin göstəricilər və izləmə."
},
{
"i": 749,
"t": "Refeeding Protokolu (Maudsley, AED)"
},
{
"i": 750,
"t": "— Başlanğıc 20 kkal/kq/gün; fosfor, magnezium, kalium əlavələri; tiamin; gündəlik elektrolit monitorinqi."
},
{
"i": 751,
"t": "9. Proqnoz"
},
{
"i": 752,
"t": "50% remisya, 30% qalıq simptomlar, 20% xronik gediş."
},
{
"i": 753,
"t": "Mortalite yüksək (5–6%)."
},
{
"i": 754,
"t": "Erkən müdaxilə (xüsusilə yeniyetməlikdə FBT) proqnozu əhəmiyyətli yaxşılaşdırır."
},
{
"i": 755,
"t": "10. Mif və yanlış inanclar"
},
{
"i": 756,
"t": "Mif 1: \"Anorexia \"imaj\" pozuntusudur, ciddi tibbi vəziyyət deyil\""
},
{
"i": 757,
"t": "Sübut:"
},
{
"i": 758,
"t": "Arcelus 2011 meta-analiz — AN ömürlük mortalite 5–6%; psixiatrik pozuntular arasında ən yüksək."
},
{
"i": 759,
"t": "Mif 2: \"Pasiyent iradi olaraq yeyə bilər — sadəcə tələb etmək lazımdır\""
},
{
"i": 760,
"t": "Sübut:"
},
{
"i": 761,
"t": "AN neyrobioloji və psixoloji kompleks pozuntudur; \"iradi olaraq yemə\" izahatı yanlış və zərərli."
},
{
"i": 762,
"t": "Mif 3: \"Antidepresant AN-da əsas müalicədir\""
},
{
"i": 763,
"t": "Sübut:"
},
{
"i": 764,
"t": "NICE NG69 — AN üçün antidepresant rutin tövsiyə edilmir; komorbid MDD üçün istifadə oluna bilər (çəki bərpasından sonra daha effektiv)."
},
{
"i": 765,
"t": "Mif 4: \"AN yalnız yeniyetmə qızlarda olur\""
},
{
"i": 766,
"t": "Sübut:"
},
{
"i": 767,
"t": "AN kişilərdə də mövcuddur (~10%); orta yaşda da inkişaf edə bilər; az-aşkarlanma sıxdır."
},
{
"i": 768,
"t": "Mif 5: \"Çəki bərpasından sonra problem həll olunur\""
},
{
"i": 769,
"t": "Sübut:"
},
{
"i": 770,
"t": "çəki bərpası vacib addımdır, lakin koqnitiv-davranış komponentin müdaxiləsiz residiv yüksəkdir; psixoterapiya kritik."
},
{
"i": 771,
"t": "Mif 6: \"Refeeding sürətli olmalıdır\""
},
{
"i": 772,
"t": "Sübut:"
},
{
"i": 773,
"t": "sürətli refeeding sindromuna (hipofosfatemiya, kardiyak çatışmazlıq) gətirə bilər; pilləli yanaşma və elektrolit monitorinqi kritik."
},
{
"i": 774,
"t": "Mif 7: \"Pasiyent perfeksionist və yüksək performanslıdır — bu xüsusiyyət saxlanılmalıdır\""
},
{
"i": 775,
"t": "Sübut:"
},
{
"i": 776,
"t": "perfeksionizm AN-ın saxlayıcı amillərindəndir; terapiya bu xüsusiyyətə yönəlir."
},
