"t": "6E20"
},
{
"i": 249,
"t": "DOĞUŞDAN SONRAKI TƏŞVİŞ, OKP, PTSP"
},
{
"i": 250,
"t": "6E40"
},
{
"i": 251,
"t": "PSİXOSOMATİK AMİLLƏR"
},
{
"i": 252,
"t": "6E60–6E6Z"
},
{
"i": 253,
"t": "İKİNCİLİ PSİXİ VƏ DAVRANIŞ SİNDROMLARI"
},
{
"i": 254,
"t": "7A00–7B2Z"
},
{
"i": 255,
"t": "YUXU POZUNTULARI"
},
{
"i": 256,
"t": "HA00–HA8Z"
},
{
"i": 257,
"t": "CİNSİ DİSFUNKSİYALAR VƏ CİNSİ SAĞLAMLIQ POZUNTULARI"
},
{
"i": 258,
"t": "ƏLAVƏLƏR"
},
{
"i": 259,
"t": "ƏLAVƏ A"
},
{
"i": 260,
"t": "MONİTORİNQ VƏ MÜAYİNƏ STANDARTLARI"
},
{
"i": 261,
"t": "Bu əlavə psixotrop dərmanların istifadəsində"
},
{
"i": 262,
"t": "təhlükəsizlik monitorinqi"
},
{
"i": 263,
"t": "və psixiatrik xəstələrin"
},
{
"i": 264,
"t": "tibbi vəziyyətinin izlənməsi"
},
{
"i": 265,
"t": "üçün standart protokolları təqdim edir."
},
{
"i": 266,
"t": "A.1. Antipsikotik terapiyada metabolik monitorinq"
},
{
"i": 267,
"t": "Atipik antipsikotiklər – xüsusilə olanzapin, kvetiapin, klozapin –"
},
{
"i": 268,
"t": "metabolik sindrom riskini artırır"
},
{
"i": 269,
"t": "(çəki artımı, dislipidemia, insulinə müqavimət, diabet)."
},
{
"i": 270,
"t": "Monitorinq cədvəli (APA/ADA 2004, İşıqlandırılmış ADA-APA-ACP-NAASO):"
},
{
"i": 271,
"t": "Parametr"
},
{
"i": 272,
"t": "Başlanğıc"
},
{
"i": 273,
"t": "4 həftə"
},
{
"i": 274,
"t": "8 həftə"
},
{
"i": 275,
"t": "12 həftə"
},
{
"i": 276,
"t": "Rüblük"
},
{
"i": 277,
"t": "İllik"
},
{
"i": 278,
"t": "Şəxsi/ailə tarixçəsi"
},
{
"i": 279,
"t": "Çəki, bel çevrəsi"
},
{
"i": 280,
"t": "Arterial təzyiq"
},
{
"i": 281,
"t": "Aclı qlükoza"
},
{
"i": 282,
"t": "Aclı lipid profili"
},
{
"i": 283,
"t": "✓ (2 ildə bir)"
},
{
"i": 284,
"t": "Əgər anormallıq aşkar olunsa:"
},
{
"i": 285,
"t": "Çəki artımı ≥7%:"
},
{
"i": 286,
"t": "dərman dəyişdirilməsinə bax (aripiprazol, ziprasidon – metabolik neytral);"
},
{
"i": 287,
"t": "HbA1c ≥6,5% və ya aclı qlükoza ≥7:"
},
{
"i": 288,
"t": "diabet konsultasiyası;"
},
{
"i": 289,
"t": "LDL ≥3,4 mmol/L:"
},
{
"i": 290,
"t": "pəhriz, statin."
},
{
"i": 291,
"t": "Klozapinə spesifik monitorinq (agranulositoza görə):"
},
{
"i": 292,
"t": "Müddət"
},
{
"i": 293,
"t": "Tezlik"
},
{
"i": 294,
"t": "İlk 6 ay"
},
{
"i": 295,
"t": "Həftəlik WBC və mütləq neytrofil (ANC)"
},
{
"i": 296,
"t": "7–12 ay"
},
{
"i": 297,
"t": "2 həftədə bir"
},
{
"i": 298,
"t": "12+ ay"
},
{
"i": 299,
"t": "Aylıq"
},
{
"i": 300,
"t": "ANC göstəriciləri:"
},
{
"i": 301,
"t": "≥2,0 × 10⁹/L:"
},
{
"i": 302,
"t": "normal – müalicəni davam et;"
},
{
"i": 303,
"t": "həftəlik izləmə;"
},
{
"i": 304,
"t": "2 gündə bir izləmə, hematoloq konsultasiyası;"
},
{
"i": 305,
"t": "&lt;1,0:"
},
{
"i": 306,
"t": "dərman dayandırılır, hematoloq müdaxiləsi"
},
{
"i": 307,
"t": "Antipsikotiklərdə EKG monitorinqi:"
},
{
"i": 308,
"t": "QTc uzanması riski:"
},
{
"i": 309,
"t": "xüsusi ziprazidon, haloperidol IV, ondansetron kombinasiya;"
},
{
"i": 310,
"t": "Başlanğıc EKG"
},
{
"i": 311,
"t": "risk amilləri olan pasiyentlərdə (ürək xəstəliyi, elektrolit pozuntusu, &gt;65 yaş);"
},
{
"i": 312,
"t": "QTc &gt;500 msn və ya bazadan &gt;60 msn artım"
},
{
"i": 313,
"t": "dərman dəyişikliyi"
},
{
"i": 314,
"t": "Risk artıran dərmanlar:"
},
{
"i": 315,
"t": "klorpromazin, haloperidol (yüksək), tioridazin."
},
{
"i": 316,
"t": "Hiperprolaktinemiya:"
},
{
"i": 317,
"t": "Risperidon, amisulprid, paliperidon"
},
{
"i": 318,
"t": "– yüksək risk;"
},
{
"i": 319,
"t": "Simptomlar: amenore, galaktoreya, cinsi disfunksiya, osteoporoz;"
},
{
"i": 320,
"t": "Bazal prolaktin; təkrar simptomla."
},
{
"i": 321,
"t": "A.2. Litium monitorinqi"
},
{
"i": 322,
"t": "Dar terapevtik pəncərə"
},
{
"i": 323,
"t": "səviyyə 0,6–1,2 mEq/L"
},
{
"i": 324,
"t": ", &gt;1,5 toksik."
},
{
"i": 325,
"t": "Parametr"
},
{
"i": 326,
"t": "Başlanğıc"
},
{
"i": 327,
"t": "Hər 6 ay"
},
{
"i": 328,
"t": "İllik"
},
{
"i": 329,
"t": "Litium səviyyəsi"
},
{
"i": 330,
"t": "Həftəlik 1-ci ay, sonra hər 6 ay"
},
{
"i": 331,
"t": "Kreatinin, eGFR"
},
{
"i": 332,
"t": "TSH"
},
{
"i": 333,
"t": "Elektrolitlər"
},
{
"i": 334,
"t": "Kalsium"
},
{
"i": 335,
"t": "EKG"
},
{
"i": 336,
"t": "✓ (50+ yaş)"
},
{
"i": 337,
"t": "Hamiləlik testi"
},
{
"i": 338,
"t": "Doğuş yaşında qadın"
},
{
"i": 339,
"t": "Litium intoksikasiyası əlamətləri:"
},
{
"i": 340,
"t": "Tremor (daha güclü);"
},
{
"i": 341,
"t": "Taksikardiya;"
},
{
"i": 342,
"t": "Diareya, qusma;"
},
{
"i": 343,
"t": "Yavaş, qarışıq nitq;"
},
{
"i": 344,
"t": "Ataksiya;"
},
{
"i": 345,
"t": "Konvulsiya – ağır vəziyyətlərdə."
},
{
"i": 346,
"t": "Vəziyyət dəyişikliyində səviyyə yoxla:"
},
{
"i": 347,
"t": "dehidratasiya, NSAİD əlavəsi, ACE inhibitor əlavəsi, böyrək funksiyasında dəyişiklik."
},
{
"i": 348,
"t": "A.3. Antikonvulsantlar (valproat, karbamazepin, lamotrigin)"
},
{
"i": 349,
"t": "Valproat:"
},
{
"i": 350,
"t": "Parametr"
},
{
"i": 351,
"t": "Başlanğıc"
},
{
"i": 352,
"t": "Hər 6 ay"
},
{
"i": 353,
"t": "CBC (trombositopeniya)"
},
{
"i": 354,
"t": "Qaraciyər funksiyası (AST, ALT)"
},
{
"i": 355,
"t": "Valproat səviyyəsi"
},
{
"i": 356,
"t": "Simptom və ya şübhə ilə"
},
{
"i": 357,
"t": "Pankreatit əlamətlərinin izlənməsi"
},
{
"i": 358,
"t": "Hər ziyarət"
},
{
"i": 359,
"t": "Hamiləlik testi"
},
{
"i": 360,
"t": "QƏTİ MÜTLƏQ doğuş yaşlı qadında"
},
{
"i": 361,
"t": "Hər rüb"
},
{
"i": 362,
"t": "&gt;"
},
{
"i": 363,
"t": "Kritik:"
},
{
"i": 364,
"t": "valproat"
},
{
"i": 365,
"t": "doğuş yaşlı qadınlarda"
},
{
"i": 366,
"t": "neyral boru defekti və koqnitiv zərər səbəbinə görə"
},
{
"i": 367,
"t": "yalnız effektiv kontrasepsiya ilə"
},
{
"i": 368,
"t": ", digər seçimlər əvvəlcə qiymətləndirildikdən sonra."
},
{
"i": 369,
"t": "Karbamazepin:"
},
{
"i": 370,
"t": "CBC, qaraciyər – başlanğıc, 1 ay, rüblük;"
},
{
"i": 371,
"t": "HLA-B*1502 testi"
},
{
"i": 372,
"t": "Asiya mənşəli pasiyentlərdə (Stevens-Johnson riski);"
},
{
"i": 373,
"t": "Auto-induksiya səbəbindən səviyyənin enməsi ilk 4 həftədə – səviyyə yoxla."
},
{
"i": 374,
"t": "Lamotrigin:"
},
{
"i": 375,
"t": "Yavaş titrasiya"
},
{
"i": 376,
"t": "– Stevens-Johnson sindromu riski;"
},
{
"i": 377,
"t": "Başlanğıc 25 mq həftədə"
},
{
"i": 378,
"t": ", 4–8 həftə ərzində hədəf dozaya;"
},
{
"i": 379,
"t": "Valproat ilə birlikdə:"
},
{
"i": 380,
"t": "başlanğıc 12,5 mq"
},
{
"i": 381,
"t": "– valproat lamotrigin metabolizmini yavaşlatır;"
},
{
"i": 382,
"t": "Dəri reaksiyası olsa –"
},
{
"i": 383,
"t": "dərhal dayandır."
},
{
"i": 384,
"t": "A.4. SSRİ və SNRİ monitorinqi"
},
{
"i": 385,
"t": "Hiponatremiya riski"
},
{
"i": 386,
"t": "– xüsusilə yaşlılarda, diuretik istifadə edənlərdə;"
},
{
"i": 387,
"t": "Bazal Na"
},
{
"i": 388,
"t": ", 1 ay sonra, sonra simptom ilə;"
},
{
"i": 389,
"t": "Suicidalitet artımı"
},
{
"i": 390,
"t": "xüsusilə 25 yaşdan aşağı başlanğıcda – ilk 1-2 ay yaxın monitorinq;"
},
{
"i": 391,
"t": "QTc uzanma"
},
{
"i": 392,
"t": "– esitalopram, sitalopram (yüksək dozalarda);"
},
{
"i": 393,
"t": "Serotonin sindromu"
},
{
"i": 394,
"t": "(MAOİ və ya triptan və s. kombinasiyada) – əlamətlərin öyrədilməsi."
},
{
"i": 395,
"t": "A.5. Benzodiazepin istifadəsi"
},
{
"i": 396,
"t": "Maximum uzunluq: 2–4 həftə"
},
{
"i": 397,
"t": "Uzunmüddətli istifadədə asılılıq qaçılmazdır;"
},
{
"i": 398,
"t": "Azaltma sxemi (tapering):"
},
{
"i": 399,
"t": "25% hər 2 həftə, bəzən daha yavaş;"
},
{
"i": 400,
"t": "Geriyə təpki simptomları"
},
{
"i": 401,
"t": "(rebound anxiety, yuxusuzluq, tremor) normal və müvəqqətidir."
},
{
"i": 402,
"t": "A.6. Psixoterapiya monitorinqi"
},
{
"i": 403,
"t": "Keyfiyyət göstəriciləri:"
},
{
"i": 404,
"t": "Seansın davam müddəti, tezlik;"
},
{
"i": 405,
"t": "Xəstə simptom şkalaları (PHQ-9, GAD-7 və s.)"
},
{
"i": 406,
"t": "hər 4–6 həftə"
},
{
"i": 407,
"t": "Funksional göstəricilər;"
},
{
"i": 408,
"t": "Terapevtik əlaqə qiymətləndirilməsi (Working Alliance Inventory);"
},
{
"i": 409,
"t": "Kənar məqsədlərə çatma;"
},
{
"i": 410,
"t": "Residiv əlamətləri."
},
{
"i": 411,
"t": "Supervision və kolleqial konsultasiya – kompleks pasiyentlərdə və istəyən klinisist üçün."
},
{
"i": 412,
"t": "ƏLAVƏ C"
},
{
"i": 413,
"t": "PSİXİATRİK TƏCİLİ VƏZİYYƏTLƏR"
},
{
"i": 414,
"t": "Bu əlavə həyatı təhdid edən və ya kəskin kliniki dəyərləndirmə tələb edən psixiatrik vəziyyətlərə praktik yanaşma təqdim edir."
},
{
"i": 415,
"t": "C.1. Aktiv intihar riski"
},
{
"i": 416,
"t": "İlkin qiymətləndirmə:"
},
{
"i": 417,
"t": "İntihar düşüncəsi varmı? Plan? Vasitə?"
},
{
"i": 418,
"t": "Yaxınlıq, konkretlik:"
},
{
"i": 419,
"t": "&quot;Bu gün axşam həyətəm tabançayla...&quot;  vs ümumi &quot;Bəzən ölmək istəyirəm&quot;;"
},
{
"i": 420,
"t": "Əvvəlki cəhdlər"
},
{
"i": 421,
"t": "– ən güclü prediktor;"
},
{
"i": 422,
"t": "Maddə intoksikasiyası"
},
{
"i": 423,
"t": "– inhibisiya azalır;"
},
{
"i": 424,
"t": "Protektiv faktorlar"
},
{
"i": 425,
"t": "– ailə, dini inanclar, gələcək planlar."
},
{
"i": 426,
"t": "Yüksək risk əlamətləri:"
},
{
"i": 427,
"t": "Konkret plan + vasitələrə çatımlılıq;"
},
{
"i": 428,
"t": "Yaxın vəziyyət dəyişikliyi (itki, ağır xəstəlik);"
},
{
"i": 429,
"t": "Təklik + rağın;"
},
{
"i": 430,
"t": "Psixoz və ya ağır depressiya;"
},
{
"i": 431,
"t": "Yeni başlanğıc və ya dərin hipomania (enerji qayıdır + aşağı əhval qalır);"
},
{
"i": 432,
"t": "Yetkin kişi + əlillik + alkogol."
},
{
"i": 433,
"t": "İdarəetmə:"
},
{
"i": 434,
"t": "Aşağı-orta risk:"
},
{
"i": 435,
"t": "Təhlükəsizlik planı"
},
{
"i": 436,
"t": "– yazılı;"
},
{
"i": 437,
"t": "Vasitələrə çatımlılığın azaldılması (silah uzaqlaşdırılması, dərman kiçik miqdarlarda);"
},
{
"i": 438,
"t": "Yaxın ambulator izləmə (24-48 saatda yenidən);"
},
{
"i": 439,
"t": "Krizi xətti nömrəsi;"
},
{
"i": 440,
"t": "Ailə iştirakı (razılıqla)."
},
{
"i": 441,
"t": "Yüksək risk:"
},
{
"i": 442,
"t": "Hospitalizasiya"
},
{
"i": 443,
"t": "(könüllü və ya məcburi);"
},
{
"i": 444,
"t": "Yaxın nəzarət – 1:1 əgər çox yüksək;"
},
{
"i": 445,
"t": "İntihar üsullarının kənarlaşdırılması (kəskin əşya, ip, pəncərə);"
},
{
"i": 446,
"t": "Nəzarətli dərman qəbulu."
},
{
"i": 447,
"t": "Məcburi hospitalizasiya Azərbaycan çərçivəsində:"
},
{
"i": 448,
"t": "&quot;Psixiatrik yardım haqqında&quot; Azərbaycan Respublikası qanunu;"
},
{
"i": 449,
"t": "Məcburi hospitalizasiya üçün"
},
{
"i": 450,
"t": "iki psixiatrın qərarı"
},
{
"i": 451,
"t": "və hüquqi prosedur;"
},
{
"i": 452,
"t": "72 saat təcili müşahidə sonra məhkəmə qərarı."
},
{
"i": 453,
"t": "C.2. Delirium tremens və alkogol kəsilməsi"
},
{
"i": 454,
"t": "Simptomlar:"
},
{
"i": 455,
"t": "Tremor"
},
{
"i": 456,
"t": "– əllər, sonra ümumi;"
},
{
"i": 457,
"t": "Təşviş, aqitasiya;"
},
{
"i": 458,
"t": "Halüsinasiya"
},
{
"i": 459,
"t": "– visual, tactile (&quot;həşəratlar üzərimdə&quot;);"
},
{
"i": 460,
"t": "Dezorientasiya;"
},
{
"i": 461,
"t": "Autonom hiperaktivlik"
},
{
"i": 462,
"t": "– taksikardiya, təzyiq, tərləmə, qızdırma;"
},
{
"i": 463,
"t": "Tutmalar"
},
{
"i": 464,
"t": "Müalicə (ICU və ya IMU şəraitində):"
},
{
"i": 465,
"t": "Benzodiazepin"
},
{
"i": 466,
"t": "diazepam 10-20 mq IV/IM hər 15-20 dəq"
},
{
"i": 467,
"t": "sedasyon əldə olunana qədər; sonra saxlayıcı rejim;"
},
{
"i": 468,
"t": "Alternativ: lorazepam (qaraciyər disfunksiyası olanlarda);"
},
{
"i": 469,
"t": "Tiamin 100-300 mq IV"
},
{
"i": 470,
"t": "– Wernicke ensefalopatiyasının qarşısının alınması."
},
{
"i": 471,
"t": "Qlukoza verməzdən əvvəl"
},
{
"i": 472,
"t": "Maye və elektrolit"
},
{
"i": 473,
"t": "bərpası;"
},
{
"i": 474,
"t": "Magnezium sulfatı, kalium – çox vaxt aşağı;"
},
{
"i": 475,
"t": "Ölümçüllük: müalicəsiz 15-20%, adekvat müalicə ilə &lt;1%."
},
{
"i": 476,
"t": "CIWA-Ar shkalası – monitorinqdə."
},
{
"i": 477,
"t": "C.3. Serotonin sindromu"
},
{
"i": 478,
"t": "Səbəb:"
},
{
"i": 479,
"t": "SSRİ + MAOİ, SSRİ + triptan, SSRİ + tramadol, SSRİ + linezolid, SSRİ + metilen mavisi və s."
},
{
"i": 480,
"t": "Simptomlar:"
},
{
"i": 481,
"t": "Mental dəyişiklik"
},
{
"i": 482,
"t": "– aqitasiya, konfüziya;"
},
{
"i": 483,
"t": "Autonom"
},
{
"i": 484,
"t": "– taksikardiya, hipertoniya, hipertermiya, tərləmə;"
},
{
"i": 485,
"t": "Neyromuskulyar"
},
{
"i": 486,
"t": "– tremor, hiperrefleksiya,"
},
{
"i": 487,
"t": "klonus"
},
{
