"i": 643,
"t": "ƏLAVƏ E"
},
{
"i": 644,
"t": "ƏLAQƏLİ NEYROLOJİ ŞƏRTLƏR"
},
{
"i": 645,
"t": "Psixiatriya və neyrologiyanın kəsişdiyi sahələrdə klinik praktika üçün vacib olan neyroloji xəstəliklərin qısa təsviri."
},
{
"i": 646,
"t": "E.1. Epilepsiya (G40) və psixiatrik təzahürlər"
},
{
"i": 647,
"t": "Epileptik sindromlar və psixiatriya:"
},
{
"i": 648,
"t": "- İnter-ikt şəxsiyyət dəyişiklikləri (Geschwind sindromu – hiperreligiozluq, hipergrafiya, &quot;viskozlıq&quot;);"
},
{
"i": 649,
"t": "- İnter-ikt psixoz – uzunmüddətli TLE;"
},
{
"i": 650,
"t": "- Post-ikt psixoz – tutma sonrası 24-72 saat ərzində psixotik epizodlar;"
},
{
"i": 651,
"t": "- İkt təşviş və dissosiativ təcrübələr;"
},
{
"i": 652,
"t": "Temporal lob epilepsiyası (TLE)"
},
{
"i": 653,
"t": "– ən çox psixiatrik komorbidlik:"
},
{
"i": 654,
"t": "Absans epilepsiyası"
},
{
"i": 655,
"t": "– diqqət problemi, DDHP ilə diferensial;"
},
{
"i": 656,
"t": "Juvenile miyoklonik epilepsiya"
},
{
"i": 657,
"t": "– yüksək komorbid təşviş, impulsivlik."
},
{
"i": 658,
"t": "Psikogen (qeyri-epileptik) tutmalar (PNES) – dissosiativ neyroloji simptom pozuntusu ("
},
{
"i": 659,
"t": "6B60.4"
},
{
"i": 660,
"t": "Video-EEG"
},
{
"i": 661,
"t": "– qızıl standart diferensial;"
},
{
"i": 662,
"t": "PNES – epilepsiya ilə tez-tez komorbid, 10-30%;"
},
{
"i": 663,
"t": "Müalicə: KDT-PNES, antikonvulsantlardan yavaş kəsilmə."
},
{
"i": 664,
"t": "Antiepileptiklərin psixiatrik yan təsirləri:"
},
{
"i": 665,
"t": "Levetirasetam:"
},
{
"i": 666,
