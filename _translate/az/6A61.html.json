},
{
"i": 645,
"t": "Mənbələr"
},
{
"i": 646,
"t": "1. Tərif və nozologiya"
},
{
"i": 647,
"t": "Bipolyar pozuntu Tip II (XBT-11:"
},
{
"i": 648,
"t": "6A61"
},
{
"i": 649,
"t": "; DSM-5-TR: 296.89) — ən azı bir"
},
{
"i": 650,
"t": "hipomanik"
},
{
"i": 651,
"t": "epizod və ən azı bir"
},
{
"i": 652,
"t": "major depresiv"
},
{
"i": 653,
"t": "epizodla xarakterizə olunan, lakin"
},
{
"i": 654,
"t": "heç vaxt tam manik epizodu olmayan"
},
{
"i": 655,
"t": "bipolyar pozuntu formasıdır. Tip I-dən \"yüngül\" forma deyil — pasiyentlər ömürlük daha çox depresiv vaxt keçirir; funksional pozulma və intihar riski Tip I ilə müqayisəli."
},
{
"i": 656,
"t": "2. Tarixçə"
},
{
"i": 657,
"t": "Dunner D.L., Gershon E.S., Goodwin F.K. (1976)"
},
{
"i": 658,
"t": "— bipolyar pozuntu alt-tiplərini ayırmaq təklifi."
},
{
"i": 659,
"t": "DSM-IV (1994)"
},
{
"i": 660,
"t": "— Bipolyar Tip II ayrı diaqnostik kateqoriya kimi rəsmiyyət."
},
{
"i": 661,
"t": "DSM-5 (2013) və XBT-11 (2019)"
},
{
"i": 662,
"t": "— Tip II saxlanılmış, \"yüngül forma\" kimi yanlış konsepsiyaya qarşı vurğu."
},
{
"i": 663,
"t": "3. Epidemiologiya"
},
{
"i": 664,
"t": "Ömürlük yayılma: ~0,4–1,1% (Merikangas K.R. Arch Gen Psychiatry 2011 WMH)."
},
{
"i": 665,
"t": "Cins: qadınlarda nisbətən yüksək (~1,5:1 — Tip I-dən fərqli)."
},
{
"i": 666,
"t": "Başlanğıc: orta 20–25 yaş, çoxsaylı depresiv epizodlar adətən hipomanik epizoddan əvvəl baş verir."
},
{
"i": 667,
"t": "Suisid riski Tip I ilə müqayisəli (ömürlük ~5–7%); daha çox depresiv vaxt səbəbi ilə."
},
{
"i": 668,
"t": "Komorbidlik: narahatlıq 60%+, maddə istifadəsi 30–40%, sərhəd şəxsiyyət pozuntusu."
},
{
"i": 669,
"t": "4. Etiologiya və patogenez"
},
{
"i": 670,
"t": "Genetik əsas Tip I ilə üst-üstə düşür — irsilik 60–80%; GWAS lokusları paralel."
},
{
"i": 671,
"t": "Klinik fenotipin bipolyar Tip I-dən müstəqil genetik vahidliyi mübahisəlidir — bəzi tədqiqatlarda hər iki tip eyni spektrum kimi qiymətləndirilir."
},
{
"i": 672,
"t": "Sirkadian ritm pozulması və ailə tarixçəsi."
},
{
"i": 673,
"t": "5. Klinik mənzərə"
},
{
"i": 674,
"t": "5.1 Hipomanik epizod"
},
{
"i": 675,
"t": "Anormal yüksək və ya irritabel əhval + artmış enerji ≥ 4 gün (Tip I-də ≥ 7)."
},
{
"i": 676,
"t": "Manik epizodla eyni alt-simptomlar (azalmış yuxu, distraktibilte, məqsədli aktivlik artımı, və s.); ≥ 3 simptom (irritabəl əhvalda ≥ 4)."
},
{
"i": 677,
"t": "Funksional pozulma əhəmiyyətli olmamalıdır"
},
{
"i": 678,
"t": "(yəni hipomanik tərifi); psixotik xüsusiyyət olmamalıdır; xəstəxana yatımı tələb olunmamalıdır. Bu meyarlar müşahidə olunarsa — diaqnoz Tip I-ə dəyişir."
},
{
"i": 679,
"t": "5.2 Major depresiv epizod"
},
{
"i": 680,
"t": "2 həftə ≥ 5 simptom (aşağı əhval və/və ya anhedoniya daxil)."
},
{
"i": 681,
"t": "Bipolyar Tip II depresiv epizodları çox vaxt atipik xüsusiyyətlərlə — hipersomniya, hiperfagiya, leaden paralysis, rejection sensitivity."
},
{
"i": 682,
"t": "Pasiyent ömürlük 70%-dən çox vaxtı depresiv keçirir (Judd L.L. et al. Arch Gen Psychiatry 2003 izləmə)."
},
{
"i": 683,
"t": "6. Diaqnoz"
},
{
"i": 684,
"t": "6.1 Vahid diaqnostik meyarlar"
},
{
"i": 685,
"t": "A."
},
{
"i": 686,
"t": "Ən azı bir hipomanik epizod."
},
{
"i": 687,
"t": "B."
},
{
"i": 688,
"t": "Ən azı bir major depresiv epizod."
},
{
"i": 689,
"t": "C."
},
{
"i": 690,
"t": "Heç vaxt manik epizod olmamışdır."
},
{
"i": 691,
"t": "D."
},
{
"i": 692,
"t": "Hipomanik və depresiv epizodlar şizoaffektiv, şizofreniya və ya digər psixotik pozuntu ilə daha yaxşı izah olunmur."
},
{
"i": 693,
"t": "E."
},
{
"i": 694,
"t": "Simptomlar əhəmiyyətli distres və ya funksional pozulma yaradır (əsasən depresiv epizoddan)."
},
{
"i": 695,
"t": "6.2 Mənbə-spesifik dəqiqləşdirmələr"
},
{
"i": 696,
"t": "DSM-5-TR / XBT-11:"
},
{
"i": 697,
"t": "hipomanik epizodda funksional pozulma əhəmiyyətli olmamalıdır; antidepresant induksiyalı hipomanik epizod bipolyar Tip II diaqnozuna yol açır (xüsusilə davam edən və ya təkrarlanan hallarda)."
},
{
"i": 698,
"t": "Underdiagnosis problemi:"
},
{
"i": 699,
"t": "Hirschfeld R.M. icmalları — depressiv epizodla müraciət edən pasiyentlərin ~25–50%-i əslində bipolyar Tip II-dir, lakin hipomanik epizodlar ailə tərəfindən \"yaxşı dövrlər\" kimi qəbul edilir."
},
{
"i": 700,
"t": "6.3 Diaqnostika alqoritmi"
},
{
"i": 701,
"t": "Hər depressiv pasiyentdə hipomanik epizodlar üçün strukturlaşdırılmış sorğu (SCID-5 mood module, MDQ, HCL-32)."
},
{
"i": 702,
"t": "Ailə üzvlərindən informasiya — hipomanik dövrlərin müşahidəsi vacibdir."
},
{
"i": 703,
"t": "Klinik müsahibə + YMRS, HAM-D / MADRS."
},
{
"i": 704,
"t": "Laborator: tireoid, qaraciyər, böyrək, toksikoloji, hamiləlik testi."
},
{
"i": 705,
"t": "Komorbidlik və intihar riski qiymətləndirməsi."
},
{
"i": 706,
"t": "6.4 Differensial diaqnostika"
},
{
"i": 707,
"t": "Vəziyyət"
},
{
"i": 708,
"t": "Fərqləndirici əlamətlər"
},
{
"i": 709,
"t": "Bipolyar Tip I (6A60)"
},
{
"i": 710,
"t": "≥ 1 manik epizod (funksional pozulma və ya hospitalizasiya tələbi)."
},
{
"i": 711,
"t": "Major depresiv pozuntu (6A70/6A71)"
},
{
"i": 712,
"t": "Hipomanik epizod yox."
},
{
"i": 713,
"t": "Sikletimik (6A62)"
},
{
"i": 714,
"t": "Tam major depresiv və ya hipomanik epizodlar yox."
},
{
"i": 715,
"t": "BPD (6D10.x)"
},
{
"i": 716,
"t": "Emosional dəyişkənlik saatlar; identifikasiya pozuntusu; xronik suicid fikirləri."
},
{
"i": 717,
"t": "ADHD"
},
{
"i": 718,
"t": "Davamlı; episodik deyil."
},
{
"i": 719,
"t": "Hipertireoid"
},
{
"i": 720,
"t": "TSH ölçməsi."
},
{
"i": 721,
"t": "7. Müayinə və qiymətləndirmə"
},
{
"i": 722,
"t": "SCID-5 mood module — qızıl standart."
},
{
"i": 723,
"t": "MDQ (Mood Disorder Questionnaire) və HCL-32 (Hypomania Checklist) — skrining."
},
{
"i": 724,
"t": "YMRS, HAM-D / MADRS, C-SSRS."
},
{
"i": 725,
"t": "Litium öncəsi: kreatinin, TSH, kalsium, EKG."
},
{
"i": 726,
"t": "8. Müalicə"
},
{
"i": 727,
"t": "8.1 Ümumi prinsiplər (NICE CG185 · CANMAT/ISBD 2018)"
},
{
"i": 728,
"t": "Bipolyar Tip II depresiv epizod (ən sıx təqdimat):"
},
{
"i": 729,
"t": "Birinci sıra — kvetiapin (FDA təsdiqi), lurasidon və ya kvetiapin + litium kombinasiyası."
},
{
"i": 730,
"t": "Lamotrigin — saxlamada və depresiv profilaktikada birinci sıra (Tip II-də xüsusilə effektiv)."
},
{
"i": 731,
"t": "Litium — saxlama və intihar azaltma."
},
{
"i": 732,
"t": "Hipomanik epizod:"
},
{
"i": 733,
"t": "antidepresanı kəs; əhval stabilizatoru (litium, valproat) və ya atipik antipsixotik."
},
{
"i": 734,
"t": "Antidepresant istifadəsi:"
},
{
"i": 735,
"t": "bipolyar Tip II-də nisbətən təhlükəsiz hesab edilirdi, lakin son tövsiyələr (CANMAT 2018) yalnız əhval stabilizatoru ilə birlikdə (manik dönüş və sürətli sikllaşma riskini azaltmaq üçün)."
},
{
"i": 736,
"t": "Saxlama (maintenance):"
},
{
"i": 737,
"t": "lamotrigin (depresiv komponent dominant olduqda) və ya kvetiapin; litium suicid azaltma effekti üçün."
},
{
"i": 738,
"t": "Psixososial:"
},
{
"i": 739,
"t": "KDT, IPSRT, ailə-fokuslu terapiya, psixoeducation."
},
{
"i": 740,
"t": "Refrakter:"
},
{
"i": 741,
"t": "klozapin, EKT."
},
{
"i": 742,
"t": "Hamiləlik:"
},
{
"i": 743,
"t": "valproat qəti qadağa; lamotrigin və kvetiapin nisbi təhlükəsiz."
},
{
"i": 744,
"t": "8.2 Mənbə-spesifik dəqiqləşdirmələr"
},
{
"i": 745,
"t": "CANMAT/ISBD 2018:"
},
{
"i": 746,
"t": "Tip II depresiv epizod birinci sıra — kvetiapin; lamotrigin saxlamada."
},
{
"i": 747,
"t": "NICE CG185:"
},
{
"i": 748,
"t": "Tip I və II eyni əsas yanaşma, lakin Tip II-də lamotriginin xüsusi rolu vurğulanır."
},
{
"i": 749,
"t": "Calabrese J.R. RKİ-ləri"
},
{
"i": 750,
"t": "— lamotriginin bipolyar Tip II saxlamada effekti."
},
{
"i": 751,
"t": "Müalicə metodikaları"
},
{
"i": 752,
"t": "Lamotrigin"
},
{
"i": 753,
"t": "— Bipolyar Tip II saxlamada və depresiv epizod profilaktikasında effektiv; titrasiyası ləng (Stevens-Johnson sindromu riski) — başlanğıc 25 mq, 2 həftə artırma; hədəf 200 mq/gün. Calabrese J.R. et al. J Clin Psychiatry 2003."
},
{
"i": 754,
"t": "Kvetiapin"
},
{
"i": 755,
"t": "— FDA bipolyar depresiv epizod üçün təsdiqi; 300–600 mq/gün; metabolik yan təsirlər monitorinqi."
},
{
"i": 756,
"t": "İnterpersonal və Sosial Ritm Terapiyası (IPSRT) — Frank (Frank E.); və bipolyar üçün KDT"
},
{
"i": 757,
"t": "— Sirkadian ritm, kompliyans, residiv profilaktikası."
},
{
"i": 758,
"t": "Hipomaniya Yoxlama Siyahısı (HCL-32 — Hypomania Checklist) — Anqst (Angst J.)"
},
{
"i": 759,
"t": "— 32 maddəlik özünüqiymətləndirmə hipomanik epizod skrininqi."
},
{
"i": 760,
"t": "Əhval Pozuntusu Sorğusu (MDQ — Mood Disorder Questionnaire)"
},
{
"i": 761,
"t": "— 13 sual; bipolyar skrining."
},
{
"i": 762,
"t": "9. Proqnoz"
},
{
"i": 763,
"t": "Episodik gediş; saxlama farmakoterapiyası ilə residiv əhəmiyyətli azalır."
},
{
"i": 764,
"t": "Tip II Tip I-dən \"yüngül\" deyil — yüksək funksional pozulma və depressiv yük."
},
{
"i": 765,
"t": "Suisid riski yüksək."
},
{
"i": 766,
"t": "Kvetiapin və lamotrigin saxlamada əsas."
},
{
"i": 767,
"t": "İzləmə — depresiv simptomlar, hipomanik tetikleyicilər, metabolik göstəricilər."
},
{
"i": 768,
"t": "10. Mif və yanlış inanclar"
},
{
"i": 769,
"t": "Mif 1: \"Tip II bipolyar \"yüngül forma\"dır, müalicəyə az ehtiyac var\""
},
{
"i": 770,
"t": "Sübut:"
},
{
"i": 771,
"t": "Judd L.L. Arch Gen Psychiatry 2003 — Tip II pasiyent ömürlük 70%-dən çox vaxtı depresiv keçirir; funksional pozulma və intihar riski Tip I ilə müqayisəli."
},
{
"i": 772,
"t": "Mif 2: \"Hipomanik epizod \"yaxşı dövrdür\", müalicəyə ehtiyac yoxdur\""
},
{
"i": 773,
"t": "Sübut:"
},
{
"i": 774,
"t": "hipomanik epizod riskli davranış, münasibət pozulması, məhsuldarlıq sonradan azalması və depresiv epizod tetikleyicisi ola bilər; ayrı-ayrı epizodlar saxlama farmakoterapiyasının lazımlılığını göstərir."
},
{
"i": 775,
"t": "Mif 3: \"Tip II pasiyentdə antidepresant tək başına istifadə edilə bilər\""
},
{
"i": 776,
"t": "Sübut:"
},
{
"i": 777,
"t": "CANMAT 2018 — antidepresant yalnız əhval stabilizatoru ilə; manik dönüş və sürətli sikllaşma riski."
},
{
"i": 778,
"t": "Mif 4: \"Bipolyar Tip II yalnız sərhəd şəxsiyyət pozuntusunun bir formasıdır\""
},
{
"i": 779,
"t": "Sübut:"
},
{
"i": 780,
"t": "əhəmiyyətli üst-üstə düşmə və komorbidlik var, lakin bunlar ayrı pozuntulardır; bipolyar Tip II episodik, BPD davamlı model."
},
{
"i": 781,
"t": "Mif 5: \"Lamotrigin manik epizodu sağaldır\""
},
{
"i": 782,
"t": "Sübut:"
},
{
"i": 783,
"t": "lamotrigin depresiv komponentdə və saxlamada effektivdir; manik epizod üçün effektsiz — antipsixotik və ya valproat tələb olunur."
},
{
"i": 784,
"t": "Mif 6: \"St John's Wort təbii antidepresant olduğu üçün bipolyarda təhlükəsizdir\""
},
{
"i": 785,
"t": "Sübut:"
},
{
"i": 786,
"t": "St John's Wort manik dönüşə səbəb ola bilər və əhval stabilizatorlarının səviyyəsini azaldır (CYP induksiyası); bipolyarda əkstərkib."
},
{
"i": 787,
"t": "Mif 7: \"Tip II-də EKT lazım deyil\""
},
{
"i": 788,
"t": "Sübut:"
},
{
"i": 789,
"t": "refrakter depresiv epizod və ya yüksək suicid riskində EKT göstərişdir; Tip II pasiyentdə də effektiv."
},
