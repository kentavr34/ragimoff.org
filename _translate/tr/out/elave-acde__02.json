[{"i": 586, "t": "Ayırıcı tanı, tanı ve hastalığın derecesinin değerlendirilmesi;"}, {"i": 587, "t": "Sonuç."}, {"i": 588, "t": "Tipik psikolojik testler (EPM):"}, {"i": 589, "t": "MMPI-2"}, {"i": 590, "t": "(Minnesota Multiphasic Personality Inventory-2) – kişilik profili;"}, {"i": 591, "t": "Raven progresif matrisleri"}, {"i": 592, "t": "– zeka;"}, {"i": 593, "t": "Luriya testleri"}, {"i": 594, "t": "– hafıza, dikkat"}, {"i": 595, "t": "Wechsler IQ ölçeği (WAIS)"}, {"i": 596, "t": "Rorschach testi"}, {"i": 597, "t": "– projektif (tartışmalı modern güvenilirliği);"}, {"i": 598, "t": "Beck, Hamilton ölçekleri"}, {"i": 599, "t": "– duygudurum"}, {"i": 600, "t": "D.3. Psikiyatrik bozukluklar ve askerlik hizmetine uygunluk değerlendirmesi"}, {"i": 601, "t": "11. Gruba göre sınıflandırma (adaptasyon – yerel normatif düzenlemeler esas alınarak):"}, {"i": 602, "t": "A grubu – askerliğe tam uygun"}, {"i": 603, "t": "Psikiyatrik öykü yok veya hafif geçici sorunlar."}, {"i": 604, "t": "B grubu – sınırlı yararlı"}, {"i": 605, "t": "Hafif kişilik özellikleri (bozukluk eşiğine ulaşmayan);"}, {"i": 606, "t": "36. Geçici uyum bozuklukları;"}, {"i": 607, "t": "Hafif uyku bozuklukları;"}, {"i": 608, "t": "Remisyon durumunda nevrotik bozukluklar."}, {"i": 609, "t": "V grubu – hizmet sırasında sınırlı"}, {"i": 610, "t": "Kısmi remisyonda orta psikiyatrik bozukluklar;"}, {"i": 611, "t": "Belirli kişilik bozuklukları;"}, {"i": 612, "t": "Geçmiş TSSB, kompanse edilmiş;"}, {"i": 613, "t": "Orta derecede nörokognitif disfonksiyon."}, {"i": 614, "t": "Q grubu – hizmete elverişsiz"}, {"i": 615, "t": "Şizofreni spektrumu;"}, {"i": 616, "t": "Bipolar bozukluk;"}, {"i": 617, "t": "Ağır depressiya"}, {"i": 618, "t": "17. Aktif PTSD/kompleks PTSD (Karabağ savaşı gazileri – ayrı tedavi programı);"}, {"i": 619, "t": "Madde kullanımı bozuklukları;"}, {"i": 620, "t": "Ağır kişilik bozuklukları;"}, {"i": 621, "t": "Mental gerilik;"}, {"i": 622, "t": "1. Otizm spektrumunun ağır formları;"}, {"i": 623, "t": "18. Aktif intihar riski olan bozukluklar;"}, {"i": 624, "t": "Parafilik bozukluklar (şiddetli, aktif)."}, {"i": 625, "t": "D.4. Doğum sonrası travma ve gazi değerlendirmesi"}, {"i": 626, "t": "Karabakh savaşı gazilerinde:"}, {"i": 627, "t": "Karmaşık TSSB yüksek yaygınlık"}, {"i": 628, "t": "– travma odaklı müdahale"}, {"i": 629, "t": "28. Alkol ve madde kullanımı"}, {"i": 630, "t": "komorbid;"}, {"i": 631, "t": "Depresyon, intihar riski;"}, {"i": 632, "t": "Aile işlev bozukluğu;"}, {"i": 633, "t": "Moral zorlanma"}, {"i": 634, "t": "– savaş zamanı etik çatışma (öldürme, tanık olma);"}, {"i": 635, "t": "Yanma ve tekrar-travmatizasyon"}, {"i": 636, "t": "risk faktörleri."}, {"i": 637, "t": "Spesifik rehabilitasyon programları:"}, {"i": 638, "t": "Kanıtlanmış travma terapisi (PE, CPT, EMDR);"}, {"i": 639, "t": "10. Grup terapisi gazilere;"}, {"i": 640, "t": "12. Aile terapisi;"}, {"i": 641, "t": "İlaç (SSRI/SNRI);"}, {"i": 642, "t": "Sosyal rehabilitasyon (iş, eğitim)."}, {"i": 643, "t": "EK E"}, {"i": 644, "t": "İLGİLİ NÖROLOJİK DURUMLAR"}, {"i": 645, "t": "Psikiyatri ve nörolojinin kesiştiği alanlarda klinik pratik için önemli olan nörolojik hastalıkların kısa tanımı."}, {"i": 646, "t": "E.1. Epilepsi (G40) ve psikiyatrik belirtiler"}, {"i": 647, "t": "Epileptik sendromlar ve psikiyatri:"}, {"i": 648, "t": "- İnter-iktal kişilik değişiklikleri (Geschwind sendromu – hiperreligiosite, hipergrafi, \"viskozite\");"}, {"i": 649, "t": "- İnter-iktal psikoz – uzun süreli TLE;"}, {"i": 650, "t": "- Post-iktal psikoz – nöbet sonrası 24-72 saat içinde psikotik epizodlar;"}, {"i": 651, "t": "- İktal anksiyete ve dissosiyatif deneyimler;"}, {"i": 652, "t": "Temporal lob epilepsisi (TLE)"}, {"i": 653, "t": "– en çok psikiyatrik komorbidite"}, {"i": 654, "t": "Absans epilepsisi"}, {"i": 655, "t": "– dikkat sorunu, DEHB ile diferansiyel;"}, {"i": 656, "t": "Juvenile miyoklonik epilepsiya"}, {"i": 657, "t": "– yüksek komorbid anksiyete, dürtüsellik"}, {"i": 658, "t": "Psikogen (qeyri-epileptik) tutmalar (PNES) – dissosiativ neyroloji simptom pozuntusu ("}, {"i": 659, "t": "6B60.4"}, {"i": 660, "t": "Video-EEG"}, {"i": 661, "t": "– altın standart diferansiyel"}, {"i": 662, "t": "PNES – epilepsi ile sık komorbid, %10-30;"}, {"i": 663, "t": "Tedavi: KDT-PNES, antikonvülzanlardan yavaş kesilme."}, {"i": 664, "t": "Antiepileptiklerin psikiyatrik yan etkileri:"}, {"i": 665, "t": "Levetirasetam:"}, {"i": 666, "t": "agresyon, irritabilite, depresyon;"}, {"i": 667, "t": "Fenobarbital, primidon:"}, {"i": 668, "t": "depresyon, kognitif yavaşlama;"}, {"i": 669, "t": "Topiramat:"}, {"i": 670, "t": "kognitif disfonksiyon, depresyon;"}, {"i": 671, "t": "Lamotrigin:"}, {"i": 672, "t": "Yine duygudurum stabilize eder."}, {"i": 673, "t": "E.2. Baş ağrısı ve psikiyatrik komorbidite"}, {"i": 674, "t": "Migren"}, {"i": 675, "t": "– depresyon riski 2-4× yüksek; anksiyete bozuklukları;"}, {"i": 676, "t": "28. Küme baş ağrısı"}, {"i": 677, "t": "– depresyon, intihar riski;"}, {"i": 678, "t": "Kronik günlük baş ağrısı"}, {"i": 679, "t": "– analjezik aşırı kullanımı (MOH) – duygudurum bozukluğu komorbid sık;"}, {"i": 680, "t": "Tekrarlayan gerilim baş ağrısı"}, {"i": 681, "t": "– yoğun stres, anksiyete ile ilişkili"}, {"i": 682, "t": "Yönetim:"}, {"i": 683, "t": "SSRI/SNRI birçok baş ağrısı tipini iyileştirir;"}, {"i": 684, "t": "TCA (amitriptilin) profilaktik migren için tarihsel standart;"}, {"i": 685, "t": "Topiramat, valproat profilaktik;"}, {"i": 686, "t": "KDT kronik baş ağrısında etkilidir;"}, {"i": 687, "t": "Opioidlerden ve aşırı analjezik kullanımından kaçınmak."}, {"i": 688, "t": "E.3. Beyin-damar hastalıkları (inme)"}, {"i": 689, "t": "Post-stroke depressiya:"}, {"i": 690, "t": "%30-40 ilk yıl;"}, {"i": 691, "t": "Post-stroke mania:"}, {"i": 692, "t": "nadir, sağ frontal veya talamik lezyonlarda;"}, {"i": 693, "t": "Pseudobulbar affekt"}, {"i": 694, "t": "(patolojik gülme/ağlama):"}, {"i": 695, "t": "dekstrometorfan-kinidin kombinasyonu"}, {"i": 696, "t": "onaylı tedavidir;"}, {"i": 697, "t": "Vaskulyar koqnitiv pozuntu/demensiya:"}, {"i": 698, "t": "6D81"}, {"i": 699, "t": "altında sınıflandırma;"}, {"i": 700, "t": "Reabilitasiya:"}, {"i": 701, "t": "multidisipliner, psikiyatrik destek merkezi rolünde."}, {"i": 702, "t": "E.4. Parkinson hastalığı"}, {"i": 703, "t": "Depressiya:"}, {"i": 704, "t": "Anksiyete:"}, {"i": 705, "t": "Dopamin agonisti kaynaklı dürtü kontrol bozukluğu:"}, {"i": 706, "t": "Parkinsonda psixoz:"}, {"i": 707, "t": "temel olarak görsel halüsinasyonlar; levodopa-induksiyon;"}, {"i": 708, "t": "Parkinsonda demensiya:"}, {"i": 709, "t": "6D85"}, {"i": 710, "t": "REM uyku davranış bozukluğu:"}, {"i": 711, "t": "Parkinson için erken belirteç."}, {"i": 712, "t": "Tedavi özellikleri:"}, {"i": 713, "t": "Antipsikotiklerin Parkinson'da kullanımı"}, {"i": 714, "t": "kvetiapin, klozapin"}, {"i": 715, "t": "(D2 minimal blokaj);"}, {"i": 716, "t": "Haloperidol, risperidon"}, {"i": 717, "t": "– motor semptomları kötüleştirir;"}, {"i": 718, "t": "SSRİ"}, {"i": 719, "t": "depresyon için;"}, {"i": 720, "t": "Pimavanserin"}, {"i": 721, "t": "– ABD'de Parkinson psikozu için onaylı."}, {"i": 722, "t": "E.5. Multipl skleroz (MS)"}, {"i": 723, "t": "Depressiya:"}, {"i": 724, "t": "Anksiyete:"}, {"i": 725, "t": "Bipolar benzeri semptomlar:"}, {"i": 726, "t": "Pseudobulbar affekt;"}, {"i": 727, "t": "Koqnitiv disfunksiya"}, {"i": 728, "t": "– hastalığın çoğunda"}, {"i": 729, "t": "Uyuşukluk ve yorgunluk"}, {"i": 730, "t": "– depresyon ile sıkı, diferansiyel zor."}, {"i": 731, "t": "İnterferon-beta tedavisi"}, {"i": 732, "t": "depresyonu kötüleştirir – aktif izlem."}, {"i": 733, "t": "E.6. Travmatik beyin hasarı (TBH)"}, {"i": 734, "t": "Post-konkussion sindromu:"}, {"i": 735, "t": "39. головная боль, головокружение, проблемы с памятью, изменения настроения;"}, {"i": 736, "t": "Kronik travma ensefalopatisi (CTE):"}, {"i": 737, "t": "tekrarlayan yaralanmalar, spor (boks, Amerikan futbolu);"}, {"i": 738, "t": "PTSD + TBZ"}, {"i": 739, "t": "– çok sık komorbid"}, {"i": 740, "t": "Kişilik değişikliği"}, {"i": 741, "t": "6E68"}, {"i": 742, "t": ") – frontal lezyonlarda."}, {"i": 743, "t": "E.7. Demans (detaylı Bölüm 17'de)"}, {"i": 744, "t": "6D80"}, {"i": 745, "t": "Alzheimer;"}, {"i": 746, "t": "6D81"}, {"i": 747, "t": "Vasküler;"}, {"i": 748, "t": "6D82"}, {"i": 749, "t": "Lewy cisimciği;"}, {"i": 750, "t": "6D83"}, {"i": 751, "t": "Frontotemporal;"}, {"i": 752, "t": "6D84"}, {"i": 753, "t": "Madde-ilişkili;"}, {"i": 754, "t": "6D85"}, {"i": 755, "t": "Parkinson ile;"}, {"i": 756, "t": "6D86"}, {"i": 757, "t": "Demanslarda davranış/psikolojik bozukluklar (BPSD)."}, {"i": 758, "t": "E.8. Nöbetler, hareket bozuklukları ve psikiyatri"}, {"i": 759, "t": "Tourette sindromu (8A05.00)"}, {"i": 760, "t": "– ICD-11'de nörolojik hastalıklar bölümünde, ancak DEHB, OKB ile komorbid çok yüksek;"}, {"i": 761, "t": "Wilson hastalığı"}, {"i": 762, "t": "– bakır metabolizmasının genetik bozukluğu; psikiyatrik prezentasyon (depresyon, psikoz) sık; testi – seruloplazmin, 24 saatlik idrar bakırı;"}, {"i": 763, "t": "19. Huntington hastalığı"}, {"i": 764, "t": "– duygudurum bozuklukları, OKB, psikoz, motor kore"}, {"i": 765, "t": "GENEL KAYNAKLAR VE LİTERATÜR"}, {"i": 766, "t": "Temel ICD-11 ve DSM-5 kaynakları"}, {"i": 767, "t": "WHO."}, {"i": 768, "t": "Klinik Tanımlamalar ve Tanı Kriterleri for WHO, 2019, yürürlük 2022 — ICD-11 Mental, Behavioural and Neurodevelopmental Disorders (KTTD)."}, {"i": 769, "t": "Cenevre: Dünya Sağlık Örgütü; 2024. ISBN: 9789240077263."}, {"i": 770, "t": "APA."}, {"i": 771, "t": "Diagnostic and Statistical Manual of Mental Disorders, 5th Edition, Text Revision (DSM-5-TR)."}, {"i": 772, "t": "APA Publishing; 2022."}, {"i": 773, "t": "First MB, Reed GM, Hyman SE, Saxena S."}, {"i": 774, "t": "WHO'nun geliştirdiği, 2019, yürürlüğe giriş 2022 — ICD-11 Ruhsal ve Davranışsal Bozukluklar için Klinik Tanımlamalar ve Tanı Kılavuzları"}, {"i": 775, "t": "World Psychiatry"}, {