[{"i": 361, "t": "Her çeyrek"}, {"i": 362, "t": "&gt;"}, {"i": 363, "t": "Kritik:"}, {"i": 364, "t": "valproat"}, {"i": 365, "t": "doğurganlık çağındaki kadınlarda"}, {"i": 366, "t": "nöral tüp defekti ve kognitif hasar nedeniyle"}, {"i": 367, "t": "yalnızca etkili kontrasepsiyon ile"}, {"i": 368, "t": ", diğer seçenekler önce değerlendirildikten sonra."}, {"i": 369, "t": "Karbamazepin:"}, {"i": 370, "t": "CBC, karaciğer – başlangıç, 1 ay, üç aylık;"}, {"i": 371, "t": "HLA-B*1502 testi"}, {"i": 372, "t": "0. Asya kökenli hastalarda (Stevens-Johnson riski);"}, {"i": 373, "t": "9. Oto-indüksiyon nedeniyle seviye düşüşü ilk 4 haftada – seviye kontrol et."}, {"i": 374, "t": "Lamotrigin:"}, {"i": 375, "t": "13. Yavaş titrasyon"}, {"i": 376, "t": "– Stevens-Johnson sendromu riski;"}, {"i": 377, "t": "Başlangıç 25 mg haftada"}, {"i": 378, "t": ", 4–8 hafta içinde hedef doza;"}, {"i": 379, "t": "Valproat ile birlikte:"}, {"i": 380, "t": "başlangıç 12,5 mg"}, {"i": 381, "t": "– valproat lamotrigin metabolizmasını yavaşlatır"}, {"i": 382, "t": "Deri reaksiyonu olursa –"}, {"i": 383, "t": "hemen durdur."}, {"i": 384, "t": "A.4. SSRI ve SNRI izlemi"}, {"i": 385, "t": "Hiponatremiya riski"}, {"i": 386, "t": "– özellikle yaşlılarda, diüretik kullananlarda"}, {"i": 387, "t": "Bazal Na"}, {"i": 388, "t": ", 1 ay sonra, sonra semptom ile;"}, {"i": 389, "t": "Suisidalitede artış"}, {"i": 390, "t": "özellikle 25 yaş altı başlangıçta – ilk 1-2 ay yakın izlem;"}, {"i": 391, "t": "QTc uzanma"}, {"i": 392, "t": "– essitalopram, sitalopram (yüksek dozlarda);"}, {"i": 393, "t": "Serotonin sindromu"}, {"i": 394, "t": "(MAOİ veya triptan vb. kombinasyonda) – belirtilerin öğretilmesi."}, {"i": 395, "t": "A.5. Benzodiazepin kullanımı"}, {"i": 396, "t": "Maksimum süre: 2–4 hafta"}, {"i": 397, "t": "Uzun süreli kullanımda bağımlılık kaçınılmazdır;"}, {"i": 398, "t": "Azaltma sxemi (tapering):"}, {"i": 399, "t": "%25 her 2 haftada, bazen daha yavaş;"}, {"i": 400, "t": "Geri tepki semptomları."}, {"i": 401, "t": "(rebound anxiety, uykusuzluk, tremor) normal ve geçicidir."}, {"i": 402, "t": "A.6. Psixoterapiya monitorinqi"}, {"i": 403, "t": "Kalite göstergeleri:"}, {"i": 404, "t": "Seansın süresi, sıklığı;"}, {"i": 405, "t": "Hasta semptom ölçekleri (PHQ-9, GAD-7 vb.)"}, {"i": 406, "t": "27. her 4–6 haftada"}, {"i": 407, "t": "İşlevsel göstergeler;"}, {"i": 408, "t": "Terapötik ilişki değerlendirmesi (Working Alliance Inventory);"}, {"i": 409, "t": "Dış hedeflere ulaşma;"}, {"i": 410, "t": "Relaps belirtileri."}, {"i": 411, "t": "10. Süpervizyon ve kollegial konsültasyon – kompleks hastalarda ve isteyen klinisyen için."}, {"i": 412, "t": "EK C"}, {"i": 413, "t": "PSİKİYATRİK ACİL DURUMLAR"}, {"i": 414, "t": "Bu ek hayatı tehdit eden veya acil klinik değerlendirme gerektiren psikiyatrik durumlara pratik bir yaklaşım sunmaktadır."}, {"i": 415, "t": "C.1. Aktiv intihar riski"}, {"i": 416, "t": "Birincil değerlendirme:"}, {"i": 417, "t": "İntihar düşüncesi var mı? Plan? Araç?"}, {"i": 418, "t": "27. Yakınlık, somutluk:"}, {"i": 419, "t": "\"Bugün akşam heyecanım tabançayla...\" vs genel \"Bazen ölmek istiyorum\";"}, {"i": 420, "t": "Önceki girişimler"}, {"i": 421, "t": "– en güçlü prediktör"}, {"i": 422, "t": "Madde intoksikasyonu"}, {"i": 423, "t": "– inhibisyon azalır;"}, {"i": 424, "t": "Protektiv faktorlar"}, {"i": 425, "t": "– aile, dini inançlar, gelecek planları."}, {"i": 426, "t": "Yüksek risk belirtileri:"}, {"i": 427, "t": "Belirli plan + araçlara erişilebilirlik;"}, {"i": 428, "t": "22. Yakın durum değişikliği (kayıp, ağır hastalık);"}, {"i": 429, "t": "Yalnızlık + öfke;"}, {"i": 430, "t": "Psikoz veya ağır depresyon;"}, {"i": 431, "t": "Yeni başlangıç veya derin hipomania (enerji geri gelir + düşük mood kalır);"}, {"i": 432, "t": "Yetkin kişi + əlillik + alkogol"}, {"i": 433, "t": "Yönetim:"}, {"i": 434, "t": "Düşük-orta risk:"}, {"i": 435, "t": "Güvenlik planı"}, {"i": 436, "t": "– yazılı"}, {"i": 437, "t": "Araçlara erişilebilirliğin azaltılması (silah uzaklaştırılması, ilaç küçük miktarlarda);"}, {"i": 438, "t": "15. Yakın ayaktan izlem (24-48 saatte yeniden);"}, {"i": 439, "t": "Kriz hattı numarası;"}, {"i": 440, "t": "Aile katılımı (rızayla)."}, {"i": 441, "t": "Yüksek risk:"}, {"i": 442, "t": "hastaneye yatırma"}, {"i": 443, "t": "(gönüllü veya zorunlu);"}, {"i": 444, "t": "20. Yakın gözetim – 1:1 eğer çok yüksek;"}, {"i": 445, "t": "İntihar yöntemlerinin ortadan kaldırılması (kesici alet, ip, pencere);"}, {"i": 446, "t": "Kontrollü ilaç alımı."}, {"i": 447, "t": "Zorunlu hastaneye yatış Azerbaycan çerçevesinde:"}, {"i": 448, "t": "\"Psikiyatrik yardım hakkında\" Azerbaycan Cumhuriyeti kanunu;"}, {"i": 449, "t": "Zorunlu hastaneye yatış için"}, {"i": 450, "t": "iki psikiyatristin kararı"}, {"i": 451, "t": "ve hukuki prosedür;"}, {"i": 452, "t": "72 saat acil gözlem sonrası mahkeme kararı."}, {"i": 453, "t": "C.2. Deliryum tremens ve alkol yoksunluğu"}, {"i": 454, "t": "Simptomlar:"}, {"i": 455, "t": "tremor"}, {"i": 456, "t": "– eller, sonra genel"}, {"i": 457, "t": "Anksiyete, ajitasyon;"}, {"i": 458, "t": "halüsinasyon"}, {"i": 459, "t": "8. – görsel, dokunsal (“böcekler üzerimde”);"}, {"i": 460, "t": "Dezoryantasyon;"}, {"i": 461, "t": "Autonom hiperaktivlik"}, {"i": 462, "t": "– taşikardi, tansiyon, terleme, ateş"}, {"i": 463, "t": "Tutmalar"}, {"i": 464, "t": "Tedavi (YBÜ veya DYBÜ koşullarında):"}, {"i": 465, "t": "benzodiazepin"}, {"i": 466, "t": "diazepam 10-20 mg IV/IM her 15-20 dk"}, {"i": 467, "t": "2. Sedasyon elde edilene kadar; sonra idame rejimi;"}, {"i": 468, "t": "Alternatif: lorazepam (karaciğer disfonksiyonu olanlarda);"}, {"i": 469, "t": "Tiamin 100-300 mq IV"}, {"i": 470, "t": "– Wernicke ensefalopatisinin önlenmesi."}, {"i": 471, "t": "Glukoz vermeden önce"}, {"i": 472, "t": "Sıvı ve elektrolit"}, {"i": 473, "t": "restorasyonu;"}, {"i": 474, "t": "Magnezyum sülfatı, potasyum – çoğu zaman düşük;"}, {"i": 475, "t": "1. Mortalite: tedavi edilmezse 15-20%, uygun tedavi ile <%1."}, {"i": 476, "t": "CIWA-Ar skalası – izlemde."}, {"i": 477, "t": "C.3. Serotonin sindromu"}, {"i": 478, "t": "Neden:"}, {"i": 479, "t": "SSRİ + MAOİ, SSRİ + triptan, SSRİ + tramadol, SSRİ + linezolid, SSRİ + metilen mavisi vb."}, {"i": 480, "t": "Simptomlar:"}, {"i": 481, "t": "Mental değişiklik"}, {"i": 482, "t": "– ajitasyon, konfüzyon;"}, {"i": 483, "t": "Autonom"}, {"i": 484, "t": "– taşikardi, hipertansiyon, hipertermi, terleme"}, {"i": 485, "t": "Neyromuskulyar"}, {"i": 486, "t": "– tremor, hiperrefleksiya,"}, {"i": 487, "t": "klonus"}, {"i": 488, "t": "(alt ekstremite – özel belirti)."}, {"i": 489, "t": "Tedavi:"}, {"i": 490, "t": "Neden olan ilacın hemen kesilmesi;"}, {"i": 491, "t": "Destek – sıvılar, elektrolit, soğutma;"}, {"i": 492, "t": "5. Şiddetli durumlar"}, {"i": 493, "t": "19. Siproheptadin 12 mg başlangıç, 2 mg her saat maksimum 32 mg/gün"}, {"i": 494, "t": "İnvaziv müdahale (entübasyon) ağır hipertermide."}, {"i": 495, "t": "C.4. Antipsixotik Malign Sindrom (NMS)"}, {"i": 496, "t": "Neden:"}, {"i": 497, "t": "antipsikotikler (özellikle yüksek güçlü, haloperidol), akut başlangıç veya doz artışı."}, {"i": 498, "t": "Semptomlar (4 ana):"}, {"i": 499, "t": "Kas sertliği"}, {"i": 500, "t": "(\"kurşun boru\");"}, {"i": 501, "t": "Hipertermiya"}, {"i": 502, "t": "32. (38–42°C);"}, {"i": 503, "t": "15. Otonom değişkenlik"}, {"i": 504, "t": "(yüksek arteriyel tansiyon, taşikardi, terleme);"}, {"i": 505, "t": "Mental durum değişikliği"}, {"i": 506, "t": "(konfüzyon → stupor → koma)."}, {"i": 507, "t": "Laboratoriya:"}, {"i": 508, "t": "CPK akut yüksek"}, {"i": 509, "t": "(>1000), mioglobinüri, lökositoz, ALT/AST yüksek."}, {"i": 510, "t": "Tedavi (YBÜ):"}, {"i": 511, "t": "Antipsikotiğin hemen kesilmesi"}, {"i": 512, "t": "Soğutma;"}, {"i": 513, "t": "Sıvılar (rabdomiyoliz ve akut böbrek yetmezliği riski);"}, {"i": 514, "t": "Dantrolen"}, {"i": 515, "t": "1-2,5 mg/kg IV – kas sertliğini azaltır;"}, {"i": 516, "t": "Bromokriptin"}, {"i": 517, "t": "2,5-5 mg her 8 saat – dopamin agonisti;"}, {"i": 518, "t": "31. EKT yanıtsız durumlarda."}, {"i": 519, "t": "Ölümcüllük:"}, {"i": 520, "t": "5-20% yeterli tedavi ile."}, {"i": 521, "t": "C.5. Akut distoni"}, {"i": 522, "t": "Neden:"}, {"i": 523, "t": "antipsikotik başlangıcı, özellikle güçlü D2 antagonistleri."}, {"i": 524, "t": "Simptomlar:"}, {"i": 525, "t": "16. Akut kas spazmları – boyun (tortikollis), dil, göz (okülojirik kriz), belirli yemek borusu spazmı;"}, {"i": 526, "t": "5. Hayat tehlikesi – laringeal spazm."}, {"i": 527, "t": "Tedavi:"}, {"i": 528, "t": "Difenhidramin"}, {"i": 529, "t": "50 mg IM/IV – 15 dakikada rahatlama;"}, {"i": 530, "t": "Benztropin"}, {"i": 531, "t": "1-2 mg IM/IV;"}, {"i": 532, "t": "Antipsikotiğin dozunun azaltılması veya değiştirilmesi"}, {"i": 533, "t": "Profilaktik antikolinerjik riskli hastalarda."}, {"i": 534, "t": "C.6. Akut mani ve psikomotor ajitasyon"}, {"i": 535, "t": "Yönetim:"}, {"i": 536, "t": "- Oral tercih: haloperidol 2-5 mg + lorazepam 1-2 mg;"}, {"i": 537, "t": "- IM endikasyonu: haloperidol 5 mg + lorazepam 2 mg (50/50 enjektör) veya olanzapin IM 10 mg;"}, {"i": 538, "t": "Güvenli ortam"}, {"i": 539, "t": "– sakin, uyarandan bağımsız"}, {"i": 540, "t": "Verbal de-eskalasiya"}, {"i": 541, "t": "ilk adım;"}, {"i": 542, "t": "İlaç:"}, {"i": 543, "t": "gönülsüz hastaneye yatırma"}, {"i": 544, "t": "Talimatla;"}, {"i": 545, "t": "Fiziksel kısıtlama"}, {"i": 546, "t": "– yalnızca son seçenek, kişisel hayat tehlikesi, kısa süreli"}, {"i": 547, "t": "C.7. Akut psikoz"}, {"i": 548, "t": "Yukarıdakine benzer protokol. Diferansiyel: organik nedenler, madde intoksikasyonu, postpartum psikoz, NMS."}, {"i": 549, "t": "C.8. Katatoniya"}, {"i": 550, "t": "Simptomlar:"}, {"i": 551, "t": "Stupor, mutizm;"}, {"i": 552, "t": "Katalepsi ('mum durumu');"}, {"i": 553, "t": "Negativizm;"}, {"i": 554, "t": "Manerizmler, stereotipiler;"}, {"i": 555, "t": "Eholalia, ekopraksiya."}, {"i": 556, "t": "Birinci basamak tedavi:"}, {"i": 557, "t": "Lorazepam 1-2 mq IV/IM test"}, {"i": 558, "t": "– 1-2 saat içinde anlamlı yanıt → katatoni tanısı ve tedavi;"}, {"i": 559, "t": "Yanıt alınırsa – 4-24 mg/gün doza çıkarmak;"}, {"i": 560, "t": "Yanıtsız –"}, {"i": 561, "t": "ECT"}, {"i": 562, "t": "2. sıra, çok etkili;"}, {"i": 563, "t": "Antipsikotikten kaçınmak"}, {"i": 564, "t": "akut fazda – NMS uygulamasını provoke edebilir."}, {"i": 565, "t": "Nedenini ara:"}, {"i": 566, "t": "organik (ensefalit, epilepsi), duygudurum bozukluğu, şizofreni, otizm, bazı maddeler."}, {"i": 567, "t": "EK D"}, {"i": 568, "t": "ASKERİ-TIBBİ UZMANLIK (AZERBAYCAN'DA)"}, {"i": 569, "t": "Bu ek Azerbaycan Cumhuriyeti'nde askerlik hizmetine uygunluk değerlendirmesi için psikiyatrik açılardan pratik bir rehber sunmaktadır."}, {"i": 570, "t": "D.1. Yasal dayanak"}, {"i": 571, "t": "\"Askerlik çağrısı hakkında\""}, {"i": 572, "t": "Azərbaycan Respublikası Qanunu"}, {"i": 573, "t": "2. Askeri-tıbbi ekspertiz hakkında Yönetmelik;"}, {"i": 574, "t": "Savunma Bakanlığının"}, {"i": 575, "t": "normatif düzenlemeleri;"}, {"i": 576, "t": "Hastalıkların tablosu"}, {"i": 577, "t": "– yarıya bölünür: hafif/ağır dereceler, A-D gruplarına"}, {"i": 578, "t": "D.2. Psikiyatrik değerlendirme yapısı"}, {"i": 579, "t": "Temel ekspertiz:"}, {"i": 580, "t": "Şikayetler ve anamnez (hasta ve yakın akrabaları);"}, {"i": 581, "t": "Önceki tıbbi belgeler;"}, {"i": 582, "t": "15. Klinik görüşme ve mental durum muayenesi;"}, {"i": 583, "t": "Deneysel-Psikolojik İnceleme"}, {"i": 584, "t": "(EPM) – psikolog tarafından;"}, {"i": 585, "t": "Laboratuvar ve enstrümantal incelemeler gerektiğinde;"}]