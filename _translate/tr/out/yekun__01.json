[{"i": 318, "t": "C-SSRS"}, {"i": 319, "t": "– intihar riski."}, {"i": 320, "t": "Azərbaycan dilinə tərcümə edilmiş və validasiya edilmiş alətlərə sərmayə qoyulmalıdır"}, {"i": 321, "t": "İntihar riskinin değerlendirilmesi"}, {"i": 322, "t": "Her psikiyatrik görüşmede aktif sorgulama:"}, {"i": 323, "t": "Son zamanlarda ölüm veya kendi hayatınıza son vermekle ilgili düşünceleriniz oldu mu?"}, {"i": 324, "t": "Belirli plan, araç?"}, {"i": 325, "t": "Önceki girişimler?"}, {"i": 326, "t": "Risk faktörleri:"}, {"i": 327, "t": "Önceki girişimler (en güçlü prediktör);"}, {"i": 328, "t": "25. Ailede intihar öyküsü;"}, {"i": 329, "t": "26. Yakınlık yaklaşık-kesin plan;"}, {"i": 330, "t": "Araçlara erişilebilirlik;"}, {"i": 331, "t": "Madde kullanımı, depresyon, BPD, psikoz;"}, {"i": 332, "t": "12. Akut stresör, kayıp."}, {"i": 333, "t": "Müdahale:"}, {"i": 334, "t": "Güvenlik planı;"}, {"i": 335, "t": "Araçlara erişilebilirliğin azaltılması;"}, {"i": 336, "t": "18. Yakın izlem;"}, {"i": 337, "t": "11. Hospitalizasyon endikasyonu;"}, {"i": 338, "t": "C-SSRS"}, {"i": 339, "t": "Şeklinde ölçekle yapılandırılmış değerlendirme."}, {"i": 340, "t": "Komorbidlik qayda istisna deyil"}, {"i": 341, "t": "Psixi pozuntularda"}, {"i": 342, "t": "komorbidlik norm"}, {"i": 343, "t": "dur:"}, {"i": 344, "t": "Depresyon + anksiyete"}, {"i": 345, "t": "– %60 komorbid;"}, {"i": 346, "t": "PTSD + depressiya"}, {"i": 347, "t": "Kişilik bozukluğu + depresyon/anksiyete/madde"}, {"i": 348, "t": "Autizm + DDHP"}, {"i": 349, "t": "Yeme bozukluğu + depresyon + travma"}, {"i": 350, "t": "– tipik üçlü"}, {"i": 351, "t": "Tedavi planı"}, {"i": 352, "t": "tüm komorbiditeleri kapsamalıdır"}, {"i": 353, "t": "– temel bozukluğun tek başına tedavisi çoğu zaman yeterli değildir"}, {"i": 354, "t": "Yaş ve gelişim evresi mutlaka dikkate alınmalıdır"}, {"i": 355, "t": "Çocukta ruhsal bozukluk"}, {"i": 356, "t": "– ebeveyn ve bağlam önemlidir; ilaçlar az, psikoterapi ve aile odaklı daha fazla"}, {"i": 357, "t": "genç, ergen"}, {"i": 358, "t": "– kimlik gelişimi, erken müdahale kritik;"}, {"i": 359, "t": "Yetkin"}, {"i": 360, "t": "– iş, aile, sosyal işlev;"}, {"i": 361, "t": "Yaşlı"}, {"i": 362, "t": "– komorbid tıbbi hastalıklar, polifarmasi, kognitif bozukluklar;"}, {"i": 363, "t": "demensiya vs depressiya"}, {"i": 364, "t": "özel dikkat."}, {"i": 365, "t": "12. Multidisipliner ekip – etkili klinik çalışmanın temelidir"}, {"i": 366, "t": "Kompleks hallarda:"}, {"i": 367, "t": "Psikiyatrist;"}, {"i": 368, "t": "2. Psikolog / psikoterapist;"}, {"i": 369, "t": "Sosyal çalışmacı;"}, {"i": 370, "t": "Tıbbi hekim (komorbiditeler)"}, {"i": 371, "t": "18. Aile üyeleri (onayla);"}, {"i": 372, "t": "Okul / iş yerindeki kişiler (çocukta)."}, {"i": 373, "t": "Azərbaycanda bu strukturun inkişaf etdirilməsi – strateji prioritet"}, {"i": 374, "t": "Etik ve hukuki çerçeve"}, {"i": 375, "t": "Her klinisyen bilmelidir:"}, {"i": 376, "t": "Gizlilik ve sınırları (başkalarına tehlike, çocuk koruma)"}, {"i": 377, "t": "Bilgilendirilmiş onam;"}, {"i": 378, "t": "Zorunlu hastaneye yatış hukuki çerçevesi;"}, {"i": 379, "t": "Çocuk/yaşlı istismarı bildirimi;"}, {"i": 380, "t": "Adli değerlendirme temelleri;"}, {"i": 381, "t": "Belgelemenin önemi."}, {"i": 382, "t": "Kendi sağlığınıza dikkat"}, {"i": 383, "t": "Psikiyatrik iş –"}, {"i": 384, "t": "duygusal yükü yüksek"}, {"i": 385, "t": "meslektir. Tükenmişlik (burnout), ikincil travma, empatik yorgunluk klinisyen için gerçek risklerdir."}, {"i": 386, "t": "11. Süpervizyon ve kollegial konsültasyon;"}, {"i": 387, "t": "Kişisel psikoterapi;"}, {"i": 388, "t": "Sağlıklı yaşam tarzı;"}, {"i": 389, "t": "Sınırın bilinmesi – tüm hastaları kurtaramazsınız."}, {"i": 390, "t": "Sürekli eğitim ve gelişim."}, {"i": 391, "t": "WHO, 2019, yürürlüğe giriş 2022 — ICD-11 on yıllar boyunca sabit kalacak, ancak:"}, {"i": 392, "t": "Tedavi standartları"}, {"i": 393, "t": "26. her 3–5 yılda"}, {"i": 394, "t": "güncelleniyor;"}, {"i": 395, "t": "Yeni ilaçlar, yeni psikoterapötik protokoller çıkıyor;"}, {"i": 396, "t": "AACE, APA, NICE, WFSBP, ISTSS"}, {"i": 397, "t": "Şeklinde kuruluşların kurallarını düzenli takip;"}, {"i": 398, "t": "Hakemli dergiler: Lancet Psychiatry, JAMA Psychiatry, American Journal of Psychiatry, World Psychiatry."}, {"i": 399, "t": "Kitabın amacı:"}, {"i": 400, "t": "Azərbaycanda psixiatrik qayğının keyfiyyətinə, xəstə və ailələrə, professional inkişafa töhfə vermək. Oxucu bu kitabdan faydalandığı halda, məqsəd əldə olunmuş hesab olunacaq"}, {"i": 401, "t": "Sağlıklı tedavi, mesleki yükseliş ve hastalarınıza faydalı olmanızı dilerim."}, {"i": 402, "t": "Kənan Rəhimov"}, {"i": 403, "t": "Bakü, 2026"}, {"i": 404, "t": "← Önceki"}, {"i": 405, "t": "Ekler A–E"}, {"i": 406, "t": "Yukarı"}, {"i": 407, "t": "Kapat"}, {"i": 408, "t": "27. KP"}, {"i": 409, "t": "Kitabın siparişi"}, {"i": 410, "t": "Kitap basılı yayına hazırlanıyor. İlk okuyucular arasında olmak istiyorsanız bilgilerinizi bırakın — yayınlandığı anda hemen sizinle iletişime geçeceğiz."}, {"i": 411, "t": "Ad Soyad"}, {"i": 412, "t": "Adınız ve soyadınız"}, {"i": 413, "t": "Mobil numara"}, {"i": 414, "t": "+994 XX XXX XX XX"}, {"i": 415, "t": "Sipariş et"}, {"i": 416, "t": "Teşekkür ederiz!"}, {"i": 417, "t": "Kitap yayınlandığı anda sizinle iletişime geçeceğiz."}]