[{"i": 692, "t": "Affektiv simptomlar."}, {"i": 693, "t": "İnsomni (7A00)"}, {"i": 694, "t": "Yetersiz uyku."}, {"i": 695, "t": "Klein-Levin sindromu"}, {"i": 696, "t": "Epizodik 1–2 haftalık hipersomni + iştah."}, {"i": 697, "t": "7. Muayene ve değerlendirme"}, {"i": 698, "t": "Epworth, PSG + MSLT."}, {"i": 699, "t": "Tibbi laborator."}, {"i": 700, "t": "8. Tedavi"}, {"i": 701, "t": "Modafinil, armodafinil — birinci basamak."}, {"i": 702, "t": "Uyarıcılar (metilfenidat, amfetamin) — refrakter."}, {"i": 703, "t": "Pitolisant (FDA 2019, idiyopatik ve narkolepsi)."}, {"i": 704, "t": "Solriamfetol (FDA 2019)."}, {"i": 705, "t": "Uyku hijyeni ve davranış müdahalesi (planlanmış gündüz uykuları)."}, {"i": 706, "t": "Kleine-Levin — destekleyici; epizodlar arası asemptomatik."}, {"i": 707, "t": "Kaynağa özgü belirteçler"}, {"i": 708, "t": "AASM Treatment Guidelines (Maski K. et al. 2021)."}, {"i": 709, "t": "Tedavi metodolojileri"}, {"i": 710, "t": "Modafinil/Armodafinil"}, {"i": 711, "t": "Wakefulness-promoting; birinci basamak; baş ağrısı, anksiyete yan etki."}, {"i": 712, "t": "Çoklu Uyku Latansı Testi (MSLT — Multiple Sleep Latency Test)"}, {"i": 713, "t": "— 5 uyku denemesi 2 saat arayla; uyku latansı ölçümü."}, {"i": 714, "t": "Pitolisant ve Solriamfetol"}, {"i": 715, "t": "Yeni ilaçlar; refrakter vakada."}, {"i": 716, "t": "9. Proqnoz"}, {"i": 717, "t": "Kronik; farmakoterapi ile fonksiyonel iyileşme."}, {"i": 718, "t": "10. Mit ve yanlış inançlar"}, {"i": 719, "t": "Efsane 1: \"Gündüz uykululuğu 'tembellik'tir\""}, {"i": 720, "t": "Kanıt:"}, {"i": 721, "t": "klinik durum; mortalite ve kaza riskinde artış."}, {"i": 722, "t": "Efsane 2: \"Kafein hipersomni için yeterlidir\""}, {"i": 723, "t": "Kanıt:"}, {"i": 724, "t": "Kafein adjunkt; modafinil veya stimülan gereklidir."}, {"i": 725, "t": "Efsane 3: \"Hipersomni yalnızca depresyon belirtisidir\""}, {"i": 726, "t": "Kanıt:"}, {"i": 727, "t": "idiyopatik hipersomni ayrı bir bozukluktur; MSLT ayırt eder."}, {"i": 728, "