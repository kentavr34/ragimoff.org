"ПСИХИЧЕСКИЕ РАССТРОЙСТВА ВО ВРЕМЯ БЕРЕМЕННОСТИ (ПЕРИНАТАЛЬНАЯ ДЕПРЕССИЯ/ПСИХОЗ)"}, {"i": 242, "t": "6E20.0"}, {"i": 243, "t": "ЭМОЦИОНАЛЬНАЯ РЕАКЦИЯ ПОСЛЕ РАННИХ РОДОВ («Baby blues»)"}, {"i": 244, "t": "6E20"}, {"i": 245, "t": "ПОСЛЕРОДОВАЯ ДЕПРЕССИЯ (PPD)"}, {"i": 246, "t": "6E21"}, {"i": 247, "t": "ПОСЛЕРОДОВОЙ ПСИХОЗ (PPP)"}, {"i": 248, "t": "6E20"}, {"i": 249, "t": "ПОСЛЕРОДОВАЯ ТРЕВОГА, ОКР, ПТСР"}, {"i": 250, "t": "6E40"}, {"i": 251, "t": "ПСИХОСОМАТИЧЕСКИЕ ФАКТОРЫ"}, {"i": 252, "t": "6E60–6E6Z"}, {"i": 253, "t": "ВТОРИЧНЫЕ ПСИХИЧЕСКИЕ И ПОВЕДЕНЧЕСКИЕ СИНДРОМЫ"}, {"i": 254, "t": "7A00–7B2Z"}, {"i": 255, "t": "РАССТРОЙСТВА СНА"}, {"i": 256, "t": "HA00–HA8Z"}, {"i": 257, "t": "СЕКСУАЛЬНЫЕ ДИСФУНКЦИИ И НАРУШЕНИЯ СЕКСУАЛЬНОГО ЗДОРОВЬЯ"}, {"i": 258, "t": "ПРИЛОЖЕНИЯ"}, {"i": 259, "t": "ПРИЛОЖЕНИЕ А"}, {"i": 260, "t": "СТАНДАРТЫ МОНИТОРИНГА И ОБСЛЕДОВАНИЯ"}, {"i": 261, "t": "Данное приложение по использованию психотропных препаратов"}, {"i": 262, "t": "мониторинг безопасности"}, {"i": 263, "t": "и психиатрических пациентов"}, {"i": 264, "t": "мониторинг медицинского состояния"}, {"i": 265, "t": "представляет стандартные протоколы для."}, {"i": 266, "t": "A.1. Antipsikotik terapiyada metabolik monitorinq"}, {"i": 267, "t": "Атипичные антипсихотики – особенно оланзапин, кветиапин, клозапин –"}, {"i": 268, "t": "повышает риск метаболического синдрома"}, {"i": 269, "t": "(увеличение веса, дислипидемия, инсулинорезистентность, диабет)."}, {"i": 270, "t": "График мониторинга (APA/ADA 2004, Освещенный ADA-APA-ACP-NAASO):"}, {"i": 271, "t": "Parametr"}, {"i": 272, "t": "Начало"}, {"i": 273, "t": "4 недели"}, {"i": 274, "t": "8 недель"}, {"i": 275, "t": "12 недель"}, {"i": 276, "t": "Ежеквартально"}, {"i": 277, "t": "Ежегодный"}, {"i": 278, "t": "Личный/семейный анамнез"}, {"i": 279, "t": "Вес, окружность талии."}, {"i": 280, "t": "Артериальное давление"}, {"i": 281, "t": "Глюкоза натощак"}, {"i": 282, "t": "Липидный профиль натощак"}, {"i": 283, "t": "✓ (1 раз в 2 года)"}, {"i": 284, "t": "Если обнаружена аномалия:"}, {"i": 285, "t": "Увеличение веса ≥7%:"}, {"i": 286, "t": "смотри замену препарата (арипипразол, зипрасидон – метаболически нейтральные);"}, {"i": 287, "t": "HbA1c ≥6,5% или глюкоза натощак ≥7:"}, {"i": 288, "t": "консультация диабетолога;"}, {"i": 289, "t": "LDL ≥3,4 ммоль/л:"}, {"i": 290, "t": "диета, статины."}, {"i": 291, "t": "Специфический мониторинг клозапина (из-за агранулоцитоза):"}, {"i": 292, "t": "Длительность"}, {"i": 293, "t": "Tezlik"}, {"i": 294, "t": "Первые 6 месяцев"}, {"i": 295, "t": "Еженедельно WBC и абсолютные нейтрофилы (ANC)"}, {"i": 296, "t": "7–12 ay"}, {"i": 297, "t": "Раз в 2 недели"}, {"i": 298, "t": "12+ ay"}, {"i": 299, "t": "Ежемесячно"}, {"i": 300, "t": "Показатели ANC:"}, {"i": 301, "t": "≥2,0 × 10⁹/Л:"}, {"i": 302, "t": "норма — продолжайте лечение;"}, {"i": 303, "t": "еженедельное наблюдение;"}, {"i": 304, "t": "Наблюдение каждые 2 дня, консультация гематолога;"}, {"i": 305, "t": "&lt;1,0:"}, {"i": 306, "t": "препарат отменяется, вмешательство гематолога"}, {"i": 307, "t": "Мониторинг ЭКГ при приеме антипсихотиков:"}, {"i": 308, "t": "29. Риск удлинения QTc:"}, {"i": 309, "t": "особенно зипрасидон, галоперидол в/в, ондансетрон в комбинации;"}, {"i": 310, "t": "Начальная ЭКГ"}, {"i": 311, "t": "у пациентов с факторами риска (сердечное заболевание, нарушение электролитного баланса, >65 лет);"}, {"i": 312, "t": "QTc >500 мс или увеличение >60 мс от исходного уровня"}, {"i": 313, "t": "Изменение лекарственной терапии"}, {"i": 314, "t": "Лекарственные средства, повышающие риск:"}, {"i": 315, "t": "хлорпромазин, галоперидол (высокий), тиоридазин."}, {"i": 316, "t": "Hiperprolaktinemiya:"}, {"i": 317, "t": "Risperidon, amisulprid, paliperidon"}, {"i": 318, "t": "– высокий риск;"}, {"i": 319, "t": "Симптомы: аменорея, галакторея, сексуальная дисфункция, остеопороз;"}, {"i": 320, "t": "Базальный пролактин; при повторном симптоме."}, {"i": 321, "t": "A.2. Litium monitorinqi"}, {"i": 322, "t": "Узкое терапевтическое окно"}, {"i": 323, "t": "уровень 0,6–1,2 мЭкв/л"}, {"i": 324, "t": ", &gt;1,5 toksik."}, {"i": 325, "t": "Parametr"}, {"i": 326, "t": "Начало"}, {"i": 327, "t": "Каждые 6 месяцев"}, {"i": 328, "t": "Ежегодный"}, {"i": 329, "t": "Уровень лития"}, {"i": 330, "t": "Еженедельно в 1-й месяц, затем каждые 6 месяцев"}, {"i": 331, "t": "Kreatinin, eGFR"}, {"i": 332, "t": "TSH"}, {"i": 333, "t": "Электролиты"}, {"i": 334, "t": "КАЛЬЦИЙ"}, {"i": 335, "t": "EKG"}, {"i": 336, "t": "✓ (возраст 50+)"}, {"i": 337, "t": "Тест на беременность."}, {"i": 338, "t": "Женщина детородного возраста"}, {"i": 339, "t": "Признаки интоксикации литием:"}, {"i": 340, "t": "Тремор (более выраженный);"}, {"i": 341, "t": "Тахикардия;"}, {"i": 342, "t": "Диарея, рвота;"}, {"i": 343, "t": "Медленная, сбивчивая речь;"}, {"i": 344, "t": "Атаксия;"}, {"i": 345, "t": "Конвульсии — при тяжелых состояниях."}, {"i": 346, "t": "Проверьте уровень при изменении состояния:"}, {"i": 347, "t": "дегидратация, добавление НПВП, добавление ингибитора АПФ, изменение функции почек."}, {"i": 348, "t": "A.3. Antikonvulsantlar (valproat, karbamazepin, lamotrigin)"}, {"i": 349, "t": "Valproat:"}, {"i": 350, "t": "Parametr"}, {"i": 351, "t": "Начало"}, {"i": 352, "t": "Каждые 6 месяцев"}, {"i": 353, "t": "CBC (trombositopeniya)"}, {"i": 354, "t": "Функция печени (АСТ, АЛТ)"}, {"i": 355, "t": "33. Уровень вальпроата"}, {"i": 356, "t": "С симптомом или подозрением"}, {"i": 357, "t": "Мониторинг признаков панкреатита"}, {"i": 358, "t": "13. Каждый визит"}, {"i": 359, "t": "Тест на беременность."}, {"i": 360, "t": "КАТЕГОРИЧЕСКИ ПРОТИВОПОКАЗАНО у женщины детородного возраста"}]