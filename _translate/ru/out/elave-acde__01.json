[{"i": 361, "t": "6. Каждый квартал"}, {"i": 362, "t": "&gt;"}, {"i": 363, "t": "Kritik:"}, {"i": 364, "t": "valproat"}, {"i": 365, "t": "у женщин детородного возраста"}, {"i": 366, "t": "из-за дефекта нервной трубки и когнитивного повреждения"}, {"i": 367, "t": "только при эффективной контрацепции"}, {"i": 368, "t": ", после предварительной оценки других вариантов."}, {"i": 369, "t": "Karbamazepin:"}, {"i": 370, "t": "CBC, печень — исходно, через 1 месяц, ежеквартально;"}, {"i": 371, "t": "Тест HLA-B*1502"}, {"i": 372, "t": "У пациентов азиатского происхождения (риск Стивенса-Джонсона);"}, {"i": 373, "t": "Снижение уровня из-за аутоиндукции в первые 4 недели – проверь уровень."}, {"i": 374, "t": "Lamotrigin:"}, {"i": 375, "t": "Медленная титрация"}, {"i": 376, "t": "– Риск синдрома Стивенса-Джонсона;"}, {"i": 377, "t": "Начало 25 мг в неделю"}, {"i": 378, "t": ", в течение 4–8 недель до целевой дозы;"}, {"i": 379, "t": "32. В сочетании с вальпроатом:"}, {"i": 380, "t": "начальная доза 12,5 мг"}, {"i": 381, "t": "– вальпроат замедляет метаболизм ламотриджина;"}, {"i": 382, "t": "Если есть кожная реакция –"}, {"i": 383, "t": "немедленно прекратить."}, {"i": 384, "t": "A.4. Мониторинг СИОЗС и СИОЗСН"}, {"i": 385, "t": "Hiponatremiya riski"}, {"i": 386, "t": "– особенно у пожилых, принимающих диуретики;"}, {"i": 387, "t": "Bazal Na"}, {"i": 388, "t": ", через 1 месяц, затем с симптомом;"}, {"i": 389, "t": "Усиление суицидальности"}, {"i": 390, "t": "особенно при начале до 25 лет — тщательный мониторинг в первые 1-2 месяца;"}, {"i": 391, "t": "QTc uzanma"}, {"i": 392, "t": "– эсциталопрам, циталопрам (в высоких дозах);"}, {"i": 393, "t": "Serotonin sindromu"}, {"i": 394, "t": "(MAOI или триптан и др. в комбинации) – обучение симптомам."}, {"i": 395, "t": "A.5. Применение бензодиазепинов"}, {"i": 396, "t": "Максимальная продолжительность: 2–4 недели"}, {"i": 397, "t": "При длительном применении зависимость неизбежна;"}, {"i": 398, "t": "Azaltma sxemi (tapering):"}, {"i": 399, "t": "25% каждые 2 недели, иногда медленнее;"}, {"i": 400, "t": "Симптомы отдачи"}, {"i": 401, "t": "(рикошетная тревога, бессонница, тремор) — нормально и временно."}, {"i": 402, "t": "A.6. Psixoterapiya monitorinqi"}, {"i": 403, "t": "Показатели качества:"}, {"i": 404, "t": "Продолжительность сеанса, частота;"}, {"i": 405, "t": "Шкалы симптомов пациента (PHQ-9, GAD-7 и т.д.)"}, {"i": 406, "t": "каждые 4–6 недель"}, {"i": 407, "t": "Функциональные показатели;"}, {"i": 408, "t": "Оценка терапевтического альянса (Working Alliance Inventory);"}, {"i": 409, "t": "Достижение посторонних целей;"}, {"i": 410, "t": "Признаки рецидива."}, {"i": 411, "t": "Супервизия и коллегиальная консультация – для сложных пациентов и клинициста по запросу."}, {"i": 412, "t": "ПРИЛОЖЕНИЕ В"}, {"i": 413, "t": "ПСИХИАТРИЧЕСКИЕ НЕОТЛОЖНЫЕ СОСТОЯНИЯ"}, {"i": 414, "t": "Данное приложение представляет практический подход к угрожающим жизни или требующим неотложной клинической оценки психиатрическим состояниям."}, {"i": 415, "t": "C.1. Aktiv intihar riski"}, {"i": 416, "t": "Первичная оценка:"}, {"i": 417, "t": "Есть ли суицидальные мысли? План? Средства?"}, {"i": 418, "t": "Близость, конкретность:"}, {"i": 419, "t": "«Сегодня вечером мой двор топят палками...» против общего «Иногда я хочу умереть»;"}, {"i": 420, "t": "Предыдущие попытки"}, {"i": 421, "t": "– самый сильный предиктор;"}, {"i": 422, "t": "Интоксикация веществом"}, {"i": 423, "t": "– снижение ингибиции;"}, {"i": 424, "t": "Protektiv faktorlar"}, {"i": 425, "t": "– семейные, религиозные убеждения, будущие планы."}, {"i": 426, "t": "Признаки высокого риска:"}, {"i": 427, "t": "Конкретный план + доступность средств;"}, {"i": 428, "t": "Недавнее изменение обстоятельств (утрата, тяжёлое заболевание);"}, {"i": 429, "t": "Одиночество + гнев;"}, {"i": 430, "t": "7. Психоз или тяжелая депрессия;"}, {"i": 431, "t": "Впервые возникшая или глубокая гипомания (энергия возвращается + низкое настроение сохраняется);"}, {"i": 432, "t": "Взрослый мужчина + инвалидность + алкоголь."}, {"i": 433, "t": "Управление:"}, {"i": 434, "t": "Низко-средний риск:"}, {"i": 435, "t": "План безопасности"}, {"i": 436, "t": "– письменный;"}, {"i": 437, "t": "38. Снижение доступности средств (удаление оружия, лекарства в малых количествах);"}, {"i": 438, "t": "Частое амбулаторное наблюдение (повторно через 24-48 часов);"}, {"i": 439, "t": "Номер линии кризиса;"}, {"i": 440, "t": "Участие семьи (с согласия)."}, {"i": 441, "t": "Высокий риск:"}, {"i": 442, "t": "госпитализация"}, {"i": 443, "t": "(добровольно или принудительно);"}, {"i": 444, "t": "Пристальное наблюдение – 1:1 при очень высоком риске;"}, {"i": 445, "t": "Устранение средств суицида (острые предметы, верёвка, окно);"}, {"i": 446, "t": "Контролируемый прием лекарств."}, {"i": 447, "t": "Принудительная госпитализация в контексте Азербайджана:"}, {"i": 448, "t": "Закон Азербайджанской Республики «О психиатрической помощи»;"}, {"i": 449, "t": "Для принудительной госпитализации"}, {"i": 450, "t": "решение двух психиатров"}, {"i": 451, "t": "и юридическая процедура;"}, {"i": 452, "t": "Судебное решение после 72 часов экстренного наблюдения."}, {"i": 453, "t": "C.2. Делирий тременс и отмена алкоголя"}, {"i": 454, "t": "Simptomlar:"}, {"i": 455, "t": "тремор"}, {"i": 456, "t": "– руки, затем общее;"}, {"i": 457, "t": "Тревога, ажитация;"}, {"i": 458, "t": "галлюцинация"}, {"i": 459, "t": "– визуальные, тактильные («насекомые на мне»);"}, {"i": 460, "t": "Дезориентация;"}, {"i": 461, "t": "Autonom hiperaktivlik"}, {"i": 462, "t": "– тахикардия, давление, потливость, лихорадка;"}, {"i": 463, "t": "Tutmalar"}, {"i": 464, "t": "Лечение (в условиях ОИТ или ПИТ):"}, {"i": 465, "t": "бензодиазепин"}, {"i": 466, "t": "диазепам 10-20 мг в/в или в/м каждые 15-20 мин"}, {"i": 467, "t": "до достижения седации; затем поддерживающий режим;"}, {"i": 468, "t": "Альтернатива: лоразепам (при дисфункции печени);"}, {"i": 469, "t": "Tiamin 100-300 mq IV"}, {"i": 470, "t": "– Профилактика энцефалопатии Вернике."}, {"i": 471, "t": "До введения глюкозы"}, {"i": 472, "t": "Жидкость и электролиты"}, {"i": 473, "t": "восстановление;"}, {"i": 474, "t": "Магния сульфат, калий – чаще всего снижены;"}, {"i": 475, "t": "Смертность: без лечения 15-20%, при адекватном лечении <1%."}, {"i": 476, "t": "Шкала CIWA-Ar — для мониторинга."}, {"i": 477, "t": "C.3. Serotonin sindromu"}, {"i": 478, "t": "Причина:"}, {"i": 479, "t": "СИОЗС + ИМАО, СИОЗС + триптан, СИОЗС + трамадол, СИОЗС + линезолид, СИОЗС + метиленовый синий и др."}, {"i": 480, "t": "Simptomlar:"}, {"i": 481, "t": "Изменение психики"}, {"i": 482, "t": "– ажитация, спутанность сознания;"}, {"i": 483, "t": "Autonom"}, {"i": 484, "t": "– тахикардия, гипертония, гипертермия, потливость;"}, {"i": 485, "t": "Neyromuskulyar"}, {"i": 486, "t": "– tremor, hiperrefleksiya,"}, {"i": 487, "t": "klonus"}, {"i": 488, "t": "(нижние конечности – специфический признак)."}, {"i": 489, "t": "Лечение:"}, {"i": 490, "t": "Немедленная отмена причинного препарата;"}, {"i": 491, "t": "Поддержка — жидкости, электролиты, охлаждение;"}, {"i": 492, "t": "В тяжелых случаях"}, {"i": 493, "t": "ципрогептадин 12 мг начально, 2 мг каждый час, максимум 32 мг/сут"}, {"i": 494, "t": "Инвазивное вмешательство (интубация) при тяжёлой гипертермии."}, {"i": 495, "t": "C.4. Antipsixotik Malign Sindrom (NMS)"}, {"i": 496, "t": "Причина:"}, {"i": 497, "t": "12. антипсихотики (особенно высокопотентные, галоперидол), острое начало или увеличение дозы."}, {"i": 498, "t": "Симптомы (4 основных):"}, {"i": 499, "t": "Мышечная ригидность"}, {"i": 500, "t": "(«железная труба»);"}, {"i": 501, "t": "Hipertermiya"}, {"i": 502, "t": "(38–42°C);"}, {"i": 503, "t": "Вегетативная лабильность"}, {"i": 504, "t": "(высокое артериальное давление, тахикардия, потливость);"}, {"i": 505, "t": "Изменение психического состояния"}, {"i": 506, "t": "(спутанность → ступор → кома)."}, {"i": 507, "t": "Laboratoriya:"}, {"i": 508, "t": "Резкое повышение КФК"}, {"i": 509, "t": "(>1000), миоглобинурия, лейкоцитоз, повышенные ALT/AST."}, {"i": 510, "t": "Лечение (ОИТ):"}, {"i": 511, "t": "Немедленная отмена антипсихотика;"}, {"i": 512, "t": "Бред;"}, {"i": 513, "t": "Жидкости (риск рабдомиолиза и острой почечной недостаточности);"}, {"i": 514, "t": "Dantrolen"}, {"i": 515, "t": "1-2,5 мг/кг в/в – уменьшает мышечную ригидность;"}, {"i": 516, "t": "Bromokriptin"}, {"i": 517, "t": "2,5–5 мг каждые 8 часов – агонист дофамина;"}, {"i": 518, "t": "ЭСТ при отсутствии ответа на терапию."}, {"i": 519, "t": "Смертность:"}, {"i": 520, "t": "5-20% при адекватном лечении."}, {"i": 521, "t": "C.5. Острая дистония"}, {"i": 522, "t": "Причина:"}, {"i": 523, "t": "11. начало приема антипсихотика, особенно сильных антагонистов D2."}, {"i": 524, "t": "Simptomlar:"}, {"i": 525, "t": "Острые мышечные спазмы — шеи (кривошея), языка, глаз (окулогирный криз), определенный спазм пищевода;"}, {"i": 526, "t": "17. Угроза жизни – ларингоспазм."}, {"i": 527, "t": "Лечение:"}, {"i": 528, "t": "Difenhidramin"}, {"i": 529, "t": "50 мг в/м или в/в – облегчение через 15 минут;"}, {"i": 530, "t": "Benztropin"}, {"i": 531, "t": "1-2 мг в/м/в/в;"}, {"i": 532, "t": "Снижение дозы или замена антипсихотика;"}, {"i": 533, "t": "Профилактические антихолинергические средства у пациентов с риском."}, {"i": 534, "t": "C.6. Острая мания и психомоторное возбуждение"}, {"i": 535, "t": "Управление:"}, {"i": 536, "t": " - Предпочтительно перорально: галоперидол 2-5 мг + лоразепам 1-2 мг;"}, {"i": 537, "t": " - В/м по показаниям: галоперидол 5 мг + лоразепам 2 мг (50/50 шприц) или оланзапин в/м 10 мг;"}, {"i": 538, "t": "Безопасная среда"}, {"i": 539, "t": "– спокойная, свободная от стимулов обстановка;"}, {"i": 540, "t": "Verbal de-eskalasiya"}, {"i": 541, "t": "первый шаг;"}, {"i": 542, "t": "Лекарства:"}, {"i": 543, "t": "недобровольная госпитализация"}, {"i": 544, "t": "по указанию;"}, {"i": 545, "t": "Физическое сдерживание"}, {"i": 546, "t": "– только как крайняя мера, угроза жизни, краткосрочно."}, {"i": 547, "t": "C.7. Острый психоз"}, {"i": 548, "t": "Протокол, аналогичный вышеуказанному. Дифференциал: органические причины, интоксикация веществами, послеродовой психоз, ЗНС."}, {"i": 549, "t": "C.8. Katatoniya"}, {"i": 550, "t": "Simptomlar:"}, {"i": 551, "t": "Ступор, мутизм;"}, {"i": 552, "t": "Каталепсия («флексибильность воска»);"}, {"i": 553, "t": "Негативизм;"}, {"i": 554, "t": "Манерности, стереотипии;"}, {"i": 555, "t": "Eholalia, ekopraksiya."}, {"i": 556, "t": "Лечение первой линии:"}, {"i": 557, "t": "Lorazepam 1-2 mq IV/IM test"}, {"i": 558, "t": "– Значимый ответ в течение 1-2 часов → диагноз и лечение кататонии;"}, {"i": 559, "t": "При получении ответа — довести до дозы 4–24 мг/сут;"}, {"i": 560, "t": "Без ответа —"}, {"i": 561, "t": "ECT"}, {"i": 562, "t": "Вторая линия, очень эффективна;"}, {"i": 563, "t": "Избегать антипсихотиков"}, {"i": 564, "t": "В острой фазе может спровоцировать развитие ЗНС."}, {"i": 565, "t": "Ищи причину:"}, {"i": 566, "t": "органические (энцефалит, эпилепсия), расстройства настроения, шизофрения, аутизм, некоторые вещества."}, {"i": 567, "t": "ПРИЛОЖЕНИЕ Г"}, {"i": 568, "t": "ВОЕННО-ВРАЧЕБНАЯ ЭКСПЕРТИЗА (В АЗЕРБАЙДЖАНЕ)"}, {"i": 569, "t": "Данное приложение представляет практическое руководство по психиатрическим аспектам оценки годности к военной службе в Азербайджанской Республике."}, {"i": 570, "t": "D.1. Правовая основа"}, {"i": 571, "t": "«О военной службе»"}, {"i": 572, "t": "Закон Азербайджанской Республики;"}, {"i": 573, "t": "14. Положение о военно-врачебной экспертизе;"}, {"i": 574, "t": "Министерства обороны"}, {"i": 575, "t": "нормативные акты;"}, {"i": 576, "t": "Таблица болезней"}, {"i": 577, "t": "– делится на две части: легкие/тяжелые степени, группы A-D."}, {"i": 578, "t": "D.2. Структура психиатрической оценки"}, {"i": 579, "t": "Основная экспертиза:"}, {"i": 580, "t": "Жалобы и анамнез (пациент и близкие родственники);"}, {"i": 581, "t": "Предыдущие медицинские документы;"}, {"i": 582, "t": "Клиническое интервью и оценка психического статуса;"}, {"i": 583, "t": "Экспериментально-Психологическое Обследование"}, {"i": 584, "t": "(ЭПМ) – психологом;"}, {"i": 585, "t": "Лабораторные и инструментальные исследования при необходимости;"}]