[{"i": 688, "t": "Клиническое интервью."}, {"i": 689, "t": "EDE-Q, EDE."}, {"i": 690, "t": "Соматическое: электролиты (K, P, Mg, Cl), печень, почки, ЭКГ (QTc)."}, {"i": 691, "t": "Стоматологический осмотр (эрозия)."}, {"i": 692, "t": "Коморбидность и риск суицида."}, {"i": 693, "t": "6.4 Differensial diaqnostika"}, {"i": 694, "t": "Состояние"}, {"i": 695, "t": "Дифференцирующий"}, {"i": 696, "t": "Нервная анорексия, тип с перееданием/очищением (6B80)"}, {"i": 697, "t": "Значительно низкий вес."}, {"i": 698, "t": "BED (6B82)"}, {"i": 699, "t": "Компенсаторное поведение отсутствует."}, {"i": 700, "t": "Night Eating Syndrome"}, {"i": 701, "t": "Преобладает ночное потребление пищи."}, {"i": 702, "t": "Klein-Levin sindromu"}, {"i": 703, "t": "Hipersomniya + hiperfagiya."}, {"i": 704, "t": "7. Обследование и оценка"}, {"i": 705, "t": "EDE-Q."}, {"i": 706, "t": "Соматическое: электролиты, ЭКГ, стоматологический осмотр."}, {"i": 707, "t": "C-SSRS."}, {"i": 708, "t": "8. Лечение"}, {"i": 709, "t": "КПТ-У — первая линия"}, {"i": 710, "t": "(Fairburn) — 20 сеансов за 20 недель; доказательства: Fairburn C.G. et al. Behav Res Ther 2009."}, {"i": 711, "t": "Флуоксетин 60 мг/сут"}, {"i": 712, "t": "— Одобрение FDA для BN; уменьшает переедание и рвоту."}, {"i": 713, "t": "FBT (Lock J., Le Grange D.) — у подростков."}, {"i": 714, "t": "ИПТ альтернатив."}, {"i": 715, "t": "Соматическое: коррекция электролитов, рефидинг-синдром, стоматологическая помощь."}, {"i": 716, "t": "Bupropion"}, {"i": 717, "t": "Экстракт"}, {"i": 718, "t": "(tutma riski)."}, {"i": 719, "t": "Уточнения по источнику"}, {"i": 720, "t": "23. NICE NG69 — CBT-E первой линии; FBT у подростков."}, {"i": 721, "t": "APA 2023."}, {"i": 722, "t": "Методики лечения"}, {"i": 723, "t": "CBT-E (Fairburn)"}, {"i": 724, "t": "— 20 сессий; трансдиагностический; разрыв цикла переедания-очищения."}, {"i": 725, "t": "Fluoksetin 60 mq"}, {"i": 726, "t": "— Одобрение FDA; снижает частоту переедания ~50%."}, {"i": 727, "t": "FBT для BN"}, {"i": 728, "t": "— Адаптировано для подростков."}, {"i": 729, "t": "Интерперсональная терапия (ИПТ / IPT — Interpersonal Therapy)"}, {"i": 730, "t": "— Альтернативный; медленный ответ, но долгосрочный эффект."}, {"i": 731, "t": "9. Proqnoz"}, {"i": 732, "t": "50–70% ремиссия при CBT-E; важно долгосрочное наблюдение."}, {"i": 733, "t": "10. Мифы и ложные убеждения"}, {"i": 734, "t": "Миф 1: «Булимия — это „неудачная диета“»"}, {"i": 735, "t": "Доказательства:"}, {"i": 736, "t": "клиническое нарушение; типичным триггером является рестриктивная диета."}, {"i": 737, "t": "Миф 2: «Рвота — эффективный метод снижения веса»"}, {"i": 738, "t": "Доказательства:"}, {"i": 739, "t": "рвота предотвращает лишь 30–50% усвоения калорий; серьёзные медицинские осложнения."}, {"i": 740, "t": "Миф 3: \"Бупропион как антидепрессант может применяться при НПП\""}, {"i": 741, "t": "Доказательства:"}, {"i": 742, "t": "bupropion BN-da"}, {"i": 743, "t": "Является экстрактом"}, {"i": 744, "t": "— высокий риск судорог."}, {"i": 745, "t": "Миф 4: «При нервной булимии, если вес нормальный, проблемы нет»"}, {"i": 746, "t": "Доказательства:"}, {"i": 747, "t": "медицинские осложнения (электролитные, кардиальные) и психиатрическая нагрузка значительны."}, {"i": 748, "t": "Миф 5: «Достаточно только антидепрессанта»"}, {"i": 749, "t": "Доказательства:"}, {"i": 750, "t": "Комбинация КПТ-У + фармакотерапия превосходит монотерапию."}, {"i": 751, "t": "11. Источники"}, {"i": 752, "t": "ВОЗ. МКБ-11. 6B81 Нервная булимия. 2024."}, {"i": 753, "t": "APA. DSM-5-TR. 2022."}, {"i": 754, "t": "NICE NG69. 2017/2020."}, {"i": 755, "t": "APA. Practice Guideline for Eating Disorders, 4th ed. 2023."}, {"i": 756, "t": "Fairburn C.G. Cognitive Behavior Therapy and Eating Disorders. Guilford Press; 2008."}, {"i": 757, "t": "Russell G. Нервная булимия: an ominous variant of нервной анорексии. Psychol Med 1979;9(3):429–448."}, {"i": 758, "t": "← 6B80"}, {"i": 759, "t": "НЕРВНАЯ АНОРЕКСИЯ"}, {"i": 760, "t": "↑ Глава"}, 