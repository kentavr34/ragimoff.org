[{"i": 586, "t": "Дифференциальный, оценка диагноза и степени тяжести заболевания;"}, {"i": 587, "t": "Результат."}, {"i": 588, "t": "1. Типичные психологические тесты (EPM):"}, {"i": 589, "t": "MMPI-2"}, {"i": 590, "t": "(Minnesota Multiphasic Personality Inventory-2) – профиль личности;"}, {"i": 591, "t": "Прогрессивные матрицы Равена"}, {"i": 592, "t": "– интеллект;"}, {"i": 593, "t": "Тесты Лурии"}, {"i": 594, "t": "– память, внимание;"}, {"i": 595, "t": "Шкала интеллекта Векслера (WAIS)."}, {"i": 596, "t": "Rorschach testi"}, {"i": 597, "t": "– проективные (спорная современная надежность);"}, {"i": 598, "t": "Шкалы Бека, Гамильтона"}, {"i": 599, "t": "– настроение."}, {"i": 600, "t": "D.3. Психиатрические расстройства и оценка годности к военной службе"}, {"i": 601, "t": "Классификация по группам (адаптация – на основе местных нормативных актов):"}, {"i": 602, "t": "Группа А – полностью годен к службе"}, {"i": 603, "t": "Психиатрический анамнез отсутствует или имеются незначительные преходящие проблемы."}, {"i": 604, "t": "Группа B – ограниченно пригоден"}, {"i": 605, "t": "Легкие черты личности (не достигающие порога расстройства);"}, {"i": 606, "t": "Временные расстройства адаптации;"}, {"i": 607, "t": "Легкие расстройства сна;"}, {"i": 608, "t": "Невротические расстройства в стадии ремиссии."}, {"i": 609, "t": "Группа V — ограничен во время службы"}, {"i": 610, "t": "Умеренные психические расстройства в случае частичной ремиссии;"}, {"i": 611, "t": "Определенные расстройства личности;"}, {"i": 612, "t": "Перенесенное ПТСР, компенсированное;"}, {"i": 613, "t": "Умеренная нейрокогнитивная дисфункция."}, {"i": 614, "t": "22. Группа Q – не годен к службе"}, {"i": 615, "t": "Спектр шизофрении;"}, {"i": 616, "t": "Биполярное расстройство;"}, {"i": 617, "t": "Тяжелая депрессия;"}, {"i": 618, "t": "Активное ПТСР/комплексное ПТСР (ветераны Карабахской войны — отдельная программа лечения);"}, {"i": 619, "t": "Расстройства употребления вещества;"}, {"i": 620, "t": "Тяжелые расстройства личности;"}, {"i": 621, "t": "Умственная отсталость;"}, {"i": 622, "t": "Тяжелые формы расстройства аутистического спектра;"}, {"i": 623, "t": "Расстройства с активным суицидальным риском;"}, {"i": 624, "t": "Парафилические расстройства (тяжелые, активные)."}, {"i": 625, "t": "D.4. Послеродовая травма и оценка ветеранов"}, {"i": 626, "t": "У ветеранов Карабахской войны:"}, {"i": 627, "t": "Комплексное ПТСР: высокая распространённость"}, {"i": 628, "t": "– травма-ориентированное вмешательство;"}, {"i": 629, "t": "Употребление алкоголя и психоактивных веществ"}, {"i": 630, "t": "коморбидный;"}, {"i": 631, "t": "Депрессия, риск суицида;"}, {"i": 632, "t": "Нарушение семейной функции;"}, {"i": 633, "t": "Моральный вред"}, {"i": 634, "t": "– этический конфликт во время боевых действий (убийство, свидетельствование);"}, {"i": 635, "t": "Ожог и повторная травматизация"}, {"i": 636, "t": "факторы риска."}, {"i": 637, "t": "Специфические программы реабилитации:"}, {"i": 638, "t": "Терапия травмы с подтвержденной эффективностью (PE, CPT, EMDR);"}, {"i": 639, "t": "Групповая терапия для ветеранов;"}, {"i": 640, "t": "Семейная терапия;"}, {"i": 641, "t": "Препарат (СИОЗС/СИОЗСН);"}, {"i": 642, "t": "Социальная реабилитация (работа, образование)."}, {"i": 643, "t": "ПРИЛОЖЕНИЕ Д"}, {"i": 644, "t": "СВЯЗАННЫЕ НЕВРОЛОГИЧЕСКИЕ СОСТОЯНИЯ"}, {"i": 645, "t": "Краткое описание неврологических заболеваний, важных для клинической практики на стыке психиатрии и неврологии."}, {"i": 646, "t": "E.1. Эпилепсия (G40) и психиатрические проявления"}, {"i": 647, "t": "Эпилептические синдромы и психиатрия:"}, {"i": 648, "t": "- Межприступные изменения личности (синдром Гешвинда – гиперрелигиозность, гиперграфия, «вязкость»);"}, {"i": 649, "t": " - Интериктальный психоз – длительная височная эпилепсия;"}, {"i": 650, "t": " - Постиктальный психоз – психотические эпизоды в течение 24-72 часов после приступа;"}, {"i": 651, "t": " - Иктальная тревога и диссоциативные переживания;"}, {"i": 652, "t": "Височная эпилепсия (TLE)"}, {"i": 653, "t": "– наиболее частая психиатрическая коморбидность:"}, {"i": 654, "t": "Абсансная эпилепсия"}, {"i": 655, "t": "– проблема внимания, дифференциальная диагностика с СДВГ;"}, {"i": 656, "t": "Juvenile miyoklonik epilepsiya"}, {"i": 657, "t": "– высокая коморбидная тревога, импульсивность."}, {"i": 658, "t": "Psikogen (qeyri-epileptik) tutmalar (PNES) – dissosiativ neyroloji simptom pozuntusu ("}, {"i": 659, "t": "6B60.4"}, {"i": 660, "t": "Video-EEG"}, {"i": 661, "t": "– золотой стандарт дифференциальной диагностики;"}, {"i": 662, "t": "PNES — часто коморбидна с эпилепсией, 10-30%;"}, {"i": 663, "t": "Лечение: КПТ-ПНЭС, медленная отмена антиконвульсантов."}, {"i": 664, "t": "Психиатрические побочные эффекты антиэпилептиков:"}, {"i": 665, "t": "Levetirasetam:"}, {"i": 666, "t": "21. агрессия, раздражительность, депрессия;"}, {"i": 667, "t": "Fenobarbital, primidon:"}, {"i": 668, "t": "депрессия, когнитивное замедление;"}, {"i": 669, "t": "Topiramat:"}, {"i": 670, "t": "Когнитивная дисфункция, депрессия;"}, {"i": 671, "t": "Lamotrigin:"}, {"i": 672, "t": "снова стабилизирует настроение."}, {"i": 673, "t": "E.2. Головная боль и психиатрическая коморбидность"}, {"i": 674, "t": "Migren"}, {"i": 675, "t": "– риск депрессии в 2-4 раза выше; тревожные расстройства;"}, {"i": 676, "t": "Кластерная головная боль"}, {"i": 677, "t": "– депрессия, риск суицида;"}, {"i": 678, "t": "Хроническая ежедневная головная боль"}, {"i": 679, "t": "– злоупотребление анальгетиками (MOH) – частая коморбидность с расстройством настроения;"}, {"i": 680, "t": "Хроническая головная боль напряжения"}, {"i": 681, "t": "– связано с интенсивным стрессом, тревогой."}, {"i": 682, "t": "Управление:"}, {"i": 683, "t": "ССРИ/СИОЗСН улучшают многие типы головной боли;"}, {"i": 684, "t": "TCA (амитриптилин) — исторический стандарт для профилактической мигрени;"}, {"i": 685, "t": "30. Топирамат, вальпроат профилактически;"}, {"i": 686, "t": "КПТ эффективна при хронической головной боли;"}, {"i": 687, "t": "Избегать употребления опиоидов и чрезмерного использования анальгетиков."}, {"i": 688, "t": "E.3. Цереброваскулярные заболевания (инсульт)"}, {"i": 689, "t": "Post-stroke depressiya:"}, {"i": 690, "t": "30–40% в первый год;"}, {"i": 691, "t": "Post-stroke mania:"}, {"i": 692, "t": "редко, при повреждениях правой лобной доли или таламуса;"}, {"i": 693, "t": "Pseudobulbar affekt"}, {"i": 694, "t": "(патологический смех/плач):"}, {"i": 695, "t": "комбинация декстрометорфан-хинидин"}, {"i": 696, "t": "Является подтвержденным лечением;"}, {"i": 697, "t": "Vaskulyar koqnitiv pozuntu/demensiya:"}, {"i": 698, "t": "6D81"}, {"i": 699, "t": "0. классификация под;"}, {"i": 700, "t": "Reabilitasiya:"}, {"i": 701, "t": "в роли мультидисциплинарного, психиатрического центра поддержки."}, {"i": 702, "t": "E.4. Болезнь Паркинсона"}, {"i": 703, "t": "Depressiya:"}, {"i": 704, "t": "Тревога:"}, {"i": 705, "t": "Импульсивное расстройство контроля, индуцированное агонистами дофамина:"}, {"i": 706, "t": "Parkinsonda psixoz:"}, {"i": 707, "t": "Преимущественно зрительные галлюцинации; индуцированные леводопой;"}, {"i": 708, "t": "Parkinsonda demensiya:"}, {"i": 709, "t": "6D85"}, {"i": 710, "t": "Расстройство поведения в фазе быстрого сна:"}, {"i": 711, "t": "Ранний маркер для болезни Паркинсона."}, {"i": 712, "t": "Особенности лечения:"}, {"i": 713, "t": "Применение антипсихотиков при болезни Паркинсона:"}, {"i": 714, "t": "kvetiapin, klozapin"}, {"i": 715, "t": "(Минимальная блокада D2);"}, {"i": 716, "t": "Haloperidol, risperidon"}, {"i": 717, "t": "– ухудшает моторные симптомы;"}, {"i": 718, "t": "СССР"}, {"i": 719, "t": "для депрессии;"}, {"i": 720, "t": "Pimavanserin"}, {"i": 721, "t": "– Одобрен в США для психоза при болезни Паркинсона."}, {"i": 722, "t": "E.5. Multipl skleroz (MS)"}, {"i": 723, "t": "Depressiya:"}, {"i": 724, "t": "Тревога:"}, {"i": 725, "t": "35. Симптомы, сходные с биполярным расстройством:"}, {"i": 726, "t": "Псевдобульбарный аффект;"}, {"i": 727, "t": "Koqnitiv disfunksiya"}, {"i": 728, "t": "– в большинстве случаев заболевания;"}, {"i": 729, "t": "Оцепенение и утомляемость"}, {"i": 730, "t": "– тесная связь с депрессией, сложная дифференциальная диагностика."}, {"i": 731, "t": "Терапия интерфероном-бета"}, {"i": 732, "t": "ухудшает депрессию – активный мониторинг."}, {"i": 733, "t": "E.6. Черепно-мозговая травма (ЧМТ)"}, {"i": 734, "t": "Post-konkussion sindromu:"}, {"i": 735, "t": "головная боль, головокружение, проблемы с памятью, изменения настроения;"}, {"i": 736, "t": "Хроническая травматическая энцефалопатия (CTE):"}, {"i": 737, "t": "Повторные травмы, спорт (бокс, американский футбол);"}, {"i": 738, "t": "PTSD + TBZ"}, {"i": 739, "t": "– очень часто коморбидный;"}, {"i": 740, "t": "Изменение личности"}, {"i": 741, "t": "6E68"}, {"i": 742, "t": ") – при фронтальных поражениях."}, {"i": 743, "t": "E.7. Деменция (подробно в Разделе 17)"}, {"i": 744, "t": "6D80"}, {"i": 745, "t": "Альцгеймер;"}, {"i": 746, "t": "6D81"}, {"i": 747, "t": "Сосудистый;"}, {"i": 748, "t": "6D82"}, {"i": 749, "t": "Телец Леви;"}, {"i": 750, "t": "6D83"}, {"i": 751, "t": "Лобно-височная;"}, {"i": 752, "t": "6D84"}, {"i": 753, "t": "Связанное с веществом;"}, {"i": 754, "t": "6D85"}, {"i": 755, "t": "С болезнью Паркинсона;"}, {"i": 756, "t": "6D86"}, {"i": 757, "t": "Поведенческие/психологические расстройства при деменции (BPSD)."}, {"i": 758, "t": "E.8. Судороги, двигательные расстройства и психиатрия"}, {"i": 759, "t": "Tourette sindromu (8A05.00)"}, {"i": 760, "t": "– В МКБ-11 в разделе неврологических заболеваний, но коморбидность с СДВГ и ОКР очень высока;"}, {"i": 761, "t": "Болезнь Вильсона"}, {"i": 762, "t": "– генетическое нарушение метаболизма меди; частые психиатрические проявления (депрессия, психоз); проверка – церулоплазмин, суточная моча на медь;"}, {"i": 763, "t": "Болезнь Гентингтона"}, {"i": 764, "t": "– расстройства настроения, ОКР, психоз, моторная хорея."}, {"i": 765, "t": "ОБЩИЕ ИСТОЧНИКИ И ЛИТЕРАТУРА"}, {"i": 766, "t": "Основные источники МКБ-11 и DSM-5"}, {"i": 767, "t": "WHO."}, {"i": 768, "t": "Клинические описания и диагностические требования for WHO, 2019, вступление в силу 2022 — МКБ-11 Психические, поведенческие расстройства и нарушения нейроразвития (КОДТ)."}, {"i": 769, "t": "Женева: Всемирная организация здравоохранения; 2024. ISBN: 9789240077263."}, {"i": 770, "t": "APA."}, {"i": 771, "t": "Diagnostic and Statistical Manual of Mental Disorders, 5th Edition, Text Revision (DSM-5-TR)."}, {"i": 772, "t": "APA Publishing; 2022."}, {"i": 773, "t": "First MB, Reed GM, Hyman SE, Saxena S."}, {"i": 774, "t": "Разработка ВОЗ, 2019 г., вступление в силу 2022 г. — XBT-11 Clinical Descriptions and Diagnostic Guidelines for Mental and Behavioural Disorders."}, {"i": 775, "t": "World Psychiatry"}, {"i": 776, "t": "Reed GM, et al."}, {"i": 777, "t": "Инновации и изменения в ВОЗ, 2019, вступление в силу 2022 — МКБ-11: классификация психических, поведенческих расстройств и расстройств нейроразвития."}, {"i": 778, "t": "World Psychiatry"}, {"i": 779, "t": "Учебники клинической психиатрии."}, {"i": 780, "t": "Popov Yu.V., Vid V.D."}, {"i": 781, "t": "Современная клиническая психиатрия."}, {"i": 782, "t": "(Современная клиническая психиатрия) 2-е издание. Санкт-Петербург: Речь, 2006."}, {"i": 783, "t": "Sadock BJ, Sadock VA, Ruiz P."}, {"i": 784, "t": "Kaplan and Sadock's Comprehensive Textbook of Psychiatry."}, {"i": 785, "t": "11th ed. Wolters Kluwer; 2023."}, {"i": 786, "t": "Gelder MG, Andreasen NC, Lopez-Ibor JJ, Geddes JR (eds)."}, {"i": 787, "t": "New Oxford Textbook of Psychiatry."}, {"i": 788, "t": "3rd ed. Oxford UP; 2020."}, {"i": 789, "t": "Cowen P, Harrison P, Burns T."}, {"i": 790, "t": "Shorter Oxford Textbook of Psychiatry."}, {"i": 791, "t": "7-е изд. Oxford UP; 2018."}, {"i": 792, "t": "Источники на азербайджанском языке"}, {"i": 793, "t": "Министерство здравоохранения Азербайджанской Республики."}, {"i": 794, "t": "Нормативные документы по обследованию и лечению психически больных."}, {"i": 795, "t": "«О психиатрической помощи»"}, {"i": 796, "t": "Закон Азербайджанской Республики (2001, с изменениями)."}, {"i": 797, "t": "Praktik klinik qaydalar (guidelines)"}, {"i": 798, "t": "NICE (UK) Clinical Guidelines – по психиатрическим состояниям: CG31 ОКР, CG78 ПРЛ, CG90 Депрессия, CG113 ГТР, CG115 Алкоголь, CG158 Расстройства поведения, NG69 Расстройства пищевого поведения, NG116 ПТСР, CG111 Энурез."}]