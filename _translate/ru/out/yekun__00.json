"i": 239, "t": "Развернуть/свернуть"}, {"i": 240, "t": "6E20"}, {"i": 241, "t": "ПСИХИЧЕСКИЕ РАССТРОЙСТВА ВО ВРЕМЯ БЕРЕМЕННОСТИ (ПЕРИНАТАЛЬНАЯ ДЕПРЕССИЯ/ПСИХОЗ)"}, {"i": 242, "t": "6E20.0"}, {"i": 243, "t": "ЭМОЦИОНАЛЬНАЯ РЕАКЦИЯ ПОСЛЕ РАННИХ РОДОВ («Baby blues»)"}, {"i": 244, "t": "6E20"}, {"i": 245, "t": "ПОСЛЕРОДОВАЯ ДЕПРЕССИЯ (PPD)"}, {"i": 246, "t": "6E21"}, {"i": 247, "t": "ПОСЛЕРОДОВОЙ ПСИХОЗ (PPP)"}, {"i": 248, "t": "6E20"}, {"i": 249, "t": "ПОСЛЕРОДОВАЯ ТРЕВОГА, ОКР, ПТСР"}, {"i": 250, "t": "6E40"}, {"i": 251, "t": "ПСИХОСОМАТИЧЕСКИЕ ФАКТОРЫ"}, {"i": 252, "t": "6E60–6E6Z"}, {"i": 253, "t": "ВТОРИЧНЫЕ ПСИХИЧЕСКИЕ И ПОВЕДЕНЧЕСКИЕ СИНДРОМЫ"}, {"i": 254, "t": "7A00–7B2Z"}, {"i": 255, "t": "РАССТРОЙСТВА СНА"}, {"i": 256, "t": "HA00–HA8Z"}, {"i": 257, "t": "СЕКСУАЛЬНЫЕ ДИСФУНКЦИИ И НАРУШЕНИЯ СЕКСУАЛЬНОГО ЗДОРОВЬЯ"}, {"i": 258, "t": "ИТОГОВЫЕ РЕКОМЕНДАЦИИ"}, {"i": 259, "t": "Практическое собрание для клиницистов."}, {"i": 260, "t": "Основные клинические уроки, полученные из всех глав книги:"}, {"i": 261, "t": "Диагноз всегда второй шаг, а не первый"}, {"i": 262, "t": "Перед постановкой диагноза психического расстройства обязательно:"}, {"i": 263, "t": "3. Исключите медицинские причины."}, {"i": 264, "t": "– особенно при начале в возрасте 40–50 лет, острое начало, атипичный профиль, соматические симптомы, изменения гормонального цикла;"}, {"i": 265, "t": "Проверьте употребление вещества"}, {"i": 266, "t": "– в 30% случаев скрытый компонент психоактивных веществ;"}, {"i": 267, "t": "Активно спрашивайте анамнез травмы"}, {"i": 268, "t": "– комплексное ПТСР и расстройства личности часто являются следствием травмы, но без скрининга травматического анамнеза не выявляются."}, {"i": 269, "t": "ВОЗ, 2019, вступила в силу 2022 — МКБ-11 принцип «первичное vs вторичное» — основная рамка для клинициста."}, {"i": 270, "t": "Психотерапия – первый выбор в большинстве случаев"}, {"i": 271, "t": "ВОЗ, 2019, вступление в силу 2022 — центральное послание эпохи МКБ-11:"}, {"i": 272, "t": "эффективность психотерапии подтверждена, она как минимум не уступает фармакотерапии, а при многих расстройствах превосходит:"}, {"i": 273, "t": "При легкой-умеренной депрессии"}, {"i": 274, "t": "– КПТ, ИПТ наравне с СИОЗС;"}, {"i": 275, "t": "При тревожных расстройствах"}, {"i": 276, "t": "– КПТ 1-я линия;"}, {"i": 277, "t": "При ОКР"}, {"i": 278, "t": "– Для ОКР: ЭРП обязательно; дополнение СИОЗС;"}, {"i": 279, "t": "При ПТСР"}, {"i": 280, "t": "– ТФ-КПТ, ДПДГ 1-я линия;"}, {"i": 281, "t": "При расстройствах личности"}, {"i": 282, "t": "– ДПТ, МПТ, ТФП – эффективнее фармакотерапии;"}, {"i": 283, "t": "При расстройствах пищевого поведения"}, {"i": 284, "t": "– КПТ-Р, СТ;"}, {"i": 285, "t": "При детских расстройствах поведения"}, {"i": 286, "t": "– программы обучения родителей."}, {"i": 287, "t": "Farmakoterapiya"}, {"i": 288, "t": "во многих случаях адъюнкт – помогает пациенту повысить и сохранить эффективность психотерапии."}, {"i": 289, "t": "Принцип минимальной эффективной дозы"}, {"i": 290, "t": "Начало низкое, повышать медленно"}, {"i": 291, "t": "Достижение строго минимальной эффективной дозы"}, {"i": 292, "t": "Избегайте полипрагмазии"}, {"i": 293, "t": "– особенно у пожилых, при коморбидности, расстройствах личности;"}, {"i": 294, "t": "Отмена или снижение дозы препарата"}, {"i": 295, "t": "требует знаний — СИОЗС нельзя отменять резко, бензодиазепины следует отменять постепенно."}, {"i": 296, "t": "Работа с культурой и контекстом"}, {"i": 297, "t": "В контексте Азербайджана:"}, {"i": 298, "t": "Соматическая презентация"}, {"i": 299, "t": "очень распространено – в первичном звене депрессия, тревога требуют активного скрининга;"}, {"i": 300, "t": "Стигма и конфиденциальность."}, {"i": 301, "t": "– визит к психиатру скрывается; работа на базе первичного звена или терапевта эффективна;"}, {"i": 302, "t": "Семейная система сильна"}, {"i": 303, "t": "– участие семьи в лечении является большим ресурсом;"}, {"i": 304, "t": "Религиозные и культурные убеждения"}, {"i": 305, "t": "– следует учитывать, но для отсутствия патологического сюжета;"}, {"i": 306, "t": "Ветераны Карабахской войны"}, {"i": 307, "t": "– ПТСР, КПТСР, высокая потребность в травма-ориентированном вмешательстве."}, {"i": 308, "t": "Скрининг должен быть стандартным в первичном звене здравоохранения"}, {"i": 309, "t": "Наиболее основные скрининговые инструменты должны рутинно применяться в первичном звене здравоохранения:"}, {"i": 310, "t": "PHQ-9"}, {"i": 311, "t": "– депрессия (при каждом медицинском визите);"}, {"i": 312, "t": "GAD-7"}, {"i": 313, "t": "– тревога;"}, {"i": 314, "t": "AUDIT"}, {"i": 315, "t": "– употребление алкоголя;"}, {"i": 316, "t": "EPDS"}, {"i": 317, "t": "– перинатальные женщины;"}]