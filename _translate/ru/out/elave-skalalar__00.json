1, "t": "ПСИХИЧЕСКИЕ РАССТРОЙСТВА ВО ВРЕМЯ БЕРЕМЕННОСТИ (ПЕРИНАТАЛЬНАЯ ДЕПРЕССИЯ/ПСИХОЗ)"}, {"i": 242, "t": "6E20.0"}, {"i": 243, "t": "ЭМОЦИОНАЛЬНАЯ РЕАКЦИЯ ПОСЛЕ РАННИХ РОДОВ («Baby blues»)"}, {"i": 244, "t": "6E20"}, {"i": 245, "t": "ПОСЛЕРОДОВАЯ ДЕПРЕССИЯ (PPD)"}, {"i": 246, "t": "6E21"}, {"i": 247, "t": "ПОСЛЕРОДОВОЙ ПСИХОЗ (PPP)"}, {"i": 248, "t": "6E20"}, {"i": 249, "t": "ПОСЛЕРОДОВАЯ ТРЕВОГА, ОКР, ПТСР"}, {"i": 250, "t": "6E40"}, {"i": 251, "t": "ПСИХОСОМАТИЧЕСКИЕ ФАКТОРЫ"}, {"i": 252, "t": "6E60–6E6Z"}, {"i": 253, "t": "ВТОРИЧНЫЕ ПСИХИЧЕСКИЕ И ПОВЕДЕНЧЕСКИЕ СИНДРОМЫ"}, {"i": 254, "t": "7A00–7B2Z"}, {"i": 255, "t": "РАССТРОЙСТВА СНА"}, {"i": 256, "t": "HA00–HA8Z"}, {"i": 257, "t": "СЕКСУАЛЬНЫЕ ДИСФУНКЦИИ И НАРУШЕНИЯ СЕКСУАЛЬНОГО ЗДОРОВЬЯ"}, {"i": 258, "t": "ПРИЛОЖЕНИЕ Б"}, {"i": 259, "t": "ШКАЛЫ СКРИНИНГА НАРУШЕНИЙ НЕЙРОРАЗВИТИЯ"}, {"i": 260, "t": "&gt;"}, {"i": 261, "t": "Правила применения:"}, {"i": 262, "t": "Эти шкалы"}, {"i": 263, "t": "не диагностические, а скрининговые инструменты"}, {"i": 264, "t": ". Положительный результат – показание для специализированной клинической оценки,"}, {"i": 265, "t": "diaqnoz deyil."}, {"i": 266, "t": "Окончательный диагноз устанавливается посредством клинического интервью, детальной оценки и (при необходимости) стандартизированных диагностических инструментов (ADOS-2, ADI-R, WISC-V и др.)."}, {"i": 267, "t": "&gt;"}, {"i": 268, "t": "&gt;"}, {"i": 269, "t": "Lisenziya statusu:"}, {"i": 270, "t": "Все шкалы, представленные в данном приложении, являются инструментами, открыто предоставленными разработчиками для научных исследований и клинического использования."}, {"i": 271, "t": "B.1. M-CHAT-R: Модифицированный скрининговый опросник на аутизм (дети 16–30 месяцев)"}, {"i": 272, "t": "Оригинальные авторы:"}, {"i": 273, "t": "Diana L. Robins, Deborah Fein, Marianne Barton, 2009."}, {"i": 274, "t": "Orijinal istinad:"}, {"i": 275, "t": "Robins DL, Fein D, Barton M. M-CHAT-R/F. Self-published, 2009; Pediatrics, 2014; 133: 37–45."}, {"i": 276, "t": "Инструкция"}, {"i": 277, "t": "Данная анкета состоит из 20 вопросов о повседневном поведении вашего ребенка."}, {"i": 278, "t": "Заполняется родителем или основным опекуном."}, {"i": 279, "t": "На каждый вопрос"}, {"i": 280, "t": "ДА"}, {"i": 281, "t": "или"}, {"i": 282, "t": "Нет"}, {"i": 283, "t": "отвечайте как – вашего ребенка"}, {"i": 284, "t": "Обычно"}, {"i": 285, "t": "на основании того, как он себя ведёт. Если вы видели такое поведение один-два раза, но в целом ребёнок так не делает,"}, {"i": 286, "t": "Нет"}, {"i": 287, "t": "ответьте."}, {"i": 288, "t": "Suallar"}, {"i": 289, "t": "Sual"}, {"i": 290, "t": "ДА"}, {"i": 291, "t": "Нет"}, {"i": 292, "t": "Если вы посмотрите на что-то на другом конце комнаты, посмотрит ли туда же ваш ребенок? (Например, на пролетающий самолет, большое животное или игрушку)"}, {"i": 293, "t": "Вы когда-нибудь думали, что ваш ребенок глухой?"}, {"i": 294, "t": "Играет ли ваш ребенок в воображаемые игры? (Например, пьет из пустой чашки, разговаривает по телефону, кормит куклу)"}, {"i": 295, "t": "Любит ли ваш ребенок карабкаться на предметы? (Например, лестницу, дерево)"}, {"i": 296, "t": "Совершает ли ваш ребенок необычные движения ладонями, пальцами или другими частями тела перед глазами?"}, {"i": 297, "t": "Указывает ли ваш ребенок на то, что он хочет? (Например, на игрушку, находящуюся далеко на полке)"}, {"i": 298, "t": "Указывает ли ваш ребенок, чтобы привлечь ваше внимание к чему-то интересному? (Например, на самолет в небе или большую машину)"}, {"i": 299, "t": "Проявляет ли ваш ребенок интерес к другим детям? (Например, смотрит на детей на игровой площадке, пытается к ним присоединиться)"}, {"i": 300, "t": "Делится ли ваш ребенок с вами, показывая или кладя перед вами что-то (не для помощи, а для того, чтобы поделиться)?"}, {"i": 301, "t": "Реагирует ли ваш ребенок, когда его называют по имени?"}, {"i": 302, "t": "Улыбается ли ваш ребенок вам в ответ, когда вы ему улыбаетесь?"}, {"i": 303, "t": "Беспокоит ли вашего ребенка повседневные звуки? (Например, пылесос, громкая музыка)"}, {"i": 304, "t": "Ходит ли ваш ребенок?"}, {"i": 305, "t": "Смотрит ли ваш ребенок вам в глаза, когда вы одеваете его или играете с ним?"}, {"i": 306, "t": "Подражает ли ваш ребенок вашим действиям? (Например, когда вы делаете что-то с лицом, он делает то же самое)"}, {"i": 307, "t": "Смотрит ли ваш ребенок на вас, когда слышит что-то, чтобы понять, что происходит?"}]