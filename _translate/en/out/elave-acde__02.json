[{"i": 586, "t": "Differential, diagnosis, and assessment of disease severity;"}, {"i": 587, "t": "Conclusion."}, {"i": 588, "t": "Typical psychological tests (EPM):"}, {"i": 589, "t": "MMPI-2"}, {"i": 590, "t": "(Minnesota Multiphasic Personality Inventory-2) – personality profile;"}, {"i": 591, "t": "Raven Progressive Matrices"}, {"i": 592, "t": "– intellect;"}, {"i": 593, "t": "Luria tests"}, {"i": 594, "t": "– memory, attention;"}, {"i": 595, "t": "Wechsler IQ scale (WAIS)"}, {"i": 596, "t": "Rorschach testi"}, {"i": 597, "t": "– projective (controversial modern reliability);"}, {"i": 598, "t": "Beck, Hamilton scales"}, {"i": 599, "t": "– mood."}, {"i": 600, "t": "D.3. Psychiatric disorders and military fitness assessment"}, {"i": 601, "t": "Classification by group (adaptation – based on local normative acts):"}, {"i": 602, "t": "Group A – fully fit for service"}, {"i": 603, "t": "No psychiatric history or minor transient issues."}, {"i": 604, "t": "Group B – useful with limitations"}, {"i": 605, "t": "Mild personality traits (below impairment threshold);"}, {"i": 606, "t": "Transient adjustment disorders;"}, {"i": 607, "t": "Mild sleep disturbances;"}, {"i": 608, "t": "Neurotic disorders in remission state."}, {"i": 609, "t": "Group V — limited during service"}, {"i": 610, "t": "Moderate psychiatric disturbances in partial remission state;"}, {"i": 611, "t": "Specific personality disorders;"}, {"i": 612, "t": "Past PTSD, compensated;"}, {"i": 613, "t": "Moderate neurocognitive dysfunction."}, {"i": 614, "t": "Group Q – Unfit for Service"}, {"i": 615, "t": "Schizophrenia spectrum;"}, {"i": 616, "t": "Bipolar disorder;"}, {"i": 617, "t": "Severe depression;"}, {"i": 618, "t": "Active PTSD/complex PTSD (Karabakh war veterans – separate treatment program);"}, {"i": 619, "t": "Substance use disorders;"}, {"i": 620, "t": "Severe personality disorders;"}, {"i": 621, "t": "Mental retardation;"}, {"i": 622, "t": "Severe forms of autism spectrum;"}, {"i": 623, "t": "Disorders with active suicide risk;"}, {"i": 624, "t": "Paraphilic disorders (severe, active)."}, {"i": 625, "t": "D.4. Postpartum trauma and veteran assessment"}, {"i": 626, "t": "In veterans of the Karabakh war:"}, {"i": 627, "t": "Complex PTSD high prevalence."}, {"i": 628, "t": "– trauma-focused intervention;"}, {"i": 629, "t": "Alcohol and substance use"}, {"i": 630, "t": "Comorbid;"}, {"i": 631, "t": "Depression, suicide risk;"}, {"i": 632, "t": "Family dysfunction;"}, {"i": 633, "t": "Moral injury"}, {"i": 634, "t": "– ethical conflict during war (killing, witnessing);"}, {"i": 635, "t": "Burning and re-traumatization"}, {"i": 636, "t": "risk factors."}, {"i": 637, "t": "Specific rehabilitation programs:"}, {"i": 638, "t": "Evidence-based trauma therapies (PE, CPT, EMDR);"}, {"i": 639, "t": "Group therapy for veterans;"}, {"i": 640, "t": "Family therapy;"}, {"i": 641, "t": "Medication (SSRI/SNRI);"}, {"i": 642, "t": "Social rehabilitation (work, education)."}, {"i": 643, "t": "APPENDIX E"}, {"i": 644, "t": "RELATED NEUROLOGICAL CONDITIONS"}, {"i": 645, "t": "Brief description of neurological diseases important for clinical practice in areas intersecting psychiatry and neurology."}, {"i": 646, "t": "E.1. Epilepsy (G40) and psychiatric manifestations"}, {"i": 647, "t": "Epileptic syndromes and psychiatry:"}, {"i": 648, "t": " - Interictal personality changes (Geschwind syndrome – hyper religiosity, hypergraphia, \"viscosity\");"}, {"i": 649, "t": " - Inter-ictal psychosis – long-standing TLE;"}, {"i": 650, "t": " - Post-ictal psychosis – psychotic episodes within 24-72 hours after a seizure;"}, {"i": 651, "t": " - Ictal anxiety and dissociative experiences;"}, {"i": 652, "t": "Temporal lobe epilepsy (TLE)."}, {"i": 653, "t": "– psychiatric comorbidity most common:"}, {"i": 654, "t": "Absence epilepsy"}, {"i": 655, "t": "– attention problems, differential with ADHD;"}, {"i": 656, "t": "Juvenile miyoklonik epilepsiya"}, {"i": 657, "t": "– high comorbid anxiety, impulsivity."}, {"i": 658, "t": "Psikogen (qeyri-epileptik) tutmalar (PNES) – dissosiativ neyroloji simptom pozuntusu ("}, {"i": 659, "t": "6B60.4"}, {"i": 660, "t": "Video-EEG"}, {"i": 661, "t": "– gold standard differential;"}, {"i": 662, "t": "PNES frequently comorbid with epilepsy, 10-30%;"}, {"i": 663, "t": "Treatment: CBT-PNES, slow tapering of anticonvulsants."}, {"i": 664, "t": "Psychiatric side effects of antiepileptics:"}, {"i": 665, "t": "Levetirasetam:"}, {"i": 666, "t": "Aggression, irritability, depression;"}, {"i": 667, "t": "Fenobarbital, primidon:"}, {"i": 668, "t": "depression, cognitive slowing;"}, {"i": 669, "t": "Topiramat:"}, {"i": 670, "t": "cognitive dysfunction, depression;"}, {"i": 671, "t": "Lamotrigin:"}, {"i": 672, "t": "Gene stabilizes mood."}, {"i": 673, "t": "E.2. Headache and psychiatric comorbidity"}, {"i": 674, "t": "Migren"}, {"i": 675, "t": "– depression risk 2-4× higher; anxiety disorders;"}, {"i": 676, "t": "Cluster headache."}, {"i": 677, "t": "– depression, suicide risk;"}, {"i": 678, "t": "Chronic daily headache"}, {"i": 679, "t": "– analgesic overuse (medication overuse headache – MOH) – mood disorder comorbid frequently;"}, {"i": 680, "t": "Recurrent tension headache"}, {"i": 681, "t": "– associated with intense stress, anxiety."}, {"i": 682, "t": "Management:"}, {"i": 683, "t": "SSRI/SNRI improves many types of headache;"}, {"i": 684, "t": "TCA (amitriptiline) historical standard for migraine prophylaxis"}, {"i": 685, "t": "Topiramate, valproate prophylactic;"}, {"i": 686, "t": "CBT is effective for chronic headache;"}, {"i": 687, "t": "Avoidance of opioids and excessive analgesic use."}, {"i": 688, "t": "E.3. Cerebrovascular diseases (stroke)"}, {"i": 689, "t": "Post-stroke depressiya:"}, {"i": 690, "t": "30-40% first year;"}, {"i": 691, "t": "Post-stroke mania:"}, {"i": 692, "t": "Rare, in right frontal or thalamic lesions;"}, {"i": 693, "t": "Pseudobulbar affekt"}, {"i": 694, "t": "(pathological laughing/crying):"}, {"i": 695, "t": "dextromethorphan-quinidine combination"}, {"i": 696, "t": "confirmatory treatment is;"}, {"i": 697, "t": "Vaskulyar koqnitiv pozuntu/demensiya:"}, {"i": 698, "t": "6D81"}, {"i": 699, "t": "Under classification;"}, {"i": 700, "t": "Reabilitasiya:"}, {"i": 701, "t": "Multidisciplinary, psychiatric support plays a central role."}, {"i": 702, "t": "E.4. Parkinson's disease"}, {"i": 703, "t": "Depressiya:"}, {"i": 704, "t": "Anxiety:"}, {"i": 705, "t": "Dopamine agonist-induced impulse control disorder:"}, {"i": 706, "t": "Parkinsonda psixoz:"}, {"i": 707, "t": "Mainly visual hallucinations; levodopa-induced;"}, {"i": 708, "t": "Parkinsonda demensiya:"}, {"i": 709, "t": "6D85"}, {"i": 710, "t": "REM sleep behavior disorder"}, {"i": 711, "t": "Early marker for Parkinson's disease."}, {"i": 712, "t": "Treatment characteristics:"}, {"i": 713, "t": "Use of antipsychotics in Parkinson's disease:"}, {"i": 714, "t": "kvetiapin, klozapin"}, {"i": 715, "t": "(D2 minimal blockade);"}, {"i": 716, "t": "Haloperidol, risperidon"}, {"i": 717, "t": "– worsens motor symptoms;"}, {"i": 718, "t": "Soviet Socialist Republics"}, {"i": 719, "t": "depression;"}, {"i": 720, "t": "Pimavanserin"}, {"i": 721, "t": "– Confirmed for Parkinson psychosis in the USA."}, {"i": 722, "t": "E.5. Multipl skleroz (MS)"}, {"i": 723, "t": "Depressiya:"}, {"i": 724, "t": "Anxiety:"}, {"i": 725, "t": "Bipolar-like symptoms:"}, {"i": 726, "t": "Pseudobulbar affect;"}, {"i": 727, "t": "Koqnitiv disfunksiya"}, {"i": 728, "t": "– in most illnesses;"}, {"i": 729, "t": "Lethargy and fatigue"}, {"i": 730, "t": "– closely associated with depression, differential diagnosis difficult."}, {"i": 731, "t": "Interferon-beta therapy"}, {"i": 732, "t": "Depression worsens – active monitoring."}, {"i": 733, "t": "E.6. Traumatic brain injury (TBI)"}, {"i": 734, "t": "Post-konkussion sindromu:"}, {"i": 735, "t": "headache, dizziness, memory issues, mood changes;"}, {"i": 736, "t": "Chronic traumatic encephalopathy (CTE):"}, {"i": 737, "t": "repeated injuries, sports (boxing, American football);"}, {"i": 738, "t": "PTSD + TBZ"}, {"i": 739, "t": "– very frequently comorbid;"}, {"i": 740, "t": "Personality change"}, {"i": 741, "t": "6E68"}, {"i": 742, "t": ") – in frontal lesions."}, {"i": 743, "t": "E.7. Dementia (detailed in Section 17)"}, {"i": 744, "t": "6D80"}, {"i": 745, "t": "Alzheimer's;"}, {"i": 746, "t": "6D81"}, {"i": 747, "t": "Vascular"}, {"i": 748, "t": "6D82"}, {"i": 749, "t": "Lewy body;"}, {"i": 750, "t": "6D83"}, {"i": 751, "t": "Frontotemporal;"}, {"i": 752, "t": "6D84"}, {"i": 753, "t": "Substance-related;"}, {"i": 754, "t": "6D85"}, {"i": 755, "t": "With Parkinson's disease;"}, {"i": 756, "t": "6D86"}, {"i": 757, "t": "Behavioral/psychological disturbances in dementia (BPSD)"}, {"i": 758, "t": "E.8. Seizures, movement disorders, and psychiatry"}, {"i": 759, "t": "Tourette sindromu (8A05.00)"}, {"i": 760, "t": "– In ICD-11, under neurological disorders section, but highly comorbid with ADHD, OCD."}, {"i": 761, "t": "Wilson's disease"}, {"i": 762, "t": "– genetic disorder of copper metabolism; psychiatric presentation (depression, psychosis) frequent; investigation – ceruloplasmin, 24-hour urinary copper;"}, {"i": 763, "t": "Huntington's disease"}, {"i": 764, "t": "– mood disorders, OCD, psychosis, motor chorea."}, {"i": 765, "t": "GENERAL SOURCES AND REFERENCES"}, {"i": 766, "t": "Main ICD-11 and DSM-5 sources"}, {"i": 767, "t": "WHO."}, {"i": 768, "t": "Clinical Descriptions and Diagnostic Guidelines for WHO, 2019, effective 2022 — ICD-11 Mental, Behavioural and Neurodevelopmental Disorders (CDDG)."}, {"i": 769, "t": "Geneva: World Health Organization; 2024. ISBN: 9789240077263."}, {"i": 770, "t": "APA."}, {"i": 771, "t": "Diagnostic and Statistical Manual of Mental Disorders, 5th Edition, Text Revision (DSM-5-TR)."}, {"i": 772, "t": "APA Publishing; 2022."}, {"i": 773, "t": "First MB, Reed GM, Hyman SE, Saxena S."}, {"i": 774, "t": "The development of the WHO, 2019, entered into force 2022 — ICD-11 Clinical Descriptions and Diagnostic Guidelines for Mental and Behavioural Disorders."}, {"i": 775, "t": "World Psychiatry"}, {"i": 776, "t": "Reed GM, et al."}, {"i": 777, "t": "Innovations and changes in the WHO, 2019, effective 2022 — ICD-11 classification of mental, behavioural and neurodevelopmental disorders."}, {"i": 778, "t": "World Psychiatry"}, {"i": 779, "t": "Clinical psychiatry textbooks"}, {"i": 780, "t": "Popov Yu.V., Vid V.D."}, {"i": 781, "t": "Modern clinical psychiatry."}, {"i": 782, "t": "(Modern Clinical Psychiatry) 2nd edition. St. Petersburg: Rech, 2006."}, {"i": 783, "t": "Sadock BJ, Sadock VA, Ruiz P."}, {"i": 784, "t": "Kaplan and Sadock's Comprehensive Textbook of Psychiatry."}, {"i": 785, "t": "11th ed. Wolters Kluwer; 2023."}, {"i": 786, "t": "Gelder MG, Andreasen NC, Lopez-Ibor JJ, Geddes JR (eds)."}, {"i": 787, "t": "New Oxford Textbook of Psychiatry."}, {"i": 788, "t": "3rd ed. Oxford UP; 2020."}, {"i": 789, "t": "Cowen P, Harrison P, Burns T."}, {"i": 790, "t": "Shorter Oxford Textbook of Psychiatry."}, {"i": 791, "t": "7th ed. Oxford UP; 2018."}, {"i": 792, "t": "Sources in Azerbaijani language"}, {"i": 793, "t": "Ministry of Health of the Republic of Azerbaijan."}, {"i": 794, "t": "\"Regulatory documents on examination and treatment of mental patients\"."}, {"i": 795, "t": "\"On psychiatric assistance\""}, {"i": 796, "t": "Law of the Republic of Azerbaijan (2001, with amendments)."}, {"i": 797, "t": "Praktik klinik qaydalar (guidelines)"}, {"i": 798, "t": "NICE (UK) Clinical Guidelines – psychiatric conditions: CG31 OCD, CG78 BPD, CG90 Depression, CG113 GAD, CG115 Alcohol, CG158 Conduct disorders, NG69 Eating disorders, NG116 PTSD, CG111 Enuresis."}]